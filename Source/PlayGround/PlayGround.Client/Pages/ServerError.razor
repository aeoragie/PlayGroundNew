@* 500 — 전역 예외 경계(App.razor)가 여기로 보낸다. 오류 코드 + 데이터 안심 문구(Design.Navigation). *@
@attribute [Route(Routes.ServerError)]
@layout LandingLayout
@using PlayGround.Client.Components.Shared.Error
@using PlayGround.Client.Styles
@inject NavigationManager Nav

<PageTitle>일시적인 오류가 발생했어요 — PlayGround</PageTitle>

<div class="min-h-screen bg-bg flex flex-col text-navy-deep">
    <PublicGnb />
    <ErrorPageBody Kind="ErrorPageBody.Art.Scoreboard" StatusCode="500" Title="일시적인 오류가 발생했어요">
        <Description>서버에 문제가 생겨 요청을 처리하지 못했어요.<br />잠시 후 다시 시도해 주세요. 기록·데이터는 안전하게 보관되어 있어요.</Description>
        <Actions>
            <button type="button" @onclick="Retry" class="@Css.Error.PrimaryButton">다시 시도</button>
            <a href="@Routes.Landing" class="@Css.Error.SecondaryButton">홈으로</a>
        </Actions>
        <Footnote>
            문제가 계속되면 고객센터로 알려주세요. 오류 코드: <span class="@Css.Error.ErrorCode">@mErrorCode</span>
        </Footnote>
    </ErrorPageBody>
</div>

@code {
    /// <summary>예외 경계가 만든 오류 코드. 직접 진입 시엔 이 화면에서 새로 만든다.</summary>
    [SupplyParameterFromQuery(Name = "code")]
    public string? Code { get; set; }

    /// <summary>오류가 난 원래 경로 — "다시 시도"가 돌아갈 곳.</summary>
    [SupplyParameterFromQuery(Name = "from")]
    public string? From { get; set; }

    private string mErrorCode = string.Empty;

    protected override void OnInitialized()
    {
        mErrorCode = string.IsNullOrWhiteSpace(Code) ? BuildErrorCode() : Code;
    }

    /// <summary>ERR-{시각}-{요청ID} — 고객센터가 로그를 찾는 열쇠.</summary>
    internal static string BuildErrorCode()
    {
        string moment = DateTime.Now.ToString("yyyyMMddHHmm");
        string requestId = Guid.NewGuid().ToString("N")[..6].ToUpperInvariant();
        return $"ERR-{moment}-{requestId}";
    }

    // 원래 경로로 전체 새로고침 — 깨진 컴포넌트 상태를 남기지 않는다
    private void Retry()
    {
        string target = Routes.IsSafeReturnUrl(From) ? From! : Routes.Landing;
        Nav.NavigateTo(target, forceLoad: true);
    }
}
