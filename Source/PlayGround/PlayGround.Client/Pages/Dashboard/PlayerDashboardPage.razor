@attribute [Route(Routes.PlayerDashboard)]
@attribute [Route(Routes.PlayerDashboardSectionTemplate)]
@using System.Security.Claims
@using PlayGround.Client.Components.Dashboard.Player
@using PlayGround.Client.Services.Feedback
@using PlayGround.Contracts.Player
@using PlayGround.Contracts.Team
@using PlayGround.Domain.Soccer
@inject NavigationManager Nav
@inject JwtAuthenticationStateProvider AuthProvider
@inject PlayerClient Players
@inject ToastService Toasts
@inject ConfirmService Confirm

<PageTitle>선수 대시보드 — PlayGround</PageTitle>

@* P0 핵심 시나리오 = 보호자 대리 관리 (Claim 완료). 프로필은 백엔드 연동, 커리어·통계·포트폴리오는 레퍼런스 목업 *@

@* PC (≥1024px 설계 — md 브레이크포인트 공용): GNB + 사이드바 230px *@
<div class="hidden md:flex min-h-screen bg-surface-alt flex-col text-navy-deep">
    <PlayerDashboardGnb GuardianInitial="@GuardianInitial" />
    <div class="flex-1 flex items-stretch">
        @if (mInfo is not null)
        {
            <PlayerDashboardSidebar ActiveSection="@CurrentSection" PlayerName="@mInfo.Profile.Name"
                                    Summary="@SidebarSummary" TeamName="@mInfo.Profile.TeamName" />
        }
        <main class="flex-1 min-w-0 max-w-[1100px] px-[34px] py-[30px] flex flex-col gap-[18px]">
            @* 자녀가 2명 이상일 때만 나타난다 *@
            <ChildSwitcher Players="@ChildList" SelectedPlayerId="@SelectedPlayerId" SelectedPlayerIdChanged="SwitchChild" />
            @if (mInfo is not null)
            {
                @switch (CurrentSection)
                {
                    case SoccerPlayerDashboardSection.Career:
                        <LoadingGate IsLoading="@(mCareer is null && !mCareerFailed)" HasFailed="@mCareerFailed" OnRetry="LoadCareerAsync">
                            <Skeleton>
                                <SkeletonSection><SkeletonRows Count="3" /></SkeletonSection>
                            </Skeleton>
                            <ChildContent>
                                <PlayerCareerSection Entries="@mCareer!.Entries" OnAdd="OpenCareerAdd" OnEdit="OpenCareerEdit" OnDelete="DeleteCareerAsync" />
                            </ChildContent>
                        </LoadingGate>
                        break;
                    case SoccerPlayerDashboardSection.Stats:
                        <LoadingGate IsLoading="@(mStats is null && !mStatsFailed)" HasFailed="@mStatsFailed" OnRetry="RetryStatsAsync">
                            <Skeleton>
                                <SkeletonSection ShowAction="false">
                                    <SkeletonStatCards Count="5" />
                                    <SkeletonRows Count="4" />
                                </SkeletonSection>
                            </Skeleton>
                            <ChildContent>
                                <PlayerStatsSection Stats="@(mStats!)" OnSeasonSelected="LoadSeasonStatsAsync"
                                                    OnRequestCorrection="OpenCorrectionForm"
                                                    PendingCorrectionMatchIds="@PendingCorrectionMatchIds"
                                                    Corrections="@ChildCorrections" OnCancelCorrection="CancelCorrectionAsync" />
                            </ChildContent>
                        </LoadingGate>
                        break;
                    case SoccerPlayerDashboardSection.Portfolio:
                        <LoadingGate IsLoading="@(mPortfolio is null && !mPortfolioFailed)" HasFailed="@mPortfolioFailed" OnRetry="LoadPortfolioAsync">
                            <Skeleton>
                                <SkeletonSection><SkeletonRows Count="3" ShowChip="false" /></SkeletonSection>
                            </Skeleton>
                            <ChildContent>
                                <PlayerPortfolioSection Videos="@mPortfolio!.Videos" OnAdd="OpenPortfolioAdd" OnEdit="OpenPortfolioEdit" OnDelete="DeletePortfolioAsync" />
                            </ChildContent>
                        </LoadingGate>
                        break;
                    default:
                        <PlayerProfileSection Info="@mInfo" PlayerId="@SelectedPlayerId" OnClaimed="ReloadAsync" />
                        break;
                }
            }
        </main>
    </div>
</div>

@* 모바일 (<768px): 상단 바 + 하단 탭 4개 *@
<div class="md:hidden min-h-screen bg-surface-alt flex flex-col max-w-[480px] mx-auto text-navy-deep">
    @if (mInfo is not null)
    {
        <PlayerMobileTopBar PlayerName="@mInfo.Profile.Name" Summary="@MobileSummary" />
        <main class="flex-1 px-4 pt-[18px] pb-24 flex flex-col gap-3.5">
            <ChildSwitcher Players="@ChildList" SelectedPlayerId="@SelectedPlayerId" SelectedPlayerIdChanged="SwitchChild" />
            @switch (CurrentSection)
            {
                case SoccerPlayerDashboardSection.Career:
                    <LoadingGate IsLoading="@(mCareer is null && !mCareerFailed)" HasFailed="@mCareerFailed" OnRetry="LoadCareerAsync">
                        <Skeleton>
                            <SkeletonSection Compact="true"><SkeletonRows Count="3" /></SkeletonSection>
                        </Skeleton>
                        <ChildContent>
                            <MobilePlayerCareerSection Entries="@mCareer!.Entries" OnAdd="OpenCareerAdd" OnEdit="OpenCareerEdit" OnDelete="DeleteCareerAsync" />
                        </ChildContent>
                    </LoadingGate>
                    break;
                case SoccerPlayerDashboardSection.Stats:
                    <LoadingGate IsLoading="@(mStats is null && !mStatsFailed)" HasFailed="@mStatsFailed" OnRetry="RetryStatsAsync">
                        <Skeleton>
                            <SkeletonSection Compact="true" ShowAction="false">
                                <SkeletonStatCards Count="2" />
                                <SkeletonRows Count="3" />
                            </SkeletonSection>
                        </Skeleton>
                        <ChildContent>
                            <MobilePlayerStatsSection Stats="@(mStats!)" OnSeasonSelected="LoadSeasonStatsAsync"
                                                      OnRequestCorrection="OpenCorrectionForm"
                                                      PendingCorrectionMatchIds="@PendingCorrectionMatchIds"
                                                      Corrections="@ChildCorrections" OnCancelCorrection="CancelCorrectionAsync" />
                        </ChildContent>
                    </LoadingGate>
                    break;
                case SoccerPlayerDashboardSection.Portfolio:
                    <LoadingGate IsLoading="@(mPortfolio is null && !mPortfolioFailed)" HasFailed="@mPortfolioFailed" OnRetry="LoadPortfolioAsync">
                        <Skeleton>
                            <SkeletonSection Compact="true"><SkeletonRows Count="3" ShowChip="false" /></SkeletonSection>
                        </Skeleton>
                        <ChildContent>
                            <MobilePlayerPortfolioSection Videos="@mPortfolio!.Videos" OnAdd="OpenPortfolioAdd" OnEdit="OpenPortfolioEdit" OnDelete="DeletePortfolioAsync" />
                        </ChildContent>
                    </LoadingGate>
                    break;
                default:
                    <MobilePlayerProfileSection Info="@mInfo" PlayerId="@SelectedPlayerId" OnClaimed="ReloadAsync" />
                    break;
            }
        </main>
        <PlayerMobileTabBar ActiveSection="@CurrentSection" />
    }
</div>

@* 입력 다이얼로그 — PC·모바일 공용 (다이얼로그가 스스로 반응형이라 두 트리 밖에 하나만 둔다) *@
@* 보호자 기록 수정 신청 — 자녀의 공식 경기. 여기서 기록이 바뀌지 않는다(주최측 전달) *@
<GuardianCorrectionFormDialog @bind-IsOpen="mCorrectionFormOpen" Match="@mCorrectionMatch"
                              PlayerId="@SelectedPlayerId" OnSubmitted="LoadCorrectionsAsync" />

<CareerFormDialog @bind-IsOpen="mCareerFormOpen" Entry="@mEditingCareer" PlayerId="@SelectedPlayerId" OnSaved="ReloadCareerAsync" />
<PortfolioFormDialog @bind-IsOpen="mPortfolioFormOpen" Entry="@mEditingVideo"
                     ExistingVideoCount="@(mPortfolio?.Videos.Count ?? 0)" PlayerId="@SelectedPlayerId" OnSaved="ReloadPortfolioAsync" />

@code {
    [Parameter]
    public string? Section { get; set; }

    /// <summary>보고 있는 자녀 — URL에 둬서 새로고침·공유·뒤로가기에도 유지된다.
    /// 없으면 첫 자녀(서버가 결정). 허브가 자녀별로 이 주소를 만들어 링크한다.</summary>
    [Parameter, SupplyParameterFromQuery(Name = "playerId")]
    public Guid? PlayerIdQuery { get; set; }

    private ManagedPlayersResponse? mChildren;

    /// <summary>전환 컨트롤은 자녀가 2명 이상일 때만 의미가 있다.</summary>
    private List<ManagedPlayerDto> ChildList => mChildren?.Players ?? new List<ManagedPlayerDto>();

    /// <summary>화면이 보고 있는 자녀. 잘못된 playerId가 오면 첫 자녀로 떨어진다.</summary>
    private Guid SelectedPlayerId =>
        ChildList.Any(p => p.PlayerId == PlayerIdQuery)
            ? PlayerIdQuery!.Value
            : ChildList.FirstOrDefault()?.PlayerId ?? Guid.Empty;

    private PlayerInfoResponse? mInfo;
    private PlayerCareerResponse? mCareer;
    private PlayerPortfolioResponse? mPortfolio;
    private PlayerSeasonStatsResponse? mStats;

    // 조회 실패(null 응답) — 스켈레톤을 무한히 돌리지 않고 에러 안내 + 다시 시도로 바꾼다
    private bool mCareerFailed;
    private bool mPortfolioFailed;
    private bool mStatsFailed;

    // 입력 다이얼로그 — 편집 대상이 null이면 신규 등록
    private bool mCareerFormOpen;
    private bool mPortfolioFormOpen;
    private PlayerCareerEntryDto? mEditingCareer;
    private PlayerPortfolioVideoDto? mEditingVideo;

    private SoccerPlayerDashboardSection CurrentSection => SoccerPlayerDashboardSectionExtensions.ParseSlug(Section);

    /// <summary>현재 섹션까지 포함한 경로 — 로그인 왕복 후 같은 자리로 돌아오기 위해.</summary>
    private string CurrentPath => "/" + Nav.ToBaseRelativePath(Nav.Uri);

    // "U15 · FW · #9 · 팀명" — 있는 항목만 조합
    private string SidebarSummary => BuildSummary(includeTeam: true);
    private string MobileSummary => BuildSummary(includeTeam: false);

    private string GuardianInitial
    {
        get
        {
            string? guardian = mInfo?.Family.FirstOrDefault(m => m.Role == "Guardian")?.MemberName;
            string? fallback = mInfo?.Profile.Name;
            string source = guardian ?? fallback ?? string.Empty;
            return source.Length > 0 ? source[..1] : string.Empty;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // 직접 URL 진입(새로고침) 대비 — 인증 상태를 먼저 확정 (토큰 복원 + Bearer 헤더 부착)
        AuthenticationState state = await AuthProvider.GetAuthenticationStateAsync();
        if (state.User.Identity is not { IsAuthenticated: true })
        {
            // 딥링크 진입 — 로그인 후 이 자리로 돌아온다
            Nav.NavigateTo(Routes.LoginWithReturn(CurrentPath), replace: true);
            return;
        }

        // 관리 중인 자녀를 먼저 안다 — 어느 자녀를 보여줄지(그리고 전환 컨트롤을 낼지) 이걸로 정한다
        mChildren = await Players.GetMyPlayersAsync();

        // 자리가 틀리면 403이 아니라 허브로 — 계정은 맞고 자리만 틀린 상황이다(Design.Navigation 3).
        // **역할 클레임이 아니라 선수 프로필 보유 여부로 판정한다**: 역할은 단일 컬럼이라 팀 관리자이면서
        // 보호자인 계정을 표현하지 못하고, 역할로 막으면 허브 ↔ 대시보드가 무한히 튕긴다.
        // null(조회 실패)에는 이동하지 않는다 — 실패로 튕기면 허브와 무한히 오갈 수 있다.
        if (mChildren is not null && mChildren.Players.Count == 0)
        {
            Nav.NavigateTo(Routes.Dashboard, replace: true);
            return;
        }

        mInfo = await Players.GetMyInfoAsync(SelectedPlayerId == Guid.Empty ? null : SelectedPlayerId);
        mLoadedPlayerId = SelectedPlayerId;
    }

    /// <summary>현재 화면에 담긴 데이터가 어느 자녀 것인지 — 바뀌면 전부 다시 읽는다.</summary>
    private Guid mLoadedPlayerId;

    // 자녀 전환은 URL만 바꾼다 — 재조회는 OnParametersSetAsync가 알아서 한다(진입 경로가 하나로 모인다)
    private void SwitchChild(Guid playerId)
    {
        Nav.NavigateTo(Nav.GetUriWithQueryParameter("playerId", playerId.ToString()), replace: true);
    }

    // 섹션 진입 시 지연 로드 (1회) — 커리어·시즌 통계·포트폴리오는 진입할 때만 조회
    protected override async Task OnParametersSetAsync()
    {
        // 자녀가 바뀌었으면 화면에 남은 건 전부 다른 아이의 데이터다 — 비우고 다시 읽는다
        if (mChildren is not null && SelectedPlayerId != mLoadedPlayerId)
        {
            mLoadedPlayerId = SelectedPlayerId;
            mCareer = null;
            mPortfolio = null;
            mStats = null;
            mCareerFailed = false;
            mPortfolioFailed = false;
            mStatsFailed = false;
            mCorrections = null;
            mInfo = await Players.GetMyInfoAsync(SelectedPlayerId);
        }

        if (CurrentSection == SoccerPlayerDashboardSection.Career && mCareer is null && !mCareerFailed)
        {
            await LoadCareerAsync();
        }
        else if (CurrentSection == SoccerPlayerDashboardSection.Stats && mStats is null && !mStatsFailed)
        {
            await LoadSeasonStatsAsync(DateTime.Now.Year);
            // 신청 목록도 함께 — 경기 행 ⋯의 "신청 처리 중" 판정과 목록 표시에 쓴다
            await LoadCorrectionsAsync();
        }
        else if (CurrentSection == SoccerPlayerDashboardSection.Portfolio && mPortfolio is null && !mPortfolioFailed)
        {
            await LoadPortfolioAsync();
        }
    }

    private async Task LoadCareerAsync()
    {
        mCareerFailed = false;
        mCareer = await Players.GetMyCareerAsync(SelectedPlayerId);
        mCareerFailed = mCareer is null;
    }

    //.// 커리어 입력 — 추가·수정은 다이얼로그, 삭제는 확인 모달 + 실행취소 토스트

    private void OpenCareerAdd()
    {
        mEditingCareer = null;
        mCareerFormOpen = true;
    }

    private void OpenCareerEdit(PlayerCareerEntryDto entry)
    {
        mEditingCareer = entry;
        mCareerFormOpen = true;
    }

    private Task ReloadCareerAsync() => LoadCareerAsync();

    // 되돌릴 수 있어도 확인은 받는다(DropdownMenu: 파괴 액션 → 확인 모달). 소프트 삭제라 실행취소를 함께 준다
    private async Task DeleteCareerAsync(PlayerCareerEntryDto entry)
    {
        bool confirmed = await Confirm.ShowAsync(new ConfirmRequest
        {
            Kind = ConfirmKind.Destructive,
            Title = $"{entry.TeamName} 이력을 삭제할까요?",
            Description = "공개 프로필에서도 사라져요.",
            ConfirmLabel = "삭제",
        });

        if (!confirmed)
        {
            return;
        }

        PlayerEntrySaveResult result = await Players.DeleteCareerAsync(entry.CareerId, playerId: SelectedPlayerId);
        if (!result.Success)
        {
            Toasts.ShowError(result.Error ?? "삭제하지 못했어요.", "재시도", () => DeleteCareerAsync(entry));
            return;
        }

        await LoadCareerAsync();
        StateHasChanged();
        Toasts.ShowSuccess($"{entry.TeamName} 이력을 삭제했어요.", "실행취소", () => RestoreCareerAsync(entry));
    }

    private async Task RestoreCareerAsync(PlayerCareerEntryDto entry)
    {
        PlayerEntrySaveResult result = await Players.DeleteCareerAsync(entry.CareerId, restore: true, playerId: SelectedPlayerId);
        if (!result.Success)
        {
            Toasts.ShowError(result.Error ?? "되돌리지 못했어요.", "재시도", () => RestoreCareerAsync(entry));
            return;
        }

        await LoadCareerAsync();
        StateHasChanged();
        Toasts.ShowSuccess("삭제를 되돌렸어요.");
    }

    //.// 포트폴리오 입력

    private void OpenPortfolioAdd()
    {
        mEditingVideo = null;
        mPortfolioFormOpen = true;
    }

    private void OpenPortfolioEdit(PlayerPortfolioVideoDto clip)
    {
        mEditingVideo = clip;
        mPortfolioFormOpen = true;
    }

    private Task ReloadPortfolioAsync() => LoadPortfolioAsync();

    private async Task DeletePortfolioAsync(PlayerPortfolioVideoDto clip)
    {
        // 대표 영상을 지우면 다른 영상이 대표로 올라온다 — 미리 알려 준다
        string description = clip.IsPrimary
            ? "대표 영상이라 다음 영상이 대표로 올라와요."
            : "공개 프로필에서도 사라져요.";

        bool confirmed = await Confirm.ShowAsync(new ConfirmRequest
        {
            Kind = ConfirmKind.Destructive,
            Title = $"\"{clip.Title}\" 영상을 삭제할까요?",
            Description = description,
            ConfirmLabel = "삭제",
        });

        if (!confirmed)
        {
            return;
        }

        PlayerEntrySaveResult result = await Players.DeletePortfolioVideoAsync(clip.VideoId, playerId: SelectedPlayerId);
        if (!result.Success)
        {
            Toasts.ShowError(result.Error ?? "삭제하지 못했어요.", "재시도", () => DeletePortfolioAsync(clip));
            return;
        }

        await LoadPortfolioAsync();
        StateHasChanged();
        Toasts.ShowSuccess("영상을 삭제했어요.", "실행취소", () => RestorePortfolioAsync(clip));
    }

    private async Task RestorePortfolioAsync(PlayerPortfolioVideoDto clip)
    {
        PlayerEntrySaveResult result = await Players.DeletePortfolioVideoAsync(clip.VideoId, restore: true, playerId: SelectedPlayerId);
        if (!result.Success)
        {
            Toasts.ShowError(result.Error ?? "되돌리지 못했어요.", "재시도", () => RestorePortfolioAsync(clip));
            return;
        }

        await LoadPortfolioAsync();
        StateHasChanged();
        Toasts.ShowSuccess("삭제를 되돌렸어요.");
    }

    private async Task LoadPortfolioAsync()
    {
        mPortfolioFailed = false;
        mPortfolio = await Players.GetMyPortfolioAsync(SelectedPlayerId);
        mPortfolioFailed = mPortfolio is null;
    }

    // 시즌 pill 전환 — 선택 연도로 재조회. 첫 조회 실패만 에러 안내로 바꾸고,
    // 이미 표시 중인 통계가 있으면 화면을 비우지 않는다(전환 실패 = 기존 값 유지)
    private async Task LoadSeasonStatsAsync(int seasonYear)
    {
        mStatsFailed = false;
        PlayerSeasonStatsResponse? stats = await Players.GetMySeasonStatsAsync(seasonYear, SelectedPlayerId);
        if (stats is not null)
        {
            mStats = stats;
        }
        else
        {
            mStatsFailed = mStats is null;
        }
    }

    private Task RetryStatsAsync() => LoadSeasonStatsAsync(DateTime.Now.Year);

    //.// 보호자 기록 수정 신청 — 진입은 경기 행 ⋯, 목록은 그 아래(B6 팀 배치와 동일)

    private RecordCorrectionsResponse? mCorrections;
    private bool mCorrectionFormOpen;
    private PlayerMatchStatDto? mCorrectionMatch;

    // 내 신청 전부 중 현재 자녀의 경기에 대한 것만 — 자녀가 여럿이면 다른 아이 신청이 섞이면 안 된다
    private List<RecordCorrectionDto> ChildCorrections
    {
        get
        {
            if (mCorrections is null || mStats is null)
            {
                return new List<RecordCorrectionDto>();
            }

            HashSet<Guid> childMatches = mStats.Matches.Select(m => m.MatchId).ToHashSet();
            return mCorrections.Corrections.Where(c => childMatches.Contains(c.MatchId)).ToList();
        }
    }

    private HashSet<Guid> PendingCorrectionMatchIds =>
        ChildCorrections
            .Where(c => c.Status == nameof(SoccerCorrectionStatus.Pending))
            .Select(c => c.MatchId)
            .ToHashSet();

    private async Task LoadCorrectionsAsync()
    {
        mCorrections = await Players.GetGuardianCorrectionsAsync();
    }

    private void OpenCorrectionForm(PlayerMatchStatDto match)
    {
        mCorrectionMatch = match;
        mCorrectionFormOpen = true;
    }

    // 취소는 되돌릴 수 없다(신청이 사라진다) — 확인을 받는다
    private async Task CancelCorrectionAsync(RecordCorrectionDto correction)
    {
        bool confirmed = await Confirm.ShowAsync(new ConfirmRequest
        {
            Kind = ConfirmKind.Destructive,
            Title = "이 수정 신청을 취소할까요?",
            Description = $"{CorrectionListSection.SummaryOf(correction)} — 주최측에 전달된 신청이 철회돼요.",
            ConfirmLabel = "신청 취소",
            CancelLabel = "닫기",
        });

        if (!confirmed)
        {
            return;
        }

        CorrectionSaveResult result = await Players.CancelGuardianCorrectionAsync(correction.CorrectionId);
        if (!result.Success)
        {
            Toasts.ShowError(result.Error ?? "취소하지 못했어요.", "재시도", () => CancelCorrectionAsync(correction));
            return;
        }

        await LoadCorrectionsAsync();
        StateHasChanged();
        Toasts.ShowSuccess("수정 신청을 취소했어요.");
    }

    // 초대코드 Claim 성공 후 — 연결된 프로필(다른 선수 행일 수 있음)로 전체 재로드
    private async Task ReloadAsync()
    {
        mInfo = await Players.GetMyInfoAsync();
        mCareer = null;
        mPortfolio = null;
        mStats = null;
        StateHasChanged();
    }

    private string BuildSummary(bool includeTeam)
    {
        if (mInfo is null)
        {
            return string.Empty;
        }

        List<string> parts = new();
        if (mInfo.Profile.AgeGroup is not null)
        {
            parts.Add(mInfo.Profile.AgeGroup);
        }

        if (mInfo.Profile.Position is not null)
        {
            parts.Add(mInfo.Profile.Position);
        }

        if (mInfo.Profile.JerseyNumber is not null)
        {
            parts.Add($"#{mInfo.Profile.JerseyNumber}");
        }

        if (includeTeam && mInfo.Profile.TeamName is not null)
        {
            parts.Add(mInfo.Profile.TeamName);
        }

        return string.Join(" · ", parts);
    }
}
