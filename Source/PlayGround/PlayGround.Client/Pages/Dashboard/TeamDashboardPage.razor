@page "/dashboard/team"
@page "/dashboard/team/{Section}"
@using PlayGround.Client.Components.Dashboard
@using PlayGround.Client.Styles

<PageTitle>팀 대시보드 — PlayGround</PageTitle>

<div class="min-h-screen bg-surface-alt flex flex-col text-navy-deep">
    <DashboardGnb />
    <div class="flex-1 flex items-stretch">
        <TeamDashboardSidebar ActiveSection="@CurrentSection" />
        <main class="flex-1 min-w-0 max-w-[1100px] px-[34px] py-[30px]">
            @switch (CurrentSection)
            {
                case TeamDashboardSection.Roster:
                    <RosterSection />
                    break;
                case TeamDashboardSection.Schedule:
                    <ScheduleSection />
                    break;
                case TeamDashboardSection.Results:
                    <MatchResultsSection />
                    break;
                case TeamDashboardSection.Videos:
                    <VideosSection />
                    break;
                case TeamDashboardSection.Recruit:
                    <RecruitSection />
                    break;
                default:
                    <TeamInfoSection />
                    break;
            }
        </main>
    </div>
</div>

@code {
    [Parameter]
    public string? Section { get; set; }

    private TeamDashboardSection CurrentSection => TeamDashboardSectionExtensions.ParseSlug(Section);
}
