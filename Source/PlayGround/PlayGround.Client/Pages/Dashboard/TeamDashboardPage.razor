@page "/dashboard/team"
@page "/dashboard/team/{Section}"
@using PlayGround.Client.Components.Dashboard
@using PlayGround.Client.Styles

<PageTitle>팀 대시보드 — PlayGround</PageTitle>

<div class="min-h-screen bg-surface-alt flex flex-col text-navy-deep">
    <DashboardGnb />
    <div class="flex-1 flex items-stretch">
        <TeamDashboardSidebar ActiveSection="@CurrentSection" />
        <main class="flex-1 min-w-0 max-w-[1100px] px-[34px] py-[30px]">
            @switch (CurrentSection)
            {
                case "roster":
                    <RosterSection />
                    break;
                case "schedule":
                    <ScheduleSection />
                    break;
                case "results":
                    <MatchResultsSection />
                    break;
                case "videos":
                    <VideosSection />
                    break;
                case "recruit":
                    <RecruitSection />
                    break;
                default:
                    <TeamInfoSection />
                    break;
            }
        </main>
    </div>
</div>

@code {
    [Parameter]
    public string? Section { get; set; }

    private static readonly string[] Sections = ["info", "roster", "schedule", "results", "videos", "recruit"];

    private string CurrentSection =>
        Section is not null && Sections.Contains(Section) ? Section : "info";
}
