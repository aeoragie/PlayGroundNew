@attribute [Route(Routes.TeamDashboard)]
@attribute [Route(Routes.TeamDashboardSectionTemplate)]
@using System.Security.Claims
@using PlayGround.Client.Components.Dashboard
@using PlayGround.Client.Components.Dashboard.Mobile
@using PlayGround.Client.Services.Feedback
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Team
@using PlayGround.Domain.Soccer
@inject NavigationManager Nav
@inject JwtAuthenticationStateProvider AuthProvider
@inject TeamClient Teams
@inject ToastService Toasts
@inject ConfirmService Confirm

<PageTitle>팀 대시보드 — PlayGround</PageTitle>

@* PC (≥768px): GNB + 사이드바 *@
<div class="hidden md:flex min-h-screen bg-surface-alt flex-col text-navy-deep">
    <DashboardGnb Slug="@mInfo?.Profile.Slug" TeamName="@mInfo?.Profile.TeamName" DisplayName="@mUserName" />
    <div class="flex-1 flex items-stretch">
        <TeamDashboardSidebar ActiveSection="@CurrentSection" Team="@mInfo?.Profile" />
        <main class="flex-1 min-w-0 max-w-[1100px] px-[34px] py-[30px]">
            @switch (CurrentSection)
            {
                case SoccerTeamDashboardSection.Roster:
                    <LoadingGate IsLoading="@(mRoster is null && !mRosterFailed)" HasFailed="@mRosterFailed" OnRetry="LoadRosterAsync">
                        <Skeleton>
                            <SkeletonSection><SkeletonPlayerCards Count="8" /></SkeletonSection>
                        </Skeleton>
                        <ChildContent>
                            <RosterSection Players="@mRoster!.Players" />
                        </ChildContent>
                    </LoadingGate>
                    break;
                case SoccerTeamDashboardSection.Schedule:
                    <ScheduleSection />
                    break;
                case SoccerTeamDashboardSection.Results:
                    <LoadingGate IsLoading="@(mMatches is null && !mMatchesFailed)" HasFailed="@mMatchesFailed" OnRetry="LoadMatchesAsync">
                        <Skeleton>
                            <SkeletonSection>
                                <SkeletonStatCards Count="4" />
                                <SkeletonRows Count="4" />
                            </SkeletonSection>
                        </Skeleton>
                        <ChildContent>
                            <MatchResultsSection Data="@(mMatches!)" TeamName="@(mInfo?.Profile.TeamName ?? "")"
                                                 Segment="@CurrentSegment" OnSegmentChanged="ApplySegment"
                                                 OnAddResult="OpenResultFormAsync"
                                                 PendingCorrectionMatchIds="@PendingCorrectionMatchIds"
                                                 OnRequestCorrection="OpenCorrectionForm"
                                                 Corrections="@CorrectionList" OnCancelCorrection="CancelCorrectionAsync" />
                        </ChildContent>
                    </LoadingGate>
                    break;
                case SoccerTeamDashboardSection.Videos:
                    <LoadingGate IsLoading="@(mVideos is null && !mVideosFailed)" HasFailed="@mVideosFailed" OnRetry="LoadVideosAsync">
                        <Skeleton>
                            <SkeletonSection><SkeletonRows Count="3" ShowChip="false" /></SkeletonSection>
                        </Skeleton>
                        <ChildContent>
                            <VideosSection Data="@(mVideos!)" />
                        </ChildContent>
                    </LoadingGate>
                    break;
                case SoccerTeamDashboardSection.Recruit:
                    <LoadingGate IsLoading="@(mRecruitments is null && !mRecruitmentsFailed)" HasFailed="@mRecruitmentsFailed" OnRetry="LoadRecruitmentsAsync">
                        <Skeleton>
                            <SkeletonSection><SkeletonRows Count="2" ShowChip="false" /></SkeletonSection>
                        </Skeleton>
                        <ChildContent>
                            <RecruitSection Data="@(mRecruitments!)" OnChanged="LoadRecruitmentsAsync" />
                        </ChildContent>
                    </LoadingGate>
                    break;
                default:
                    @if (mInfo is not null)
                    {
                        <TeamInfoSection Info="@mInfo" OnEdit="() => mInfoFormOpen = true" />
                    }
                    break;
            }
        </main>
    </div>
</div>

@* 모바일 (<768px): 상단 바 + 하단 탭 5개 — 경기 결과·영상은 "경기" 서브탭으로 통합 *@
<div class="md:hidden min-h-screen bg-surface-alt flex flex-col max-w-[480px] mx-auto text-navy-deep">
    <MobileTopBar Team="@mInfo?.Profile" />
    <main class="flex-1 px-4 pt-[18px] pb-24 flex flex-col gap-3.5">
        @switch (CurrentSection)
        {
            case SoccerTeamDashboardSection.Roster:
                <LoadingGate IsLoading="@(mRoster is null && !mRosterFailed)" HasFailed="@mRosterFailed" OnRetry="LoadRosterAsync">
                    <Skeleton>
                        <SkeletonSection Compact="true"><SkeletonPlayerCards Count="4" /></SkeletonSection>
                    </Skeleton>
                    <ChildContent>
                        <MobileRosterSection Players="@mRoster!.Players" />
                    </ChildContent>
                </LoadingGate>
                break;
            case SoccerTeamDashboardSection.Schedule:
                <MobileScheduleSection />
                break;
            case SoccerTeamDashboardSection.Results:
            case SoccerTeamDashboardSection.Videos:
                @* 서브탭이 결과·영상을 공유하므로 둘 다 도착해야 실물을 그린다 *@
                <LoadingGate IsLoading="@((mMatches is null && !mMatchesFailed) || (mVideos is null && !mVideosFailed))"
                             HasFailed="@(mMatchesFailed || mVideosFailed)" OnRetry="RetryMatchTabAsync">
                    <Skeleton>
                        <SkeletonSection Compact="true">
                            <SkeletonStatCards Count="2" />
                            <SkeletonRows Count="3" />
                        </SkeletonSection>
                    </Skeleton>
                    <ChildContent>
                        <MobileMatchSection ActiveSection="@CurrentSection" Matches="@(mMatches!)" Videos="@(mVideos!)"
                                            TeamName="@(mInfo?.Profile.TeamName ?? "")"
                                            Segment="@CurrentSegment" OnSegmentChanged="ApplySegment"
                                            OnAddResult="OpenResultFormAsync"
                                            PendingCorrectionMatchIds="@PendingCorrectionMatchIds"
                                            OnRequestCorrection="OpenCorrectionForm"
                                            Corrections="@CorrectionList" OnCancelCorrection="CancelCorrectionAsync" />
                    </ChildContent>
                </LoadingGate>
                break;
            case SoccerTeamDashboardSection.Recruit:
                <LoadingGate IsLoading="@(mRecruitments is null && !mRecruitmentsFailed)" HasFailed="@mRecruitmentsFailed" OnRetry="LoadRecruitmentsAsync">
                    <Skeleton>
                        <SkeletonSection Compact="true"><SkeletonRows Count="2" ShowChip="false" /></SkeletonSection>
                    </Skeleton>
                    <ChildContent>
                        <MobileRecruitSection Data="@(mRecruitments!)" OnChanged="LoadRecruitmentsAsync" />
                    </ChildContent>
                </LoadingGate>
                break;
            default:
                @if (mInfo is not null)
                {
                    <MobileTeamInfoSection Info="@mInfo" OnEdit="() => mInfoFormOpen = true" />
                }
                break;
        }
    </main>
    <MobileTabBar ActiveSection="@CurrentSection" />
</div>

@* 경기 결과 입력 — PC·모바일 공용 (다이얼로그가 스스로 반응형) *@
<MatchResultFormDialog @bind-IsOpen="mResultFormOpen"
                       TeamName="@(mInfo?.Profile.TeamName ?? "우리 팀")"
                       Players="@(mRoster?.Players ?? new List<TeamRosterPlayerDto>())"
                       MatchDays="@ExistingMatchDays"
                       RecentMatchTime="@RecentMatchTime"
                       OnSaved="ReloadAfterResultSavedAsync" />

@* 팀 정보 수정 — 저장하면 공개 홈페이지도 같은 데이터를 읽으므로 즉시 반영된다 *@
<TeamInfoEditDialog @bind-IsOpen="mInfoFormOpen" Info="@mInfo" OnSaved="ReloadInfoAsync" />

@* 기록 수정 신청 — 여기서 기록이 바뀌지 않는다. 주최측에 전달될 뿐이다(설계 결정 7) *@
<CorrectionFormDialog @bind-IsOpen="mCorrectionFormOpen" Match="@mCorrectionMatch"
                      TeamName="@(mInfo?.Profile.TeamName ?? "우리 팀")" OnSubmitted="LoadCorrectionsAsync" />

@code {
    [Parameter]
    public string? Section { get; set; }

    /// <summary>결과 목록 세그먼트 — URL에 둬서 공유·뒤로가기·새로고침에도 유지된다(Design.SearchFilter).</summary>
    [Parameter, SupplyParameterFromQuery(Name = "type")]
    public string? MatchTypeQuery { get; set; }

    private TeamInfoResponse? mInfo;
    private TeamRosterResponse? mRoster;
    private TeamMatchesResponse? mMatches;
    private TeamVideosResponse? mVideos;
    private TeamRecruitmentsResponse? mRecruitments;
    private bool mAuthenticated;
    private string? mUserName;
    private bool mRosterRequested;
    private bool mMatchesRequested;
    private bool mVideosRequested;
    private bool mRecruitmentsRequested;

    // 조회 실패(null 응답) — 스켈레톤을 무한히 돌리지 않고 에러 안내 + 다시 시도로 바꾼다
    private bool mRosterFailed;
    private bool mMatchesFailed;
    private bool mVideosFailed;
    private bool mRecruitmentsFailed;

    private bool mResultFormOpen;
    private bool mInfoFormOpen;

    // 기록 수정 신청 — 목록은 경기 섹션과 함께 읽는다(같은 화면에 붙어 있다)
    private RecordCorrectionsResponse? mCorrections;
    private bool mCorrectionFormOpen;
    private TeamMatchDto? mCorrectionMatch;

    private List<RecordCorrectionDto> CorrectionList => mCorrections?.Corrections ?? new List<RecordCorrectionDto>();

    /// <summary>미처리(접수) 신청이 걸린 경기 — 그 행은 중복 신청을 막는다.</summary>
    private HashSet<Guid> PendingCorrectionMatchIds =>
        CorrectionList
            .Where(c => c.Status == nameof(SoccerCorrectionStatus.Pending))
            .Select(c => c.MatchId)
            .ToHashSet();

    private SoccerTeamDashboardSection CurrentSection => SoccerTeamDashboardSectionExtensions.ParseSlug(Section);

    private SoccerMatchSegment CurrentSegment => SoccerMatchTypeExtensions.ParseSegment(MatchTypeQuery);

    // 전체는 기본값이라 쿼리에서 지운다 — 주소가 불필요하게 길어지지 않게
    private void ApplySegment(SoccerMatchSegment segment)
    {
        string uri = Nav.GetUriWithQueryParameter("type", segment.ToQuery());
        Nav.NavigateTo(uri, replace: true);
    }

    /// <summary>현재 섹션까지 포함한 경로 — 로그인 왕복 후 같은 자리로 돌아오기 위해.</summary>
    private string CurrentPath => "/" + Nav.ToBaseRelativePath(Nav.Uri);

    protected override async Task OnInitializedAsync()
    {
        // 직접 URL 진입(새로고침) 대비 — 인증 상태를 먼저 확정 (토큰 복원 + Bearer 헤더 부착)
        AuthenticationState state = await AuthProvider.GetAuthenticationStateAsync();
        if (state.User.Identity is not { IsAuthenticated: true })
        {
            // 딥링크 진입 — 로그인 후 이 자리로 돌아온다
            Nav.NavigateTo(Routes.LoginWithReturn(CurrentPath), replace: true);
            return;
        }

        mAuthenticated = true;
        mUserName = state.User.Identity?.Name;
        mInfo = await Teams.GetTeamInfoAsync();

        // 자리가 틀리면 403이 아니라 허브로 — 계정은 맞고 자리만 틀린 상황이다(Design.Navigation 3).
        // **역할 클레임이 아니라 팀 보유 여부로 판정한다**: 역할은 단일 컬럼이라 팀 관리자이면서
        // 보호자인 계정을 표현하지 못하고, 역할로 막으면 허브 ↔ 대시보드가 무한히 튕긴다.
        // (팀 조회는 "없음"과 "실패"가 둘 다 null이라 여기서 구분되지 않는다 — 허브 쪽에서
        //  실패 시 이동하지 않는 것으로 왕복을 끊는다.)
        if (mInfo is null)
        {
            Nav.NavigateTo(Routes.Dashboard, replace: true);
        }
    }

    // 섹션 진입 시 지연 로드 (한 번만 — 섹션 재방문 시 재요청하지 않는다)
    protected override async Task OnParametersSetAsync()
    {
        if (!mAuthenticated)
        {
            return;
        }

        if (CurrentSection == SoccerTeamDashboardSection.Roster && !mRosterRequested)
        {
            await LoadRosterAsync();
        }
        else if (CurrentSection is SoccerTeamDashboardSection.Results or SoccerTeamDashboardSection.Videos)
        {
            // 모바일은 결과·영상이 한 화면(서브탭)이라 함께 로드한다
            if (!mMatchesRequested)
            {
                await LoadMatchesAsync();
            }

            if (!mVideosRequested)
            {
                await LoadVideosAsync();
            }

            // 신청 목록은 경기 결과 화면 안에 붙어 있어 같이 읽는다 (없으면 렌더되지 않는다)
            if (mCorrections is null)
            {
                await LoadCorrectionsAsync();
            }
        }
        else if (CurrentSection == SoccerTeamDashboardSection.Recruit && !mRecruitmentsRequested)
        {
            mRecruitmentsRequested = true;
            await LoadRecruitmentsAsync();
        }
    }

    private async Task LoadRecruitmentsAsync()
    {
        mRecruitmentsFailed = false;
        mRecruitments = await Teams.GetMyRecruitmentsAsync();
        mRecruitmentsFailed = mRecruitments is null;
    }

    /// <summary>이미 결과가 있는 날 — 캘린더 도트로 중복 입력을 눈으로 막는다.</summary>
    private IReadOnlyCollection<DateTime> ExistingMatchDays =>
        mMatches?.Matches
            .Where(m => m.MatchedAt.HasValue)
            .Select(m => m.MatchedAt!.Value.Date)
            .Distinct()
            .ToList() ?? new List<DateTime>();

    /// <summary>시각 기본값 = 최근 경기와 같은 시각 (팀 루틴 반복 — Design.DatePicker).</summary>
    private TimeOnly? RecentMatchTime
    {
        get
        {
            DateTime? recent = mMatches?.Matches
                .Where(m => m.MatchedAt.HasValue)
                .OrderByDescending(m => m.MatchedAt)
                .Select(m => m.MatchedAt)
                .FirstOrDefault();
            return recent is null ? null : TimeOnly.FromDateTime(recent.Value);
        }
    }

    // 득점자 칩은 로스터가 있어야 뜬다 — 경기 섹션에서 바로 열면 아직 안 불러왔을 수 있다
    private async Task OpenResultFormAsync()
    {
        if (mRoster is null && !mRosterRequested)
        {
            await LoadRosterAsync();
        }

        mResultFormOpen = true;
    }

    // 팀 정보 저장 후 — 사이드바·상단바까지 새 값으로 갱신된다
    private async Task ReloadInfoAsync()
    {
        mInfo = await Teams.GetTeamInfoAsync();
    }

    // 저장 성공 → 경기 목록·순위표를 다시 읽는다 (순위표 재계산은 서버가 이미 끝냈다)
    private async Task ReloadAfterResultSavedAsync()
    {
        mMatchesRequested = false;
        await LoadMatchesAsync();
    }

    private async Task LoadRosterAsync()
    {
        mRosterRequested = true;
        mRosterFailed = false;
        mRoster = await Teams.GetTeamRosterAsync();
        mRosterFailed = mRoster is null;
    }

    private async Task LoadMatchesAsync()
    {
        mMatchesRequested = true;
        mMatchesFailed = false;
        mMatches = await Teams.GetTeamMatchesAsync(DateTime.Now.Year);
        mMatchesFailed = mMatches is null;
    }

    //.// 기록 수정 신청 — 진입점이 경기 행이라 경기 섹션과 같은 시점에 읽는다

    private async Task LoadCorrectionsAsync()
    {
        mCorrections = await Teams.GetRecordCorrectionsAsync();
    }

    private void OpenCorrectionForm(TeamMatchDto match)
    {
        mCorrectionMatch = match;
        mCorrectionFormOpen = true;
    }

    // 취소는 되돌릴 수 없다(신청이 사라진다) — 확인을 받는다
    private async Task CancelCorrectionAsync(RecordCorrectionDto correction)
    {
        bool confirmed = await Confirm.ShowAsync(new ConfirmRequest
        {
            Kind = ConfirmKind.Destructive,
            Title = "이 수정 신청을 취소할까요?",
            Description = $"{CorrectionListSection.SummaryOf(correction)} — 주최측에 전달된 신청이 철회돼요.",
            ConfirmLabel = "신청 취소",
            CancelLabel = "닫기",
        });

        if (!confirmed)
        {
            return;
        }

        CorrectionSaveResult result = await Teams.CancelRecordCorrectionAsync(correction.CorrectionId);
        if (!result.Success)
        {
            Toasts.ShowError(result.Error ?? "취소하지 못했어요.", "재시도", () => CancelCorrectionAsync(correction));
            return;
        }

        await LoadCorrectionsAsync();
        StateHasChanged();
        Toasts.ShowSuccess("수정 신청을 취소했어요.");
    }

    private async Task LoadVideosAsync()
    {
        mVideosRequested = true;
        mVideosFailed = false;
        mVideos = await Teams.GetTeamVideosAsync();
        mVideosFailed = mVideos is null;
    }

    // 모바일 경기 탭은 결과·영상을 함께 쓰므로 실패한 쪽만 다시 부른다
    private async Task RetryMatchTabAsync()
    {
        if (mMatchesFailed)
        {
            await LoadMatchesAsync();
        }

        if (mVideosFailed)
        {
            await LoadVideosAsync();
        }
    }
}
