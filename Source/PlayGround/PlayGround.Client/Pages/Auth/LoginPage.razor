@page "/login"
@layout AuthLayout
@using PlayGround.Client.Styles
@inject NavigationManager Nav
@inject AuthClient Auth
@inject JwtAuthenticationStateProvider AuthProvider

<PageTitle>시작하기 — PlayGround</PageTitle>

@* ① 로그인. 소셜·이메일 모두 실연동 (가입과 로그인이 한 번에) *@
<div class="@($"w-[400px] max-w-full {Css.Auth.Card} px-9 py-10 flex flex-col gap-[22px]")">
    <div class="flex flex-col gap-2 text-center">
        <h1 class="m-0 text-2xl font-extrabold tracking-[-.02em] text-navy-deep">시작하기</h1>
        <p class="m-0 text-sm text-text-body leading-relaxed">가입과 로그인이 한 번에 —<br />계정이 없으면 자동으로 만들어 드려요.</p>
    </div>

    @if (mError is not null)
    {
        <div role="alert" class="rounded-[11px] bg-surface-alt border-1.5 border-border text-[13px] text-text-body px-4 py-3 text-center">@mError</div>
    }

    @* 소셜 로그인 (공식 브랜드 색상 — 우리 팔레트 아님, 각 사 가이드 준수) *@
    <div class="flex flex-col gap-2.5">
        <button type="button" @onclick="@(() => StartSocial("google"))"
                class="flex items-center justify-center gap-2.5 h-[50px] rounded-[11px] border-1.5 border-border bg-white hover:bg-surface-alt text-[15px] font-bold text-navy-deep transition-colors">
            <svg width="19" height="19" viewBox="0 0 48 48" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"></path><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path></svg>
            Google로 계속하기
        </button>
        <button type="button" @onclick="@(() => StartSocial("kakao"))"
                class="flex items-center justify-center gap-2.5 h-[50px] rounded-[11px] bg-[#FEE500] hover:bg-[#f5dc00] text-[15px] font-bold text-[#191919] transition-colors">
            <svg width="19" height="19" viewBox="0 0 24 24" aria-hidden="true"><path fill="#191919" d="M12 3C6.48 3 2 6.54 2 10.9c0 2.8 1.86 5.26 4.66 6.65l-.95 3.51c-.08.31.27.56.54.38l4.19-2.79c.51.05 1.03.08 1.56.08 5.52 0 10-3.54 10-7.83S17.52 3 12 3z"></path></svg>
            카카오로 계속하기
        </button>
        <button type="button" @onclick="@(() => StartSocial("line"))"
                class="flex items-center justify-center gap-2.5 h-[50px] rounded-[11px] bg-[#06C755] hover:bg-[#05b34c] text-[15px] font-bold text-white transition-colors">
            <svg width="19" height="19" viewBox="0 0 24 24" aria-hidden="true"><path fill="#fff" d="M12 2.5C6.2 2.5 1.5 6.36 1.5 11.11c0 4.26 3.76 7.83 8.84 8.5.34.07.81.23.93.52.1.27.07.68.03.95l-.15.9c-.04.27-.21 1.05.92.57 1.13-.48 6.08-3.58 8.3-6.13 1.53-1.68 2.13-3.39 2.13-5.31C22.5 6.36 17.8 2.5 12 2.5zM8.09 13.7H6.02a.55.55 0 0 1-.55-.55V8.98a.55.55 0 0 1 1.1 0v3.62h1.52a.55.55 0 0 1 0 1.1zm1.98-.55a.55.55 0 0 1-1.1 0V8.98a.55.55 0 0 1 1.1 0v4.17zm5.02 0a.55.55 0 0 1-.99.33l-2.13-2.9v2.57a.55.55 0 0 1-1.1 0V8.98a.55.55 0 0 1 .99-.33l2.13 2.9V8.98a.55.55 0 0 1 1.1 0v4.17zm3.35-2.64a.55.55 0 0 1 0 1.1h-1.52v.99h1.52a.55.55 0 0 1 0 1.1h-2.07a.55.55 0 0 1-.55-.55V8.98c0-.3.25-.55.55-.55h2.07a.55.55 0 0 1 0 1.1h-1.52v.98h1.52z"></path></svg>
            LINE으로 계속하기
        </button>
        <div class="flex gap-2.5">
            <div class="flex-1 h-11 border-1.5 border-dashed border-border rounded-[11px] flex items-center justify-center text-[13px] text-text-faint">네이버 (준비중)</div>
            <div class="flex-1 h-11 border-1.5 border-dashed border-border rounded-[11px] flex items-center justify-center text-[13px] text-text-faint">Apple (준비중)</div>
        </div>
    </div>

    @* 구분선 *@
    <div class="flex items-center gap-3 text-text-faint text-[12.5px]">
        <div class="flex-1 h-px bg-border"></div>또는 이메일로<div class="flex-1 h-px bg-border"></div>
    </div>

    @* 이메일 로그인 *@
    <div class="flex flex-col gap-2.5">
        <input type="email" placeholder="이메일 주소" class="@Css.Auth.Input" @bind="mEmail" @bind:event="oninput" />
        <input type="password" placeholder="비밀번호" class="@Css.Auth.Input" @bind="mPassword" @bind:event="oninput" @onkeydown="OnPasswordKeyDown" />
        <button type="button" @onclick="EmailLogin" disabled="@mSaving" class="@Css.Auth.NavyButton">@(mSaving ? "처리 중…" : "이메일로 계속하기")</button>
    </div>

    <p class="m-0 text-xs text-text-muted text-center leading-relaxed">
        계속하면 <a href="#" class="underline">이용약관</a>과 <a href="#" class="underline">개인정보처리방침</a>에 동의하는 것으로 간주됩니다.<br />로그인 시 General 역할로 자동 가입됩니다.
    </p>
</div>

@code {
    private string? mError;
    private string mEmail = string.Empty;
    private string mPassword = string.Empty;
    private bool mSaving;

    protected override void OnInitialized()
    {
        // 콜백 실패 시 /login?error=... 로 리다이렉트된다.
        string query = new Uri(Nav.Uri).Query;
        const string marker = "error=";
        int index = query.IndexOf(marker, StringComparison.Ordinal);
        if (index >= 0)
        {
            string code = query[(index + marker.Length)..].Split('&')[0];
            mError = MapError(Uri.UnescapeDataString(code));
        }
    }

    // 소셜 OAuth 시작 — 서버 엔드포인트로 전체 페이지 이동(브라우저 리다이렉트 필요 → forceLoad)
    private void StartSocial(string provider)
    {
        Nav.NavigateTo($"api/auth/social/{provider}", forceLoad: true);
    }

    private async Task OnPasswordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await EmailLogin();
        }
    }

    // 이메일 로그인/가입 (없으면 자동 생성). 성공 시 토큰 저장 후 역할 선택으로 — 역할 보유자는 거기서 대시보드 직행.
    private async Task EmailLogin()
    {
        mError = null;

        if (string.IsNullOrWhiteSpace(mEmail) || string.IsNullOrWhiteSpace(mPassword))
        {
            mError = "이메일과 비밀번호를 입력해 주세요.";
            return;
        }

        mSaving = true;
        EmailLoginResult result = await Auth.LoginByEmailAsync(mEmail.Trim(), mPassword);
        mSaving = false;

        if (!result.Success || string.IsNullOrEmpty(result.Token))
        {
            mError = result.Error;
            return;
        }

        await AuthProvider.MarkUserAuthenticatedAsync(result.Token);
        Nav.NavigateTo("/settings/select-role");
    }

    private static string MapError(string code)
    {
        return code switch
        {
            "NoCode" => "인증이 취소되었어요. 다시 시도해 주세요.",
            "NotConfigured" => "아직 준비 중인 로그인 방식이에요. 다른 방법으로 시작해 주세요.",
            "ProviderError" => "소셜 로그인 제공자에서 오류가 발생했어요.",
            "LoginFailed" => "로그인 처리 중 문제가 발생했어요. 잠시 후 다시 시도해 주세요.",
            _ => "로그인에 실패했어요. 다시 시도해 주세요."
        };
    }
}
