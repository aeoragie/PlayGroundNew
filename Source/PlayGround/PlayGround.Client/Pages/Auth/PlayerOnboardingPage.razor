@page "/onboarding/player"
@layout AuthLayout
@using PlayGround.Client.Styles
@inject NavigationManager Nav
@inject OnboardingState State

<PageTitle>선수 온보딩 — PlayGround</PageTitle>

@* ③a 선수 온보딩 (3스텝) *@
<div class="w-[480px] max-w-full flex flex-col gap-5">
    <div class="flex flex-col gap-3">
        <div class="flex justify-between items-baseline">
            <h1 class="m-0 text-[23px] font-extrabold tracking-[-.02em] text-navy-deep">@StepTitle</h1>
            <span class="text-[13px] font-bold text-text-muted">@mStep / 3</span>
        </div>
        <StepProgress Total="3" Current="@mStep" />
    </div>

    <div class="@($"{Css.Auth.Card} px-7 py-[30px] flex flex-col gap-4")">
        @if (mStep == 1)
        {
            <div class="flex flex-col gap-3.5">
                <label class="flex flex-col gap-[7px] text-[13.5px] font-bold text-text-strong">선수 이름
                    <input type="text" placeholder="예: 김민준" class="@Css.Auth.Input" /></label>
                <label class="flex flex-col gap-[7px] text-[13.5px] font-bold text-text-strong">생년월일
                    <input type="text" placeholder="YYYY.MM.DD" class="@Css.Auth.Input" /></label>
                <div class="flex gap-2.5 items-start bg-surface-teal border border-teal/30 rounded-[11px] px-3.5 py-3">
                    <span class="text-[15px]">👪</span>
                    <span class="text-[12.5px] text-text-strong leading-relaxed">학부모이신가요? 자녀의 정보를 입력하면 <b>보호자 대리 관리</b> 프로필로 만들어져요. 자녀가 크면 계정을 넘겨줄 수 있어요.</span>
                </div>
            </div>
        }
        else if (mStep == 2)
        {
            <div class="flex flex-col gap-4">
                <div class="flex flex-col gap-2">
                    <span class="text-[13.5px] font-bold text-text-strong">연령대</span>
                    <div class="flex gap-2">
                        @foreach (var age in AgeOptions)
                        {
                            <ChoiceChip Label="@age" Selected="@(mAge == age)" OnClick="@(() => mAge = age)" />
                        }
                    </div>
                </div>
                <div class="flex flex-col gap-2">
                    <span class="text-[13.5px] font-bold text-text-strong">종목</span>
                    <div class="flex items-center gap-2.5 h-12 border-1.5 border-border rounded-[11px] px-[15px] bg-[#fafbfc]">
                        <span>⚽</span><span class="text-[14.5px] font-bold text-navy-deep">축구</span>
                        <span class="text-[11.5px] font-bold text-text-muted bg-surface-icon rounded-full px-[9px] py-0.5">현재 축구만 지원</span>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="flex flex-col gap-3.5">
                <label class="flex flex-col gap-[7px] text-[13.5px] font-bold text-text-strong">활동 지역
                    <input type="text" placeholder="예: 서울 송파구" class="@Css.Auth.Input" /></label>
                <label class="flex flex-col gap-[7px] text-[13.5px] font-bold text-text-strong">소속팀 <span class="font-medium text-text-muted">(선택)</span>
                    <input type="text" placeholder="팀 이름 검색 — 없으면 비워두세요" class="@Css.Auth.Input" /></label>
                <div class="flex gap-2.5 items-start bg-surface-orange border border-dashed border-orange rounded-[11px] px-3.5 py-3">
                    <span class="text-[15px]">✉️</span>
                    <span class="text-[12.5px] text-text-strong leading-relaxed">팀에서 <b>초대코드</b>를 받았나요? 온보딩 후 대시보드에서 입력하면 팀 로스터의 프로필과 바로 연결돼요.</span>
                </div>
            </div>
        }
    </div>

    <div class="flex gap-2.5">
        @if (mStep > 1)
        {
            <button type="button" @onclick="Back" class="@Css.Auth.SecondaryButton">← 이전</button>
        }
        <button type="button" @onclick="Next" class="@($"flex-1 {Css.Auth.PrimaryButton}")">@NextLabel</button>
    </div>
    @if (mStep == 3)
    {
        <button type="button" @onclick="Finish" class="@($"{Css.Auth.TextLink} !text-[13px]")">이 단계 건너뛰기</button>
    }
</div>

@code {
    private static readonly string[] AgeOptions = ["U12", "U15", "U18"];
    private static readonly Dictionary<int, string> Titles = new() { [1] = "선수 기본 정보", [2] = "연령대와 종목", [3] = "지역과 소속" };

    private int mStep = 1;
    private string mAge = "U15";

    private string StepTitle => Titles[mStep];
    private string NextLabel => mStep < 3 ? "다음 →" : "프로필 만들기";

    private void Back() => mStep--;

    private void Next()
    {
        if (mStep < 3)
        {
            mStep++;
        }
        else
        {
            Finish();
        }
    }

    private void Finish()
    {
        State.DoneFrom = "player";
        Nav.NavigateTo("/onboarding/complete");
    }
}
