@attribute [Route(Routes.AgentApprovalTemplate)]
@* 에이전트 열람 요청 심사 (보호자 측 — Design.AgentViewApproval). 미성년자 보호 관문.
   3상태: Pending(승인/거절/차단) → Approved(만료 카운트다운+열람 기록+철회) / Denied·Revoked(거절 동급).
   열람 범위는 고정 세트 — 연락처는 항상 제외(문구 변경 금지). violet은 에이전트 요소에만, 주 버튼 = teal.
   **FeatureFlags.AgentApproval(기본 off) 뒤** — 요청 생산자(에이전트 서비스)가 생기면 켠다.
   레퍼런스의 "프로토타입 · 상태" 바는 구현하지 않는다. *@
@using PlayGround.Client.Services.Feedback
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Agent
@using PlayGround.Domain.Soccer
@inject NavigationManager Nav
@inject JwtAuthenticationStateProvider AuthProvider
@inject AgentClient Agents
@inject ToastService Toasts
@inject ConfirmService Confirm

<PageTitle>상세 정보 열람 요청 — PlayGround</PageTitle>

@if (mReady)
{
    @* ── PC (≥768px): 다크 GNB + 브레드크럼 + 2컬럼 ── *@
    <div class="hidden md:flex min-h-screen bg-flow-bg flex-col text-navy-deep">
        <header class="bg-navy-deep h-[58px] flex items-center px-7 gap-3.5 text-white">
            <BrandLogo Href="@Routes.Landing" InheritColor="true" />
            <span class="w-px h-[18px] bg-white/[.18]"></span>
            <span class="text-[13px] font-bold text-white/85 whitespace-nowrap">알림 센터</span>
            <div class="flex-1"></div>
            <a href="@Routes.Dashboard" class="text-[12.5px] font-bold text-white/75 hover:text-white whitespace-nowrap transition-colors">대시보드로</a>
            <Avatar Name="@mInitial" Size="32" />
        </header>

        <main class="max-w-[980px] w-full mx-auto mt-4 mb-[60px] px-6 flex flex-col gap-4">
            <LoadingGate IsLoading="@(mData is null && !mFailed)" HasFailed="@mFailed" OnRetry="LoadAsync">
                <Skeleton><SkeletonSection ShowAction="false"><SkeletonRows Count="3" ShowChip="false" /></SkeletonSection></Skeleton>
                <ChildContent>
                    <div class="flex items-center gap-2.5">
                        <button type="button" aria-label="뒤로" @onclick="GoBack"
                                class="w-[34px] h-[34px] rounded-[10px] bg-white border-1.5 border-border flex items-center justify-center flex-none cursor-pointer">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-strong"><path d="M15 18l-6-6 6-6"></path></svg>
                        </button>
                        <span class="flex flex-col gap-px">
                            <span class="text-[11.5px] text-text-muted whitespace-nowrap">알림 센터 · 열람 요청</span>
                            <h1 class="m-0 text-xl font-extrabold whitespace-nowrap">상세 정보 열람 요청 — @mData!.PlayerName@(PlayerMeta is not null ? $" ({PlayerMeta})" : "")</h1>
                        </span>
                    </div>

                    <div class="grid grid-cols-[1.15fr_.85fr] gap-4 items-start">
                        <div class="flex flex-col gap-3.5">
                            @AgentCard
                            @RequestCard
                            @if (IsApproved)
                            {
                                @ViewLogCard
                            }
                        </div>
                        <div class="flex flex-col gap-3.5 sticky top-5">
                            @ScopeCard
                            <div class="bg-white border-1.5 border-border rounded-2xl p-[18px_20px] flex flex-col gap-[9px]">
                                @ActionBlock
                            </div>
                        </div>
                    </div>
                </ChildContent>
            </LoadingGate>
        </main>
    </div>

    @* ── 모바일 (<768px): 420 카드 세로 스택 ── *@
    <div class="md:hidden min-h-screen bg-flow-bg flex flex-col items-center gap-3.5 px-4 pt-5 pb-[60px]">
        <div class="w-full max-w-[420px] bg-bg rounded-card shadow-flow overflow-hidden flex flex-col">
            <div class="px-5 py-3.5 border-b border-border flex items-center gap-2">
                <button type="button" aria-label="뒤로" @onclick="GoBack"
                        class="w-8 h-8 rounded-[9px] bg-surface-alt flex items-center justify-center -ml-1 flex-none border-0 cursor-pointer">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-strong"><path d="M15 18l-6-6 6-6"></path></svg>
                </button>
                <span class="text-sm font-extrabold text-navy-deep whitespace-nowrap">상세 정보 열람 요청</span>
                <div class="flex-1"></div>
                <span class="text-[11.5px] text-text-muted whitespace-nowrap">알림 센터에서 열림</span>
            </div>

            <LoadingGate IsLoading="@(mData is null && !mFailed)" HasFailed="@mFailed" OnRetry="LoadAsync">
                <Skeleton><div class="p-5"><SkeletonRows Count="3" ShowChip="false" /></div></Skeleton>
                <ChildContent>
                    <div class="p-5 flex flex-col gap-4">
                        @AgentCard
                        @RequestCard
                        @ScopeCard
                        @ActionBlock
                        @if (IsApproved)
                        {
                            @ViewLogCard
                        }
                    </div>
                </ChildContent>
            </LoadingGate>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid RequestId { get; set; }

    private bool mReady;
    private bool mBusy;
    private bool mFailed;
    private string mInitial = "?";
    private AgentViewRequestResponse? mData;

    private string CurrentPath => "/" + Nav.ToBaseRelativePath(Nav.Uri);

    private bool IsPending => mData?.Status == "Pending";
    private bool IsApproved => mData?.Status == "Approved";

    private string? PlayerMeta => mData is null
        ? null
        : string.Join(" · ", new[] { mData.PlayerAgeGroup, mData.PlayerPosition }.Where(v => v is not null)) is { Length: > 0 } meta
            ? meta
            : null;

    protected override async Task OnInitializedAsync()
    {
        // 에이전트 축은 feature flag 뒤 (설계 결정 4) — 꺼져 있으면 없는 화면이다
        if (!FeatureFlags.AgentApproval)
        {
            Nav.NavigateTo(Routes.NotFound, replace: true);
            return;
        }

        AuthenticationState state = await AuthProvider.GetAuthenticationStateAsync();
        if (state.User.Identity is not { IsAuthenticated: true })
        {
            Nav.NavigateTo(Routes.LoginWithReturn(CurrentPath), replace: true);
            return;
        }

        string? name = state.User.Identity?.Name;
        mInitial = string.IsNullOrWhiteSpace(name) ? "?" : name[..1];
        mReady = true;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        mFailed = false;
        mData = await Agents.GetRequestAsync(RequestId);
        mFailed = mData is null;
    }

    private void GoBack() => Nav.NavigateTo(Routes.Dashboard);

    //.// 액션 — 승인은 즉시(철회로 되돌릴 수 있다), 철회·차단은 확인 모달

    private async Task ApproveAsync()
    {
        mBusy = true;
        AgentViewRequestResponse? result = await Agents.ReviewAsync(RequestId, nameof(SoccerAgentReviewAction.Approve));
        mBusy = false;

        if (result is null)
        {
            Toasts.ShowError("요청을 처리하지 못했어요. 다시 시도해 주세요.");
            return;
        }

        await LoadAsync();
    }

    private async Task DenyAsync()
    {
        mBusy = true;
        AgentViewRequestResponse? result = await Agents.ReviewAsync(RequestId, nameof(SoccerAgentReviewAction.Deny));
        mBusy = false;

        if (result is null)
        {
            Toasts.ShowError("요청을 처리하지 못했어요. 다시 시도해 주세요.");
            return;
        }

        await LoadAsync();
    }

    private async Task RevokeAsync()
    {
        // 철회는 에이전트 접근을 즉시 끊고 재승인 경로가 없다 — 파괴 확인
        bool confirmed = await Confirm.ShowAsync(new ConfirmRequest
        {
            Kind = ConfirmKind.Destructive,
            Title = $"{mData?.Agent.Name} 에이전트의 열람 권한을 철회할까요?",
            Description = "즉시 열람이 차단되고 되돌릴 수 없어요.",
            ConfirmLabel = "철회",
        });

        if (!confirmed)
        {
            return;
        }

        mBusy = true;
        AgentViewRequestResponse? result = await Agents.ReviewAsync(RequestId, nameof(SoccerAgentReviewAction.Revoke));
        mBusy = false;

        if (result is null)
        {
            Toasts.ShowError("요청을 처리하지 못했어요. 다시 시도해 주세요.");
            return;
        }

        await LoadAsync();
    }

    private async Task BlockAsync()
    {
        bool confirmed = await Confirm.ShowAsync(new ConfirmRequest
        {
            Kind = ConfirmKind.Destructive,
            Title = $"{mData?.Agent.Name} 에이전트의 요청을 다시 받지 않을까요?",
            Description = "이 요청은 거절되고, 같은 에이전트의 새 요청이 차단돼요.",
            ConfirmLabel = "다시 받지 않기",
        });

        if (!confirmed)
        {
            return;
        }

        mBusy = true;
        bool blocked = await Agents.BlockAsync(RequestId);
        mBusy = false;

        if (!blocked)
        {
            Toasts.ShowError("요청을 처리하지 못했어요. 다시 시도해 주세요.");
            return;
        }

        Toasts.ShowSuccess("이 에이전트의 요청을 더 받지 않아요.");
        await LoadAsync();
    }

    //.// 표시 헬퍼

    private string ExpiryText
    {
        get
        {
            if (mData?.ExpiresAt is null)
            {
                return string.Empty;
            }

            DateTime local = mData.ExpiresAt.Value.ToLocalTime();
            if (mData.IsExpired)
            {
                return $"만료됨 — {local.Month}/{local.Day}까지 열람";
            }

            int daysLeft = Math.Max(0, (int)Math.Ceiling((mData.ExpiresAt.Value - DateTime.UtcNow).TotalDays));
            return $"승인됨 — {local.Month}/{local.Day}까지 열람 가능 ({daysLeft}일 남음)";
        }
    }

    private static string RequestedAtText(DateTime utc)
    {
        DateTime local = utc.ToLocalTime();
        return $"{local.Month}/{local.Day} {(local.Hour < 12 ? "오전" : "오후")} {((local.Hour + 11) % 12) + 1}:{local.Minute:D2} 요청";
    }

    private static string LogLabel(string eventType) => eventType switch
    {
        "RecordView" => "경기별 상세 기록 열람",
        "ProfileView" => "디테일 권한 뷰 방문",
        _ => "승인 완료",
    };

    private static string LogTimeText(DateTime utc)
    {
        DateTime local = utc.ToLocalTime();
        DateTime today = DateTime.Now.Date;
        string clock = $"{(local.Hour < 12 ? "오전" : "오후")} {((local.Hour + 11) % 12) + 1}:{local.Minute:D2}";
        if (local.Date == today)
        {
            return $"오늘 {clock}";
        }

        if (local.Date == today.AddDays(-1))
        {
            return $"어제 {clock}";
        }

        return $"{local.Month}/{local.Day}";
    }

    //.// 공용 블록 (PC 2컬럼 / 모바일 스택이 같은 마크업을 쓴다)

    private RenderFragment AgentCard => __builder =>
    {
        <div class="bg-white border-1.5 border-agent/30 rounded-2xl overflow-hidden">
            <div class="bg-agent/[.06] px-4 py-3.5 md:px-[22px] md:py-[18px] flex items-center gap-3 md:gap-3.5">
                <Avatar Name="@mData!.Agent.Name" Tone="Avatar.AvatarTone.Agent" Size="44" Class="flex-none md:!hidden" />
                <Avatar Name="@mData!.Agent.Name" Tone="Avatar.AvatarTone.Agent" Size="56" Class="flex-none !hidden md:!flex" />
                <span class="flex flex-col gap-0.5 md:gap-[3px] flex-1 min-w-0">
                    <span class="flex items-center gap-1.5 md:gap-2 flex-wrap">
                        <span class="text-[14.5px] md:text-[16.5px] font-extrabold whitespace-nowrap">@mData.Agent.Name</span>
                        @if (mData.Agent.IsVerified)
                        {
                            <span class="@Css.Badge.Agent">인증 에이전트</span>
                        }
                    </span>
                    <span class="text-[11.5px] md:text-[12.5px] text-text-body whitespace-nowrap">@AgencyLine</span>
                </span>
            </div>
            @if (HasStats)
            {
                <div class="px-4 py-3 md:px-[22px] md:py-4 flex gap-3.5 md:gap-[18px]">
                    @if (mData.Agent.BrokerageCount > 0)
                    {
                        <span class="flex flex-col gap-px md:gap-0.5 flex-1">
                            <span class="text-sm md:text-[17px] font-extrabold">@(mData.Agent.BrokerageCount)명</span>
                            <span class="text-[10.5px] md:text-[11px] font-bold text-text-muted whitespace-nowrap">중개 이력</span>
                        </span>
                    }
                    @if (mData.Agent.Rating is not null)
                    {
                        <span class="flex flex-col gap-px md:gap-0.5 flex-1">
                            <span class="flex items-center gap-1 text-sm md:text-[17px] font-extrabold">
                                <svg width="12" height="12" viewBox="0 0 24 24" class="md:w-3.5 md:h-3.5 fill-current text-orange"><path d="M12 2l2.9 6.3 6.6.8-4.9 4.6 1.3 6.6-5.9-3.4-5.9 3.4 1.3-6.6-4.9-4.6 6.6-.8z"></path></svg>@mData.Agent.Rating
                            </span>
                            <span class="text-[10.5px] md:text-[11px] font-bold text-text-muted whitespace-nowrap">팀·학부모 평가</span>
                        </span>
                    }
                    @if (mData.Agent.ActiveRegions is not null)
                    {
                        <span class="flex flex-col gap-px md:gap-0.5 flex-1">
                            <span class="text-sm md:text-[17px] font-extrabold whitespace-nowrap">@mData.Agent.ActiveRegions</span>
                            <span class="text-[10.5px] md:text-[11px] font-bold text-text-muted whitespace-nowrap">활동 지역</span>
                        </span>
                    }
                </div>
            }
        </div>
    };

    private string AgencyLine => string.Join(" · ", new[]
    {
        mData?.Agent.AgencyName,
        mData?.Agent.RegisteredYear is int year ? $"등록 {year}" : null,
    }.Where(v => v is not null));

    private bool HasStats => mData is not null
        && (mData.Agent.BrokerageCount > 0 || mData.Agent.Rating is not null || mData.Agent.ActiveRegions is not null);

    private RenderFragment RequestCard => __builder =>
    {
        <div class="flex flex-col gap-[9px] md:bg-white md:border-1.5 md:border-border md:rounded-2xl md:p-[20px_22px] md:gap-[11px]">
            <span class="text-[13px] md:text-[13.5px] font-extrabold text-text-strong">요청 내용</span>
            <div class="bg-surface-soft rounded-xl px-4 py-3.5 flex flex-col gap-2.5 md:bg-transparent md:rounded-none md:p-0">
                <span class="text-[13px] md:text-[13.5px] text-text-strong leading-[1.65] md:leading-[1.7] break-keep"><b>@mData!.PlayerName</b>@(PlayerMeta is not null ? $"({PlayerMeta})" : "") @mData.Message</span>
                <span class="text-[11px] md:text-[11.5px] text-text-muted whitespace-nowrap">@RequestedAtText(mData.RequestedAt)</span>
            </div>
        </div>
    };

    private RenderFragment ScopeCard => __builder =>
    {
        <div class="flex flex-col gap-[9px] md:bg-white md:border-1.5 md:border-border md:rounded-2xl md:p-[18px_20px] md:gap-2.5">
            <span class="flex items-center gap-1.5">
                <span class="text-[13px] md:text-[13.5px] font-extrabold text-text-strong">승인 시 열람되는 정보</span>
                @* 서비스 고유 개념 보조 설명 (Design.TooltipHelp §2 — dc 데모 카피 그대로) *@
                <InfoPopover Title="에이전트 열람이란?">인증된 에이전트가 자녀의 상세 기록을 보려면 보호자 승인이 필요해요. 승인 후 30일이 지나면 자동 만료돼요.</InfoPopover>
            </span>
            <div class="border-1.5 border-border rounded-xl px-4 py-1.5 flex flex-col md:border-0 md:rounded-none md:p-0">
                @foreach ((string label, string note) in Scopes)
                {
                    <div class="flex items-center gap-2.5 py-[9px] border-b border-surface-soft">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="flex-none text-teal"><path d="M5 12.5l4.5 4.5 9-10"></path></svg>
                        <span class="text-[12.5px] font-bold text-navy-deep flex-1 break-keep">@label</span>
                        @if (note.Length > 0)
                        {
                            <span class="text-[11px] text-text-muted whitespace-nowrap">@note</span>
                        }
                    </div>
                }
                <div class="flex items-center gap-2.5 py-[9px]">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" class="flex-none text-danger"><path d="M6 6l12 12M18 6L6 18"></path></svg>
                    <span class="text-[12.5px] font-bold text-text-muted flex-1 break-keep">연락처 직접 노출</span>
                    <span class="text-[11px] text-text-muted whitespace-nowrap">항상 제외 — 플랫폼 메시지만</span>
                </div>
            </div>
            <div class="bg-teal/[.08] rounded-[11px] px-3.5 py-[11px] flex gap-[9px] items-start">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="flex-none mt-px text-teal-ink"><rect x="4" y="9" width="16" height="11" rx="2.5"></rect><path d="M8 9V6.5a4 4 0 0 1 8 0V9"></path></svg>
                <span class="text-[11.5px] text-teal-ink leading-[1.6] break-keep">승인은 <b>30일 후 자동 만료</b>되고, 에이전트의 모든 열람 기록이 보호자님께 표시됩니다. 언제든 철회할 수 있어요.</span>
            </div>
        </div>
    };

    private static readonly (string Label, string Note)[] Scopes =
    {
        ("경기별 상세 기록", "득점·도움·출전분"),
        ("학교 · 학년", ""),
        ("커리어 검증 상태", "팀 확인됨 표시"),
        ("보호자에게 연락하기", "플랫폼 메시지"),
    };

    private RenderFragment ViewLogCard => __builder =>
    {
        <div class="border-1.5 border-border rounded-xl px-4 py-1.5 flex flex-col md:bg-white md:rounded-2xl md:px-[22px] md:py-4">
            <span class="text-xs md:text-[13.5px] font-extrabold text-text-strong pt-[9px] pb-1 md:pt-0 md:pb-1.5">열람 기록</span>
            @foreach (AgentViewLogDto log in mData!.Logs)
            {
                <div class="flex items-center gap-[9px] md:gap-2.5 py-2 md:py-[9px] border-t border-surface-soft">
                    <span class="w-1.5 h-1.5 rounded-full bg-agent flex-none"></span>
                    <span class="text-xs md:text-[13px] text-text-strong flex-1 break-keep">@LogLabel(log.EventType)</span>
                    <span class="text-[11px] md:text-[11.5px] text-text-muted whitespace-nowrap">@LogTimeText(log.CreatedAt)</span>
                </div>
            }
        </div>
    };

    private RenderFragment ActionBlock => __builder =>
    {
        @if (IsPending)
        {
            <div class="flex flex-col gap-[9px]">
                <div class="flex gap-[9px]">
                    <button type="button" disabled="@mBusy" @onclick="ApproveAsync"
                            class="flex-[1.6] md:flex-1 h-[50px] border-0 rounded-xl bg-teal hover:bg-teal/90 text-[14.5px] font-bold text-white cursor-pointer whitespace-nowrap shadow-[0_5px_16px_rgba(46,196,182,.3)] transition-colors">30일 열람 승인</button>
                    <button type="button" disabled="@mBusy" @onclick="DenyAsync"
                            class="flex-1 md:hidden h-[50px] border-1.5 border-border rounded-xl bg-white text-sm font-bold text-text-body cursor-pointer whitespace-nowrap hover:border-danger hover:text-danger transition-colors">거절</button>
                </div>
                <button type="button" disabled="@mBusy" @onclick="DenyAsync"
                        class="hidden md:block h-[46px] border-1.5 border-border rounded-xl bg-white text-[13.5px] font-bold text-text-body cursor-pointer whitespace-nowrap hover:border-danger hover:text-danger transition-colors">거절</button>
                <button type="button" disabled="@mBusy" @onclick="BlockAsync"
                        class="h-10 md:h-9 border-0 bg-transparent text-[12.5px] md:text-xs font-bold text-text-muted cursor-pointer whitespace-nowrap">이 에이전트의 요청 다시 받지 않기</button>
            </div>
        }
        else if (IsApproved)
        {
            <div class="flex flex-col gap-2.5">
                <div class="flex items-center gap-[9px] bg-teal/10 rounded-xl px-3.5 py-3">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="flex-none text-teal-ink"><path d="M4.5 12.5l5 5 10-11"></path></svg>
                    <span class="text-[12.5px] md:text-[13px] font-bold text-teal-ink break-keep">@ExpiryText</span>
                </div>
                <button type="button" disabled="@mBusy" @onclick="RevokeAsync"
                        class="h-[46px] border-1.5 border-danger/25 rounded-xl bg-white text-[13px] font-bold text-danger cursor-pointer whitespace-nowrap hover:bg-danger/5 transition-colors">열람 권한 철회</button>
            </div>
        }
        else
        {
            <div class="flex flex-col gap-2.5">
                <div class="flex items-center gap-[9px] bg-surface-alt rounded-xl px-3.5 py-3">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" class="flex-none text-text-body"><path d="M6 6l12 12M18 6L6 18"></path></svg>
                    <span class="text-[12.5px] md:text-[13px] font-bold text-text-body break-keep">거절됨 — 에이전트에게는 사유 없이 "거절"만 전달돼요</span>
                </div>
                <span class="text-[11.5px] text-text-muted leading-[1.6] break-keep">같은 에이전트는 30일간 다시 요청할 수 없어요. 마음이 바뀌면 알림 센터의 요청 기록에서 다시 승인할 수 있습니다.</span>
            </div>
        }
    };

    private static string InitialOf(string name)
    {
        return string.IsNullOrEmpty(name) ? "?" : name[..1];
    }
}
