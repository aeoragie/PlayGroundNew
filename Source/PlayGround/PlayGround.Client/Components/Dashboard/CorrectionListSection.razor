@* 내 기록 수정 신청 목록 (Design.RecordCorrection §3).
   상태 3종: 접수(오렌지·취소 가능) / 반영(teal) / 반려(연레드 + **사유 필수 표시**).
   신청이 하나도 없으면 섹션 자체를 렌더하지 않는다 — 평소엔 비어 있는 게 정상이라
   빈 상태 카드를 두면 경기 결과 화면이 늘 어수선해진다. *@
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Team
@using PlayGround.Domain.Soccer

@if (Corrections.Count > 0)
{
    <div class="flex flex-col gap-3">
        <div class="flex items-center gap-2.5">
            <h3 class="m-0 text-[15px] font-extrabold text-navy-deep">기록 수정 신청</h3>
            <span class="@Css.Correction.Meta">@(Corrections.Count)건</span>
        </div>

        <div class="@Css.Correction.ListCard">
            @foreach (RecordCorrectionDto correction in Corrections)
            {
                SoccerCorrectionStatus status = SoccerCorrectionStatusExtensions.Parse(correction.Status);
                bool isRejected = status == SoccerCorrectionStatus.Rejected;

                <div class="@(isRejected ? Css.Correction.RowRejected : Css.Correction.Row)">
                    <div class="flex items-center gap-3">
                        <span class="flex flex-col gap-px flex-1 min-w-0">
                            <span class="@Css.Correction.Summary">@SummaryOf(correction)</span>
                            <span class="@Css.Correction.Meta">@MetaOf(correction)</span>
                        </span>
                        <span class="@Css.Correction.StatusBadge(correction.Status)">@status.ToLabel()</span>

                        @* 취소는 접수 상태에서만 — 심사가 끝난 건은 손댈 수 없다 *@
                        @if (status == SoccerCorrectionStatus.Pending)
                        {
                            <OverflowMenu Target="@SummaryOf(correction)"
                                          DestructiveItems="@BuildCancelItems(correction)" />
                        }
                    </div>

                    @if (isRejected && correction.RejectReason is not null)
                    {
                        <div class="@Css.Correction.ReasonBox">
                            <b>반려 사유</b> — @correction.RejectReason
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public List<RecordCorrectionDto> Corrections { get; set; } = new();

    /// <summary>신청 취소 — 확인 모달·재조회는 페이지가 맡는다.</summary>
    [Parameter]
    public EventCallback<RecordCorrectionDto> OnCancel { get; set; }

    // "리그 12R 스코어 3:1 → 3:2" — 대회명(있으면) + 항목 + 현재→요청
    internal static string SummaryOf(RecordCorrectionDto correction)
    {
        SoccerCorrectionFieldExtensions.TryParse(correction.FieldType, out SoccerCorrectionField field);
        string head = correction.TournamentName ?? $"vs {correction.OpponentName}";
        string change = correction.CurrentValue is null
            ? correction.RequestedValue
            : $"{correction.CurrentValue} → {correction.RequestedValue}";

        return $"{head} {field.ToLabel()} {change}";
    }

    // "3/15 신청" + 심사 끝났으면 "· 3/17 반영됨"
    private static string MetaOf(RecordCorrectionDto correction)
    {
        string requested = $"{correction.RequestedAt.Month}/{correction.RequestedAt.Day} 신청";
        if (correction.ReviewedAt is null)
        {
            return requested;
        }

        SoccerCorrectionStatus status = SoccerCorrectionStatusExtensions.Parse(correction.Status);
        string verb = status == SoccerCorrectionStatus.Accepted ? "반영됨" : "반려됨";
        return $"{requested} · {correction.ReviewedAt.Value.Month}/{correction.ReviewedAt.Value.Day} {verb}";
    }

    private List<OverflowMenu.MenuItem> BuildCancelItems(RecordCorrectionDto correction) => new()
    {
        new OverflowMenu.MenuItem("신청 취소", () => OnCancel.InvokeAsync(correction)),
    };
}
