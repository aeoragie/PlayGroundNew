@* 좌측 사이드바(230px): 팀 요약 + 섹션 메뉴(선택 = 네이비 채움) + P1 예정 비활성 메뉴 *@
@using PlayGround.Contracts.Team
<aside class="w-[230px] shrink-0 bg-bg border-r border-border px-3.5 py-[22px] flex flex-col gap-1">
    @if (Team is not null)
    {
        <div class="flex items-center gap-3 px-3 pt-2.5 pb-[18px]">
            <span class="w-11 h-11 rounded-xl bg-navy flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5.5c0 4.5-3 7.6-7 9.5-4-1.9-7-5-7-9.5V6z"></path></svg>
            </span>
            <span class="flex flex-col gap-0.5 min-w-0">
                <span class="text-[15px] font-extrabold tracking-[-.01em] text-navy-deep whitespace-nowrap overflow-hidden text-ellipsis">@Team.TeamName</span>
                @if (Team.IsVerified || SummaryMeta.Length > 0)
                {
                    <span class="text-[11.5px] font-bold text-orange-ink flex items-center gap-1 whitespace-nowrap">
                        @if (Team.IsVerified)
                        {
                            <text>✓ 인증팀 </text>
                        }
                        @if (SummaryMeta.Length > 0)
                        {
                            <span class="text-text-muted font-semibold">@(Team.IsVerified ? "· " : "")@SummaryMeta</span>
                        }
                    </span>
                }
            </span>
        </div>
    }

    @foreach (NavItem item in NavItems)
    {
        <a href="@($"dashboard/team/{item.Section.ToSlug()}")" class="@NavClass(item.Section)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">@((MarkupString)item.IconPaths)</svg>@item.Label
        </a>
    }

    <div class="mx-3 mt-3.5 mb-1.5 text-[11px] font-extrabold text-text-faint tracking-[.08em]">P1 예정</div>
    <div class="flex flex-col gap-0.5 opacity-55">
        @foreach (PlannedItem item in PlannedItems)
        {
            <div class="flex items-center gap-2.5 px-3 py-2.5 text-sm font-semibold text-text-muted">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">@((MarkupString)item.IconPaths)</svg>@item.Label
            </div>
        }
    </div>
</aside>

@code {
    [Parameter]
    public SoccerTeamDashboardSection ActiveSection { get; set; } = SoccerTeamDashboardSection.Info;

    [Parameter]
    public TeamProfileDto? Team { get; set; }

    // "클럽 · 서울" — 있는 값만 이어 붙인다
    private string SummaryMeta =>
        string.Join(" · ", new[] { Team?.TeamType, Team?.Region }.Where(v => v is not null));

    private sealed record NavItem(SoccerTeamDashboardSection Section, string Label, string IconPaths);

    // P1 예정 메뉴 — 아직 섹션이 아니라 라우트 없음
    private sealed record PlannedItem(string Label, string IconPaths);

    private static readonly NavItem[] NavItems =
    [
        new(SoccerTeamDashboardSection.Info, "팀 정보", """<path d="M12 3l7 3v5.5c0 4.5-3 7.6-7 9.5-4-1.9-7-5-7-9.5V6z"></path>"""),
        new(SoccerTeamDashboardSection.Roster, "선수단", """<circle cx="9" cy="8" r="3.2"></circle><path d="M3.5 19.5c0-3 2.5-5.2 5.5-5.2s5.5 2.2 5.5 5.2"></path><path d="M16 5.6a2.8 2.8 0 0 1 0 5.4"></path><path d="M17.5 14.6c2 .7 3 2.4 3 4.4"></path>"""),
        new(SoccerTeamDashboardSection.Schedule, "일정", """<rect x="3.5" y="5" width="17" height="15.5" rx="2.5"></rect><path d="M3.5 10h17M8 3v4M16 3v4"></path>"""),
        new(SoccerTeamDashboardSection.Results, "경기 결과", """<path d="M5 20V11M12 20V4M19 20v-6"></path>"""),
        new(SoccerTeamDashboardSection.Videos, "경기영상", """<rect x="3" y="5" width="18" height="14.5" rx="3"></rect><path d="M10 9.5l5 3-5 3z"></path>"""),
        new(SoccerTeamDashboardSection.Recruit, "선수 모집", """<path d="M3 10.5v3h3.5l9.5 5v-13l-9.5 5z"></path><path d="M19.5 9.5a4 4 0 0 1 0 5"></path>"""),
    ];

    private static readonly PlannedItem[] PlannedItems =
    [
        new("팀 게시판", """<path d="M20 15a2 2 0 0 1-2 2H8l-4 4V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2z"></path>"""),
        new("회비 · 출결", """<rect x="3" y="6" width="18" height="13" rx="2.5"></rect><path d="M3 10.5h18"></path>"""),
        new("메시지", """<rect x="3" y="5.5" width="18" height="13.5" rx="2.5"></rect><path d="M3.5 7l8.5 6.5L20.5 7"></path>"""),
    ];

    private string NavClass(SoccerTeamDashboardSection section)
    {
        string baseClass = "flex items-center gap-2.5 rounded-[10px] px-3 py-[11px] text-sm font-bold transition-colors ";
        return baseClass + (ActiveSection == section
            ? "bg-navy text-white"
            : "text-text-strong hover:bg-surface-icon");
    }
}
