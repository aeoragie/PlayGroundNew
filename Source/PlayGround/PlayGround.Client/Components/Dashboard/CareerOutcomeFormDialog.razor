@* 진학·진로 사례 등록·수정 — PC 중앙 모달 / 모바일 전체 시트 (Css.MatchForm 골격 재사용).
   "선수 개인이 공개에 동의한 사례만" 규칙은 동의 데이터가 없어 입력 안내 카피로 강제한다.
   저장 성공 = 토스트(A2), 검증 오류 = 인라인(폼 오류에 토스트 금지). *@
@using PlayGround.Client.Services.Feedback
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Team
@using PlayGround.Domain.Soccer
@inject TeamClient Teams
@inject ToastService Toasts

@if (IsOpen)
{
    <div class="@Css.MatchForm.Overlay">
        <div class="fixed inset-0" @onclick="CancelAsync"></div>

        <div class="@Css.MatchForm.Card">
            <span class="@Css.MatchForm.GrabBar"></span>

            <div class="@Css.MatchForm.Header">
                <span class="flex flex-col gap-1 min-w-0">
                    <h2 class="@Css.MatchForm.Title">@(IsEdit ? "진학·진로 사례 수정" : "진학·진로 사례 등록")</h2>
                    <span class="@Css.MatchForm.Subtitle">선수 개인(보호자)이 공개에 동의한 사례만 등록해 주세요. 저장하면 공개 홈페이지 진학·진로 탭에 바로 반영돼요.</span>
                </span>
                <button type="button" aria-label="닫기" class="@Css.MatchForm.CloseButton" @onclick="CancelAsync">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
                         stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg>
                </button>
            </div>

            <CascadingValue Value="@mForm" IsFixed="true">
                <div class="@Css.MatchForm.Body">
                    <RadioCards TValue="SoccerCareerOutcomeType" Label="유형" @bind-Value="mType"
                                Options="@TypeOptions" />

                    <TextField Label="연도" @bind-Value="mYear" Placeholder="@DateTime.Now.Year.ToString()"
                               Validator="ValidateYear" MaxLength="4" />

                    <TextField Label="제목" @bind-Value="mTitle" Placeholder="K리그 산하 U18 이적 1명"
                               Validator="ValidateTitle" MaxLength="100" />

                    <TextField Label="상세" @bind-Value="mDetail" IsOptional="true" MaxLength="200"
                               Placeholder="MF · U15 출신 · 3년 재적"
                               Helper="포지션·출신 연령·재적 기간처럼 방문자가 참고할 내용을 적어 주세요." />

                    <TextField Label="인원" @bind-Value="mPlayerCount" Placeholder="1"
                               Validator="ValidatePlayerCount" MaxLength="2"
                               Helper="요약 카드의 유형별 인원 수에 합산돼요." />
                </div>

                <div class="@Css.MatchForm.Footer">
                    <button type="button" class="@Css.MatchForm.CancelButton" @onclick="CancelAsync">취소</button>
                    <SubmitButton Label="@(IsEdit ? "사례 저장" : "사례 등록")" BusyLabel="저장 중…" IsBusy="@mSaving"
                                  OnClick="SubmitAsync" Class="@Css.MatchForm.SubmitWidth" />
                </div>
            </CascadingValue>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    /// <summary>수정 대상 — null이면 신규 등록.</summary>
    [Parameter]
    public TeamCareerOutcomeDto? Editing { get; set; }

    /// <summary>저장 성공 후 — 부모가 목록을 다시 불러온다.</summary>
    [Parameter]
    public EventCallback OnSaved { get; set; }

    private static readonly List<SelectOption<SoccerCareerOutcomeType>> TypeOptions = new()
    {
        new SelectOption<SoccerCareerOutcomeType>(SoccerCareerOutcomeType.ProTransfer, "프로 산하 이적"),
        new SelectOption<SoccerCareerOutcomeType>(SoccerCareerOutcomeType.SchoolTeam, "축구부 진학"),
        new SelectOption<SoccerCareerOutcomeType>(SoccerCareerOutcomeType.Promotion, "상급 연령팀 승격"),
    };

    private readonly FormFieldContext mForm = new();

    private SoccerCareerOutcomeType mType = SoccerCareerOutcomeType.ProTransfer;
    private string mYear = string.Empty;
    private string mTitle = string.Empty;
    private string mDetail = string.Empty;
    private string mPlayerCount = "1";
    private bool mSaving;
    private Guid mLoadedFor;

    private bool IsEdit => Editing is not null;

    protected override void OnParametersSet()
    {
        if (!IsOpen)
        {
            mLoadedFor = Guid.Empty;
            return;
        }

        // 열릴 때 1회 프리필 (수정) — 재렌더마다 입력을 덮어쓰지 않는다
        Guid target = Editing?.OutcomeId ?? Guid.Empty;
        if (Editing is not null && mLoadedFor != target)
        {
            mLoadedFor = target;
            mType = Enum.TryParse(Editing.OutcomeType, out SoccerCareerOutcomeType parsed)
                ? parsed : SoccerCareerOutcomeType.ProTransfer;
            mYear = Editing.OutcomeYear.ToString();
            mTitle = Editing.Title;
            mDetail = Editing.Detail ?? string.Empty;
            mPlayerCount = Editing.PlayerCount.ToString();
        }
        else if (Editing is null && mLoadedFor == Guid.Empty && mYear.Length == 0)
        {
            mYear = DateTime.Now.Year.ToString();
        }
    }

    private static string? ValidateTitle(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "제목을 입력해 주세요." : null;

    private static string? ValidateYear(string? value)
    {
        if (!int.TryParse(value, out int year))
        {
            return "연도를 입력해 주세요.";
        }

        return year < 1990 || year > DateTime.Now.Year + 1 ? "연도를 다시 확인해 주세요." : null;
    }

    private static string? ValidatePlayerCount(string? value)
    {
        if (!int.TryParse(value, out int count))
        {
            return "인원을 입력해 주세요.";
        }

        return count is < 1 or > 99 ? "인원은 1~99명 사이여야 해요." : null;
    }

    private async Task SubmitAsync()
    {
        bool fieldsValid = await mForm.ValidateAllAsync();
        if (!fieldsValid)
        {
            return;
        }

        var request = new SaveTeamCareerOutcomeRequest
        {
            OutcomeId = Editing?.OutcomeId ?? Guid.Empty,
            OutcomeYear = int.Parse(mYear),
            OutcomeType = mType.ToString(),
            Title = mTitle.Trim(),
            Detail = string.IsNullOrWhiteSpace(mDetail) ? null : mDetail.Trim(),
            PlayerCount = int.Parse(mPlayerCount),
        };

        mSaving = true;
        RecruitmentSaveResult result = await Teams.SaveCareerOutcomeAsync(request);
        mSaving = false;

        if (!result.Success)
        {
            if (result.IsNetworkError)
            {
                Toasts.ShowError(result.Error ?? "저장하지 못했어요.", "재시도", SubmitAsync);
            }
            else
            {
                Toasts.ShowError(result.Error ?? "저장하지 못했어요.");
            }

            return;
        }

        Toasts.ShowSuccess(IsEdit ? "사례를 저장했어요." : "사례를 등록했어요. 공개 홈페이지에서 확인할 수 있어요.");
        Reset();
        await IsOpenChanged.InvokeAsync(false);
        await OnSaved.InvokeAsync();
    }

    private async Task CancelAsync()
    {
        Reset();
        await IsOpenChanged.InvokeAsync(false);
    }

    private void Reset()
    {
        mType = SoccerCareerOutcomeType.ProTransfer;
        mYear = string.Empty;
        mTitle = string.Empty;
        mDetail = string.Empty;
        mPlayerCount = "1";
        mLoadedFor = Guid.Empty;
    }
}
