@* 선수 프로필 연결(Claim) 상태 뱃지: Claimed(teal) / Pending(오렌지톤) / Unclaimed(회색) *@
<span class="@BadgeClass">@Status</span>

@code {
    [Parameter, EditorRequired]
    public SoccerClaimStatus Status { get; set; }

    private string BadgeClass =>
        "text-[11.5px] font-bold rounded-full px-[11px] py-1 w-fit whitespace-nowrap " + Status switch
        {
            SoccerClaimStatus.Claimed => "text-teal-ink bg-teal/[.12]",
            SoccerClaimStatus.Pending => "text-orange-ink bg-surface-orange-badge",
            _ => "text-text-muted bg-surface-icon",
        };
}
