@* 경기 결과 섹션: 시즌 요약 4카드 + 세그먼트 + 경기 카드 — SPEC.TEAMDASHBOARD.md §4
   결과 없으면 현재 상태 + 등록 가이드 안내. 승무패·요약은 팀 관점 스코어에서 파생.
   **요약은 공식 경기만 집계한다** — 친선은 합산하지 않고 아래 한 줄로 따로 알린다(Design.FriendlyMatch). *@
@using PlayGround.Client.Models
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Team

<div class="flex flex-col gap-[18px]">
    <div class="flex justify-between items-center">
        <h1 class="@Css.Dashboard.SectionTitle">경기 결과</h1>
        <button type="button" class="@Css.Dashboard.PrimaryButton" @onclick="OnAddResult">＋ 결과 입력</button>
    </div>

    @if (Data.Matches.Count == 0)
    {
        @* 빈 상태 Tier A (주 액션은 헤더의 ＋ 결과 입력 하나 유지 — 카드 안 CTA 없음) *@
        <EmptyState Kind="EmptyState.Art.Record" Title="아직 등록된 경기 결과가 없어요">
            <Description>＋ 결과 입력으로 첫 경기를 기록해 보세요.<br />득점·도움은 선수 시즌 통계에, 결과는 공개 홈페이지와 경기기록(Records)에 자동 반영돼요.</Description>
        </EmptyState>
    }
    else
    {
        @* 시즌 요약 — 공식 경기만 *@
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <div class="bg-navy-deep rounded-[14px] px-[18px] py-4 flex flex-col gap-[3px] text-white">
                <span class="text-xs font-bold text-white/60">@(Data.SeasonYear) 시즌 (공식)</span>
                <span class="text-[21px] font-extrabold whitespace-nowrap">@(Wins)승 @(Draws)무 @(Losses)패</span>
            </div>
            <div class="@SummaryCardClass">
                <span class="text-xs font-bold text-text-muted">득점 (공식)</span>
                <span class="text-[21px] font-extrabold text-navy-deep">@GoalsFor</span>
            </div>
            <div class="@SummaryCardClass">
                <span class="text-xs font-bold text-text-muted">실점 (공식)</span>
                <span class="text-[21px] font-extrabold text-navy-deep">@GoalsAgainst</span>
            </div>
            @if (Data.LeagueRank is not null)
            {
                <div class="@SummaryCardClass">
                    <span class="text-xs font-bold text-text-muted">리그 순위</span>
                    <span class="text-[21px] font-extrabold text-navy-deep">@(Data.LeagueRank)위</span>
                </div>
            }
        </div>

        @* 요약에 합산되지 않은 친선 — 왜 목록과 수가 다른지 알려 준다 *@
        @if (FriendlyCount > 0)
        {
            <span class="@Css.FriendlyMatch.Note">친선경기 @(FriendlyCount)경기는 별도예요 — 순위표와 시즌 기록에는 반영되지 않아요.</span>
        }

        @* 세그먼트 (전체 / 공식 / 친선경기) — 상태는 URL에 있다 *@
        <MatchSegment Value="@Segment" ValueChanged="OnSegmentChanged" />

        @* 경기 카드 *@
        <div class="flex flex-col gap-3">
            @foreach (TeamMatchDto match in FilteredMatches)
            {
                bool isFriendly = SoccerMatchTypeExtensions.IsFriendly(match.MatchType);
                <div class="@Css.FriendlyMatch.Row(isFriendly, $"{(isFriendly ? "rounded-[14px]" : Css.Dashboard.Card + " rounded-[14px]")} px-[22px] py-[18px] flex flex-col gap-3")">
                    <div class="flex items-center gap-3.5">
                        @if (isFriendly)
                        {
                            @* 대회명 자리에 회색 라벨 — 뱃지를 하나 더 붙이지 않는다(행당 1개 규칙) *@
                            <span class="@Css.FriendlyMatch.Label">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M18.4 5.6L17 7M7 17l-1.4 1.4"></path>
                                    <circle cx="12" cy="12" r="4"></circle>
                                </svg>친선경기
                            </span>
                        }
                        else
                        {
                            <span class="@CompetitionClass(CompetitionOf(match))">@CompetitionOf(match).ToLabel()</span>
                        }
                        <span class="text-[12.5px] text-text-muted">@MetaLine(match)</span>
                        <div class="flex-1"></div>
                        <span class="@OutcomeClass(OutcomeOf(match), isFriendly)">@OutcomeOf(match).ToLabel()</span>
                    </div>
                    <div class="flex items-center justify-center gap-[22px]">
                        <span class="text-[15.5px] font-extrabold text-navy-deep flex-1 text-right break-keep">@TeamName</span>
                        <span class="@($"text-2xl font-extrabold rounded-[10px] px-[18px] py-1.5 whitespace-nowrap {(isFriendly ? $"{Css.FriendlyMatch.Score} bg-surface-icon" : "text-navy-deep bg-surface-alt")}")">@match.TeamScore : @match.OpponentScore</span>
                        <span class="text-[15.5px] font-bold text-text-body flex-1 break-keep">@match.OpponentName</span>
                    </div>
                    @{
                        List<string> chips = EventChips(match);
                    }
                    @if (chips.Count > 0)
                    {
                        <div class="flex gap-2 flex-wrap justify-center">
                            @foreach (string chip in chips)
                            {
                                <span class="text-xs font-bold text-text-strong bg-surface-icon rounded-full px-3 py-1 whitespace-nowrap">@chip</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <div class="text-[12.5px] text-text-muted break-keep">득점·도움은 해당 선수 프로필의 시즌 통계에 자동 반영 · 결과는 공개 홈페이지와 경기기록(Records)에 노출돼요</div>
    }
</div>

@code {
    private const string SummaryCardClass =
        "bg-white border-1.5 border-border rounded-[14px] px-[18px] py-4 flex flex-col gap-[3px]";

    [Parameter, EditorRequired]
    public TeamMatchesResponse Data { get; set; } = new();

    /// <summary>목록 세그먼트 — 값은 URL에 있고 페이지가 내려 준다.</summary>
    [Parameter]
    public SoccerMatchSegment Segment { get; set; } = SoccerMatchSegment.All;

    [Parameter]
    public EventCallback<SoccerMatchSegment> OnSegmentChanged { get; set; }

    /// <summary>경기 카드의 아군 팀명 (페이지가 팀 프로필에서 전달).</summary>
    [Parameter, EditorRequired]
    public string TeamName { get; set; } = string.Empty;

    /// <summary>"＋ 결과 입력" — 페이지가 입력 다이얼로그를 연다(로스터·재조회를 페이지가 쥐고 있다).</summary>
    [Parameter]
    public EventCallback OnAddResult { get; set; }

    private IEnumerable<TeamMatchDto> FilteredMatches =>
        Data.Matches.Where(match => Segment.Matches(match.MatchType));

    //.// 요약 집계 (팀 관점 스코어) — 공식만. 친선을 섞으면 순위표와 숫자가 어긋난다

    private List<TeamMatchDto> OfficialMatches => OfficialOf(Data.Matches);

    private int FriendlyCount => Data.Matches.Count(m => SoccerMatchTypeExtensions.IsFriendly(m.MatchType));

    private int Wins => OfficialMatches.Count(m => m.TeamScore > m.OpponentScore);
    private int Draws => OfficialMatches.Count(m => m.TeamScore == m.OpponentScore);
    private int Losses => OfficialMatches.Count(m => m.TeamScore < m.OpponentScore);
    private int GoalsFor => OfficialMatches.Sum(m => m.TeamScore);
    private int GoalsAgainst => OfficialMatches.Sum(m => m.OpponentScore);

    /// <summary>집계 대상 = 공식 경기. 모바일·공개홈 요약도 같은 규칙을 쓴다.</summary>
    internal static List<TeamMatchDto> OfficialOf(IEnumerable<TeamMatchDto> matches) =>
        matches.Where(m => !SoccerMatchTypeExtensions.IsFriendly(m.MatchType)).ToList();

    internal static int FriendlyCountOf(IEnumerable<TeamMatchDto> matches) =>
        matches.Count(m => SoccerMatchTypeExtensions.IsFriendly(m.MatchType));

    //.// 표시 파생 — PC·모바일 공유

    internal static SoccerCompetitionType CompetitionOf(TeamMatchDto match)
    {
        return Enum.TryParse(match.CompetitionType, out SoccerCompetitionType parsed) ? parsed : SoccerCompetitionType.Friendly;
    }

    internal static SoccerMatchOutcome OutcomeOf(TeamMatchDto match)
    {
        if (match.TeamScore > match.OpponentScore)
        {
            return SoccerMatchOutcome.Win;
        }

        return match.TeamScore == match.OpponentScore ? SoccerMatchOutcome.Draw : SoccerMatchOutcome.Loss;
    }

    // "7/5 · 신답체육공원" — 구장 없으면 홈/원정
    internal static string MetaLine(TeamMatchDto match)
    {
        string date = match.MatchedAt is null ? "일정 미정" : $"{match.MatchedAt.Value.Month}/{match.MatchedAt.Value.Day}";
        return $"{date} · {match.VenueName ?? (match.IsHome ? "홈" : "원정")}";
    }

    // "득점 김민준 ×2" / "도움 이서준" — 이름 있는 이벤트만, 자책골 제외
    internal static List<string> EventChips(TeamMatchDto match)
    {
        List<string> chips = new();
        chips.AddRange(match.Events
            .Where(e => e.EventType != "OwnGoal" && e.PlayerName is not null)
            .GroupBy(e => e.PlayerName!)
            .Select(g => g.Count() > 1 ? $"득점 {g.Key} ×{g.Count()}" : $"득점 {g.Key}"));
        chips.AddRange(match.Events
            .Where(e => e.AssistPlayerName is not null)
            .GroupBy(e => e.AssistPlayerName!)
            .Select(g => g.Count() > 1 ? $"도움 {g.Key} ×{g.Count()}" : $"도움 {g.Key}"));
        return chips;
    }

    internal static string CompetitionClass(SoccerCompetitionType competition) =>
        "text-[11.5px] font-bold rounded-full px-[11px] py-[3px] whitespace-nowrap " + competition switch
        {
            SoccerCompetitionType.League => "text-navy bg-surface-icon",
            SoccerCompetitionType.Cup => "text-orange-ink bg-surface-orange-badge",
            _ => "text-teal-ink bg-teal/[.12]",
        };

    /// <summary>친선은 중립 회색 톤 — 공식의 teal/레드와 눈으로 구분된다(뱃지를 늘리지 않고 톤으로).</summary>
    internal static string OutcomeClass(SoccerMatchOutcome outcome, bool isFriendly = false)
    {
        const string Shape = "text-[12.5px] font-extrabold rounded-lg px-[13px] py-[5px] whitespace-nowrap ";
        if (isFriendly)
        {
            return Shape + "text-text-muted bg-surface-icon";
        }

        return Shape + outcome switch
        {
            SoccerMatchOutcome.Win => "text-white bg-teal",
            SoccerMatchOutcome.Draw => "text-text-strong bg-surface-icon",
            _ => "text-white bg-text-muted",
        };
    }
}
