@* 상단 GNB(관리 모드): 네이비 sticky 60px — 로고 + 모드 pill + 공개 홈페이지 보기 / 알림 / 아바타 *@
<header class="sticky top-0 z-40 h-[60px] bg-navy-deep flex items-center gap-3.5 px-6 text-white">
    <BrandLogo Href="@Routes.Landing" InheritColor="true" />
    <span class="text-[11.5px] font-bold text-white/60 bg-white/10 rounded-full px-[11px] py-[3px] whitespace-nowrap">팀 관리자 모드</span>
    <div class="flex-1"></div>
    @if (Slug is not null)
    {
        <a href="@Routes.TeamPublicHome(Slug)" target="_blank" class="flex items-center gap-[7px] text-[13.5px] font-bold text-white/85 hover:text-teal transition-colors whitespace-nowrap">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <path d="M15 3h6v6M10 14L21 3"></path>
            </svg>공개 홈페이지 보기
        </a>
    }
    <NotificationBell ContextLabel="@TeamName" />
    <AccountMenu DisplayName="@DisplayName" RoleCaption="팀 관리자" />
</header>

@code {
    /// <summary>공개 팀 홈페이지 슬러그 — null이면 링크를 렌더하지 않는다 (팀 정보 로딩 전 포함).</summary>
    [Parameter]
    public string? Slug { get; set; }

    /// <summary>알림 패널 컨텍스트(팀명). null이면 표시하지 않는다.</summary>
    [Parameter]
    public string? TeamName { get; set; }

    /// <summary>아바타 이니셜용 사용자 표시 이름.</summary>
    [Parameter]
    public string? DisplayName { get; set; }
}
