@* 선수단 섹션: 연령 탭 + 리스트/카드 뷰 토글 + Claim 상태 — SPEC.TEAMDASHBOARD.md §2
   연령 탭은 전원 AgeGroup 보유 시만 노출 (온보딩 로스터는 null — 전부 표시).
   Unclaimed 안내 박스는 Unclaimed 선수 존재 시만.
   "초대코드 보내기" 클릭 → 코드 표시 + 클립보드 복사 (관리자가 직접 전달). *@
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Team
@inject IJSRuntime Js

<div class="flex flex-col gap-[18px]">
    <div class="flex justify-between items-center">
        <h1 class="@Css.Dashboard.SectionTitle">선수단 <span class="text-sm font-bold text-text-muted">@(Players.Count)명</span></h1>
        <div class="flex gap-2">
            <div class="flex border-1.5 border-border rounded-[10px] overflow-hidden h-[42px]">
                <button type="button" class="@ViewToggleClass(isList: true)" @onclick="() => mIsListView = true">리스트</button>
                <button type="button" class="@ViewToggleClass(isList: false)" @onclick="() => mIsListView = false">카드</button>
            </div>
            <button type="button" class="@Css.Dashboard.SecondaryButton">초대코드 일괄 발송</button>
            <button type="button" class="@Css.Dashboard.PrimaryButton">＋ 선수 추가</button>
        </div>
    </div>

    @* 연령 탭 *@
    @if (HasAgeTabs)
    {
        <div class="flex gap-2">
            @foreach (SoccerAgeGroup age in AgeTabs)
            {
                SoccerAgeGroup tab = age;
                <button type="button" class="@(mAgeTab == tab ? Css.Dashboard.FilterChipOn : Css.Dashboard.FilterChipOff)"
                        @onclick="() => mAgeTab = tab">@tab (@CountOf(tab))</button>
            }
        </div>
    }

    @if (mIsListView)
    {
        @* 리스트 뷰 *@
        <div class="@($"{Css.Dashboard.Card} overflow-hidden")">
            <div class="@($"{RowGrid} bg-surface-soft border-b border-border text-xs font-extrabold text-text-muted")">
                <span>번호</span><span>이름</span><span>포지션</span><span>학년</span><span>연결 상태</span><span></span>
            </div>
            @foreach (TeamRosterPlayerDto player in VisiblePlayers)
            {
                <div class="@($"{RowGrid} border-b border-surface-icon items-center")">
                    <span class="w-8 h-8 rounded-full bg-surface-icon flex items-center justify-center text-[13px] font-extrabold text-navy">@(player.JerseyNumber ?? "-")</span>
                    <a href="#" class="text-[14.5px] font-bold text-navy-deep hover:text-orange transition-colors">@player.Name</a>
                    <span class="text-[13.5px] text-text-body">@(player.Position ?? "-")</span>
                    <span class="text-[13.5px] text-text-body">@(player.Grade ?? "-")</span>
                    <ClaimBadge Status="@ClaimOf(player)" />
                    <span class="flex items-center justify-end">@ActionArea(player)</span>
                </div>
            }
        </div>
    }
    else
    {
        @* 카드 뷰 *@
        <div class="grid grid-cols-[repeat(auto-fill,minmax(210px,1fr))] gap-3.5">
            @foreach (TeamRosterPlayerDto player in VisiblePlayers)
            {
                <div class="@($"{Css.Dashboard.Card} px-3.5 pt-3.5 pb-5 flex flex-col items-center gap-3 text-center")">
                    <div class="w-full aspect-[4/3] rounded-[11px] overflow-hidden relative bg-surface-icon">
                        @if (player.PhotoUrl is not null)
                        {
                            <img src="@player.PhotoUrl" alt="@player.Name" class="absolute inset-0 w-full h-full object-cover" />
                        }
                        else
                        {
                            <span class="absolute inset-0 flex items-center justify-center text-xs text-text-faint">선수 사진</span>
                        }
                        <span class="absolute top-2 left-2 w-[30px] h-[30px] rounded-full bg-navy-deep/85 flex items-center justify-center text-[13px] font-extrabold text-white pointer-events-none">@(player.JerseyNumber ?? "-")</span>
                    </div>
                    <span class="flex flex-col gap-[3px]">
                        <a href="#" class="text-[15.5px] font-extrabold text-navy-deep hover:text-orange transition-colors">@player.Name</a>
                        <span class="text-[12.5px] text-text-body whitespace-nowrap">@(player.Position ?? "-") · @(player.Grade ?? "-")</span>
                    </span>
                    <ClaimBadge Status="@ClaimOf(player)" />
                    @ActionArea(player)
                </div>
            }
        </div>
    }

    @* Unclaimed 안내 *@
    @if (HasUnclaimed)
    {
        <div class="flex gap-2.5 items-start bg-surface-orange border border-dashed border-orange rounded-xl px-4 py-[13px]">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" class="shrink-0 mt-0.5 text-orange-ink"><circle cx="12" cy="12" r="9"></circle><path d="M12 11v5M12 8v.1"></path></svg>
            <span class="text-[13px] text-text-strong leading-[1.6] break-keep">Unclaimed 선수는 아직 가족이 연결되지 않은 프로필이에요. <b>초대코드를 보내면</b> 학부모·선수가 직접 기록을 관리하고 알림을 받게 됩니다.</span>
        </div>
    }
</div>

@code {
    private const string RowGrid = "grid grid-cols-[56px_1.4fr_.8fr_.8fr_1fr_110px] gap-3 px-5 py-[13px]";

    [Parameter]
    public List<TeamRosterPlayerDto> Players { get; set; } = new();

    private SoccerAgeGroup? mAgeTab;
    private bool mIsListView = true;

    // 연령 탭은 전원이 AgeGroup을 가질 때만 (혼합·전부 null이면 탭 없이 전체 표시)
    private bool HasAgeTabs => Players.Count > 0 && Players.All(p => AgeOf(p) is not null);

    private List<SoccerAgeGroup> AgeTabs =>
        Players
        .Select(AgeOf)
        .OfType<SoccerAgeGroup>()
        .Distinct()
        .OrderBy(age => age)
        .ToList();

    private IEnumerable<TeamRosterPlayerDto> VisiblePlayers =>
        HasAgeTabs && mAgeTab is not null ? Players.Where(p => AgeOf(p) == mAgeTab) : Players;

    private bool HasUnclaimed => Players.Any(p => ClaimOf(p) == SoccerClaimStatus.Unclaimed);

    protected override void OnParametersSet()
    {
        if (HasAgeTabs && (mAgeTab is null || !AgeTabs.Contains(mAgeTab.Value)))
        {
            mAgeTab = AgeTabs[0];
        }
    }

    private static SoccerAgeGroup? AgeOf(TeamRosterPlayerDto player) =>
        SoccerAgeGroupExtensions.ParseAgeGroupOrNull(player.AgeGroup);

    private static SoccerClaimStatus ClaimOf(TeamRosterPlayerDto player) =>
        SoccerClaimStatusExtensions.ParseClaimStatus(player.ClaimStatus);

    private int CountOf(SoccerAgeGroup tab) => Players.Count(p => AgeOf(p) == tab);

    private Guid? mOpenCodePlayerId;
    private string? mCopiedCode;

    private static string ActionLabel(SoccerClaimStatus status) => status switch
    {
        SoccerClaimStatus.Claimed => "프로필 보기",
        SoccerClaimStatus.Pending => "승인 대기",
        _ => "초대코드 보내기",
    };

    // 액션 영역: Unclaimed + 유효 코드 보유 → 클릭 시 코드 노출 + 복사. 그 외는 기존 라벨.
    private RenderFragment ActionArea(TeamRosterPlayerDto player) => __builder =>
    {
        if (ClaimOf(player) == SoccerClaimStatus.Unclaimed && player.InviteCode is not null)
        {
            if (mOpenCodePlayerId == player.TeamPlayerId)
            {
                <span class="flex items-center gap-1.5 whitespace-nowrap">
                    <span class="text-xs font-extrabold tracking-[.08em] text-navy-deep bg-surface-icon rounded-md px-2 py-[3px]">@player.InviteCode</span>
                    <button type="button" class="text-xs font-bold text-navy hover:text-orange bg-transparent border-0 cursor-pointer p-0 transition-colors"
                            @onclick="() => CopyCodeAsync(player.InviteCode)">@(mCopiedCode == player.InviteCode ? "복사됨" : "복사")</button>
                </span>
            }
            else
            {
                <button type="button" class="text-[12.5px] font-bold text-navy hover:text-orange bg-transparent border-0 cursor-pointer p-0 whitespace-nowrap transition-colors"
                        @onclick="() => mOpenCodePlayerId = player.TeamPlayerId">초대코드 보내기</button>
            }
        }
        else
        {
            <span class="text-[12.5px] font-bold text-navy whitespace-nowrap">@ActionLabel(ClaimOf(player))</span>
        }
    };

    private async Task CopyCodeAsync(string code)
    {
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", code);
        mCopiedCode = code;
    }

    private string ViewToggleClass(bool isList) =>
        "px-4 text-[13px] font-bold transition-colors " +
        (mIsListView == isList ? "bg-navy text-white" : "bg-white text-text-body");
}
