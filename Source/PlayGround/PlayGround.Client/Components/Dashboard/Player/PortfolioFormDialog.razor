@* 포트폴리오 영상 입력 (신규·수정 겸용) — PC 중앙 모달 / 모바일 전체 시트.
   영상은 업로드가 아니라 유튜브 링크 등록이다 — 붙여넣는 즉시 썸네일로 확인시켜 준다
   (링크 해석은 Domain의 YouTubeVideoLink — 서버가 저장할 때 쓰는 규칙과 같아야 미리보기가 어긋나지 않는다).
   촬영일은 연·월 자동 포맷 — 캘린더를 쓰지 않는다(Design.DatePicker 3분법). *@
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Player
@using PlayGround.Domain.Soccer
@inject PlayerClient Players
@inject ToastService Toasts

@if (IsOpen)
{
    <div class="@Css.MatchForm.Overlay">
        <div class="fixed inset-0" @onclick="CancelAsync"></div>

        <div class="@Css.MatchForm.Card">
            <span class="@Css.MatchForm.GrabBar"></span>

            <div class="@Css.MatchForm.Header">
                <h2 class="@Css.MatchForm.Title">@(IsEdit ? "영상 수정" : "영상 추가")</h2>
                <button type="button" aria-label="닫기" class="@Css.MatchForm.CloseButton" @onclick="CancelAsync">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
                         stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg>
                </button>
            </div>

            <CascadingValue Value="@mForm" IsFixed="true">
                <div class="@Css.MatchForm.Body">
                    <TextField Label="유튜브 링크" @bind-Value="mVideoUrl" Validator="ValidateUrl"
                               Placeholder="https://youtu.be/..." InputType="url"
                               Helper="유튜브 링크만 등록할 수 있어요. 영상 파일을 올리는 방식이 아니에요." />

                    @* 붙여넣기 성공 여부를 문구가 아니라 그림으로 확인시킨다 *@
                    @if (ThumbnailUrl is not null)
                    {
                        <div class="@PreviewFrameClass">
                            <img src="@ThumbnailUrl" alt="영상 미리보기" class="w-full h-full object-cover" />
                            <span class="@PreviewPlayClass">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M8 5.5v13l11-6.5z"></path>
                                </svg>
                            </span>
                        </div>
                    }

                    <TextField Label="제목" @bind-Value="mTitle" Validator="ValidateTitle"
                               Placeholder="전반 12분 왼발 감아차기" MaxLength="60" />

                    <TextField Label="태그" @bind-Value="mTagText" IsOptional="true"
                               Placeholder="왼발 마무리, 드리블 돌파" MaxLength="80"
                               Helper="쉼표로 구분해요. 최대 5개까지 칩으로 보여요." />

                    <TextField Label="촬영 시점" @bind-Value="mRecordedText" IsOptional="true"
                               Validator="ValidateRecorded" Format="FormInputFormat.YearMonth" Placeholder="2025. 04" />

                    @if (CanChoosePrimary)
                    {
                        <CheckboxField Label="대표 영상으로 지정" @bind-Value="mIsPrimary"
                                       Helper="공개 프로필과 선수 카드의 첫 화면에 이 영상이 나와요. 대표는 하나뿐이라 기존 대표는 해제돼요." />
                    }
                    else
                    {
                        <div class="@FirstVideoNoticeClass" role="note">
                            첫 영상이라 자동으로 대표 영상이 돼요.
                        </div>
                    }
                </div>

                <div class="@Css.MatchForm.Footer">
                    <button type="button" class="@Css.MatchForm.CancelButton" @onclick="CancelAsync">취소</button>
                    <SubmitButton Label="저장" BusyLabel="저장 중…" IsBusy="@mSaving" OnClick="SubmitAsync"
                                  Class="@Css.MatchForm.SubmitWidth" />
                </div>
            </CascadingValue>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    /// <summary>수정 대상 — null이면 신규 등록.</summary>
    [Parameter]
    public PlayerPortfolioVideoDto? Entry { get; set; }

    /// <summary>이미 등록된 영상 수 — 첫 영상이면 대표 선택을 묻지 않는다(자동 지정).</summary>
    [Parameter]
    public int ExistingVideoCount { get; set; }

    [Parameter]
    public EventCallback OnSaved { get; set; }

    private readonly FormFieldContext mForm = new();

    private string? mVideoUrl;
    private string? mTitle;
    private string? mTagText;
    private string? mRecordedText;
    private bool mIsPrimary;
    private bool mSaving;
    private bool mLoaded;

    private bool IsEdit => Entry is not null;

    /// <summary>대표 선택지는 다른 영상이 있을 때만 의미가 있다.</summary>
    private bool CanChoosePrimary => IsEdit ? ExistingVideoCount > 1 : ExistingVideoCount > 0;

    /// <summary>입력 중인 링크에서 파생 — 서버도 같은 규칙으로 저장한다.</summary>
    private string? ThumbnailUrl => YouTubeVideoLink.ToThumbnailUrl(mVideoUrl);

    protected override void OnParametersSet()
    {
        if (!IsOpen)
        {
            mLoaded = false;
            return;
        }

        if (mLoaded)
        {
            return;
        }

        mLoaded = true;
        mVideoUrl = Entry?.VideoUrl;
        mTitle = Entry?.Title;
        mTagText = Entry is null ? null : string.Join(", ", Entry.Tags.Select(t => t.TrimStart('#')));
        mRecordedText = Entry?.RecordedOn is null ? null : $"{Entry.RecordedOn.Value.Year}. {Entry.RecordedOn.Value.Month:00}";
        mIsPrimary = Entry?.IsPrimary ?? false;
    }

    private static DateOnly? ParseYearMonth(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return null;
        }

        string digits = new(text.Where(char.IsAsciiDigit).ToArray());
        if (digits.Length != 6)
        {
            return null;
        }

        int month = int.Parse(digits[4..]);
        return month is < 1 or > 12 ? null : new DateOnly(int.Parse(digits[..4]), month, 1);
    }

    private static string? ValidateUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "유튜브 링크를 붙여넣어 주세요.";
        }

        return YouTubeVideoLink.IsValid(value) ? null : "유튜브 영상 링크가 아니에요. 주소를 다시 확인해 주세요.";
    }

    private static string? ValidateTitle(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "제목을 입력해 주세요." : null;

    // 선택 항목 — 비어 있으면 통과, 값이 있으면 형태를 본다
    private static string? ValidateRecorded(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return ParseYearMonth(value) is null ? "연·월 6자리로 입력해 주세요. (예: 2025. 04)" : null;
    }

    private async Task SubmitAsync()
    {
        if (!await mForm.ValidateAllAsync())
        {
            return;
        }

        var request = new SavePlayerPortfolioVideoRequest
        {
            VideoId = Entry?.VideoId ?? Guid.Empty,
            Title = mTitle!.Trim(),
            VideoUrl = mVideoUrl!.Trim(),
            Tags = ParseTags(mTagText),
            RecordedOn = ParseYearMonth(mRecordedText),
            IsPrimary = CanChoosePrimary ? mIsPrimary : true
        };

        mSaving = true;
        PlayerEntrySaveResult result = await Players.SavePortfolioVideoAsync(request);
        mSaving = false;

        if (!result.Success)
        {
            if (result.IsNetworkError)
            {
                Toasts.ShowError(result.Error ?? "저장하지 못했어요.", "재시도", SubmitAsync);
            }
            else
            {
                Toasts.ShowError(result.Error ?? "저장하지 못했어요.");
            }

            return;
        }

        Toasts.ShowSuccess(IsEdit ? "영상을 수정했어요." : "영상을 등록했어요.");
        await CloseAsync();
        await OnSaved.InvokeAsync();
    }

    // "왼발 마무리, 드리블" → ["#왼발 마무리", "#드리블"] — 화면은 # 붙은 칩으로 그린다
    private static List<string> ParseTags(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return new List<string>();
        }

        return text
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(tag => tag.StartsWith('#') ? tag : "#" + tag)
            .Distinct()
            .ToList();
    }

    private Task CancelAsync() => CloseAsync();

    private async Task CloseAsync()
    {
        mLoaded = false;
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }

    private const string PreviewFrameClass =
        "relative w-full aspect-video rounded-xl overflow-hidden bg-navy-deep";

    private const string PreviewPlayClass =
        "absolute inset-0 m-auto w-11 h-11 rounded-full bg-white/90 text-navy-deep " +
        "flex items-center justify-center pointer-events-none";

    private const string FirstVideoNoticeClass =
        "rounded-xl bg-surface-soft border border-border px-3.5 py-3 " +
        "text-[12px] text-text-body leading-[1.6] break-keep";
}
