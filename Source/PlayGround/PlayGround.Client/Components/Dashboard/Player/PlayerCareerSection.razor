@* 커리어 섹션(PC): 타임라인(도트 현재=teal/과거=회색) + 검증 뱃지("팀 확인됨"/"본인 입력" 우측) — SPEC.PLAYERDASHBOARD.md §2
   이력 없으면 타임라인 카드를 렌더하지 않는다 (빈 데이터 노출 금지) *@
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Player

<div class="flex flex-col gap-[18px]">
    <div class="flex justify-between items-center">
        <h1 class="@Css.Dashboard.SectionTitle">커리어</h1>
        <button type="button" class="@Css.Dashboard.PrimaryButton">＋ 이력 추가</button>
    </div>

    @if (Entries.Count > 0)
    {
        <div class="@($"{Css.Dashboard.Card} p-[26px] flex flex-col")">
            @foreach (PlayerCareerEntryDto entry in Entries)
            {
                <div class="flex gap-[18px] py-4 border-b border-surface-icon">
                    <span class="flex flex-col items-center shrink-0 w-5">
                        <span class="@($"w-3 h-3 rounded-full shrink-0 mt-1 {(entry.IsCurrent ? "bg-teal" : "bg-border")}")"></span>
                        <span class="w-0.5 flex-1 bg-border mt-1"></span>
                    </span>
                    <span class="flex flex-col gap-1 flex-1 min-w-0 pb-1">
                        <span class="flex items-center gap-[9px] flex-wrap">
                            <span class="text-[15px] font-extrabold text-navy-deep whitespace-nowrap">@entry.TeamName</span>
                            @if (entry.IsCurrent)
                            {
                                <span class="text-[10.5px] font-bold text-teal-ink bg-teal/[.12] rounded-full px-[9px] py-0.5 whitespace-nowrap">현재 소속</span>
                            }
                            @if (entry.BadgeLabel is not null)
                            {
                                <span class="text-[10.5px] font-bold text-orange-ink bg-surface-orange border border-orange/40 rounded-full px-[9px] py-0.5 whitespace-nowrap">@entry.BadgeLabel</span>
                            }
                        </span>
                        <span class="text-[12.5px] text-text-body whitespace-nowrap">@MetaLine(entry)</span>
                        @if (entry.Note is not null)
                        {
                            <span class="text-[12.5px] text-text-body leading-[1.6] break-keep">@entry.Note</span>
                        }
                    </span>
                    <span class="@VerifyClass(entry.IsVerified)">@(entry.IsVerified ? "팀 확인됨" : "본인 입력")</span>
                </div>
            }
            <span class="text-xs text-text-muted pt-3.5 break-keep">팀 소속 이력은 팀 관리자가 확인하면 "팀 확인됨"으로 표시돼요. 확인된 이력은 공개 프로필에서 신뢰 표시와 함께 노출됩니다.</span>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public List<PlayerCareerEntryDto> Entries { get; set; } = new();

    // "2024.3 ~ 현재 · U15 · FW · 주전" — 기간 + 역할(있으면)
    internal static string MetaLine(PlayerCareerEntryDto entry)
    {
        string period = $"{FormatMonth(entry.StartDate)} ~ {(entry.EndDate is null ? "현재" : FormatMonth(entry.EndDate.Value))}";
        return entry.Role is null ? period : $"{period} · {entry.Role}";
    }

    private static string FormatMonth(DateOnly date)
    {
        return $"{date.Year}.{date.Month}";
    }

    internal static string VerifyClass(bool verified) =>
        "text-[11px] font-bold rounded-full px-[11px] py-1 whitespace-nowrap self-start " +
        (verified ? "text-teal-ink bg-teal/[.12]" : "text-text-muted bg-surface-icon");
}
