@* 시즌 통계(모바일): 시즌 pill + 요약 2카드 + 경기별 2줄 카드(스탯 뱃지, 기록 없으면 "기록 없음") — SPEC §3
   출전 기록 없으면 안내 카드 *@
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Player
@using PlayGround.Contracts.Team

<div class="flex flex-col gap-3">
    <div class="flex justify-between items-center">
        <h1 class="m-0 text-[19px] font-extrabold text-navy-deep">시즌 통계</h1>
        @if (Stats.SeasonYears.Count > 0)
        {
            <div class="flex gap-[7px]">
                @foreach (int season in Stats.SeasonYears)
                {
                    int tab = season;
                    <button type="button" class="@PillClass(tab)" @onclick="() => OnSeasonSelected.InvokeAsync(tab)">@tab 시즌</button>
                }
            </div>
        }
    </div>

    @if (Stats.Matches.Count == 0)
    {
        @* 자동 집계 섹션 — CTA 없이 입력 부담 제거 문구(카탈로그 인스턴스 6) *@
        <EmptyState Kind="EmptyState.Art.Record" Title="아직 경기 기록이 없어요">
            <Description>첫 경기 결과가 반영되면 자동으로 채워져요. 따로 입력할 필요 없어요.</Description>
        </EmptyState>
    }
    else
    {
        <div class="grid grid-cols-2 gap-2.5">
            <div class="bg-gradient-navy rounded-[13px] px-4 py-3.5 flex flex-col gap-0.5 text-white">
                <span class="text-[11px] font-bold text-white/60">출전 (공식)</span>
                <span class="text-[17px] font-extrabold whitespace-nowrap">@(OfficialMatches.Count)경기@(TotalMinutes > 0 ? $" · {TotalMinutes}'" : "")</span>
            </div>
            <div class="@($"{Css.Dashboard.Card} rounded-[13px] px-4 py-3.5 flex flex-col gap-0.5")">
                <span class="text-[11px] font-bold text-text-muted">득점 · 도움 (공식)</span>
                <span class="text-[17px] font-extrabold text-navy-deep whitespace-nowrap">@(TotalGoals)골 · @(TotalAssists)도움</span>
                @if (FriendlyGoals + FriendlyAssists > 0)
                {
                    <span class="text-[10.5px] font-bold @Css.FriendlyMatch.SupplementValue">친선경기 별도 +@(FriendlyGoals)골 · +@(FriendlyAssists)도움</span>
                }
            </div>
        </div>

        <div class="@($"{Css.Dashboard.Card} rounded-[15px] overflow-hidden")">
            <div class="px-4 py-3.5 border-b border-surface-icon flex items-center gap-2 flex-wrap">
                <h3 class="m-0 text-sm font-extrabold text-navy-deep">경기별 기록</h3>
                <span class="@Css.Badge.Positive">자동 집계</span>
            </div>
            @foreach (PlayerMatchStatDto match in Stats.Matches)
            {
                bool isFriendly = SoccerMatchTypeExtensions.IsFriendly(match.MatchType);
                <div class="@($"flex flex-col gap-[7px] px-4 py-[13px] border-b border-surface-icon {(isFriendly ? "bg-surface-friendly" : "")}")">
                    <div class="flex items-center gap-2">
                        @if (isFriendly)
                        {
                            <span class="@Css.FriendlyMatch.Label">친선경기</span>
                        }
                        else
                        {
                            <span class="@PlayerStatsSection.CompClass(PlayerStatsSection.CompetitionOf(match).ToLabel())">@PlayerStatsSection.CompetitionOf(match).ToLabel()</span>
                        }
                        <span class="text-[11px] text-text-muted whitespace-nowrap">@PlayerStatsSection.DateLabel(match)</span>
                        <div class="flex-1"></div>
                        @if (match.MinutesPlayed is not null)
                        {
                            <span class="text-[11.5px] text-text-body whitespace-nowrap">출전 @(match.MinutesPlayed)'</span>
                        }
                    </div>
                    <div class="flex items-center gap-2.5">
                        <span class="text-[13px] font-bold text-navy-deep flex-1 break-keep">@PlayerStatsSection.TitleLabel(match)</span>
                        <span class="text-xs font-extrabold text-navy-deep bg-surface-alt rounded-[7px] px-2.5 py-[3px] whitespace-nowrap">@StatLabel(match)</span>
                        @if (!isFriendly)
                        {
                            <OverflowMenu Target="@($"vs {match.OpponentName}")"
                                          Items="@BuildMatchMenu(match)" DisabledItems="@BuildMatchDisabled(match)" />
                        }
                    </div>
                </div>
            }
        </div>

        @* 내 신청 목록 — 신청이 시작된 자리 바로 아래 *@
        <CorrectionListSection Corrections="@Corrections" OnCancel="OnCancelCorrection" />
    }
</div>

@code {
    [Parameter, EditorRequired]
    public PlayerSeasonStatsResponse Stats { get; set; } = new();

    [Parameter]
    public EventCallback<int> OnSeasonSelected { get; set; }

    [Parameter]
    public EventCallback<PlayerMatchStatDto> OnRequestCorrection { get; set; }

    [Parameter]
    public HashSet<Guid> PendingCorrectionMatchIds { get; set; } = new();

    [Parameter]
    public List<RecordCorrectionDto> Corrections { get; set; } = new();

    [Parameter]
    public EventCallback<RecordCorrectionDto> OnCancelCorrection { get; set; }

    private List<OverflowMenu.MenuItem> BuildMatchMenu(PlayerMatchStatDto match) =>
        PendingCorrectionMatchIds.Contains(match.MatchId)
            ? new List<OverflowMenu.MenuItem>()
            : new List<OverflowMenu.MenuItem> { new("기록 수정 신청", () => OnRequestCorrection.InvokeAsync(match)) };

    private List<string> BuildMatchDisabled(PlayerMatchStatDto match) =>
        PendingCorrectionMatchIds.Contains(match.MatchId)
            ? new List<string> { "신청 처리 중" }
            : new List<string>();

    // 집계는 공식만 — PC 섹션과 같은 규칙
    private List<PlayerMatchStatDto> OfficialMatches => PlayerStatsSection.OfficialOf(Stats.Matches);

    private int TotalGoals => OfficialMatches.Sum(m => m.Goals);
    private int TotalAssists => OfficialMatches.Sum(m => m.Assists);
    private int TotalMinutes => OfficialMatches.Sum(m => m.MinutesPlayed ?? 0);

    private int FriendlyGoals => PlayerStatsSection.FriendlyOf(Stats.Matches).Sum(m => m.Goals);
    private int FriendlyAssists => PlayerStatsSection.FriendlyOf(Stats.Matches).Sum(m => m.Assists);

    private static string StatLabel(PlayerMatchStatDto match)
    {
        List<string> parts = new();
        if (match.Goals > 0)
        {
            parts.Add($"{match.Goals}골");
        }

        if (match.Assists > 0)
        {
            parts.Add($"{match.Assists}도움");
        }

        return parts.Count > 0 ? string.Join(" · ", parts) : "기록 없음";
    }

    private string PillClass(int tab) =>
        "h-[34px] px-[13px] rounded-full text-xs font-bold border-1.5 whitespace-nowrap cursor-pointer transition-colors " +
        (Stats.SeasonYear == tab ? "border-navy bg-navy text-white" : "border-border bg-white text-text-body");
}
