@* 모바일 상단 바: 이니셜 아바타(teal) + 이름 + 요약·보호자 관리 모드 + 공개 프로필·알림 아이콘 — sticky
   공개 선수 프로필 페이지 구현 전이라 링크는 무동작 버튼 *@

<header class="sticky top-0 z-40 bg-navy-deep px-4 py-3 flex items-center gap-[11px]">
    <span class="w-9 h-9 rounded-full bg-teal flex items-center justify-center text-sm font-extrabold text-white shrink-0">@PlayerInitial</span>
    <span class="flex flex-col gap-px min-w-0 flex-1">
        <span class="text-[15px] font-extrabold text-white whitespace-nowrap overflow-hidden text-ellipsis">@PlayerName</span>
        <span class="text-[11px] font-bold text-teal whitespace-nowrap">@Summary · 보호자 관리 모드</span>
    </span>
    <button type="button" aria-label="공개 프로필" class="w-9 h-9 rounded-[10px] bg-white/[.08] flex items-center justify-center text-white/85 border-0 cursor-pointer">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><path d="M15 3h6v6M10 14L21 3"></path></svg>
    </button>
    <span class="w-9 h-9 rounded-[10px] bg-white/[.08] flex items-center justify-center relative">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-white/85"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.7 21a2 2 0 0 1-3.4 0"></path></svg>
        <span class="absolute top-1.5 right-1.5 w-[7px] h-[7px] rounded-full bg-orange"></span>
    </span>
</header>

@code {
    [Parameter, EditorRequired]
    public string PlayerName { get; set; } = string.Empty;

    /// <summary>요약 라인 앞부분 (예: "U15 · FW · #9").</summary>
    [Parameter, EditorRequired]
    public string Summary { get; set; } = string.Empty;

    private string PlayerInitial => PlayerName.Length > 1 ? PlayerName[1..2] : PlayerName;
}
