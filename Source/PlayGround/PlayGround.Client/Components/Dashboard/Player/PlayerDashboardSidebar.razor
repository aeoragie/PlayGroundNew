@* 사이드바 230px: 선수 요약(이니셜·이름·요약 라인) + 메뉴 4 + P1 예정(비활성) + 하단 소속팀 연결 안내 *@
@using PlayGround.Client.Styles

<aside class="w-[230px] shrink-0 bg-bg border-r border-border px-3.5 py-5 flex flex-col gap-1">
    <div class="flex items-center gap-[11px] px-2.5 pt-1.5 pb-4">
        @* 개인은 teal 고정 (Design.AvatarBadge — 기존 네이비는 유형 색 규칙 위반이라 교정) *@
        <Avatar Name="@PlayerInitial" Size="44" Class="shrink-0" />
        <span class="flex flex-col gap-0.5 min-w-0">
            <span class="text-[14.5px] font-extrabold text-navy-deep whitespace-nowrap">@PlayerName</span>
            <span class="text-[11px] font-bold text-text-body whitespace-nowrap">@Summary</span>
        </span>
    </div>

    @foreach (SoccerPlayerDashboardSection section in Enum.GetValues<SoccerPlayerDashboardSection>())
    {
        <a href="@Routes.PlayerDashboardSection(section)" class="@NavClass(section)">
            @MenuIcon(section)@section.ToLabel()
        </a>
    }

    <div class="text-[10.5px] font-extrabold text-text-faint tracking-[.08em] px-2.5 pt-4 pb-1.5">P1 예정</div>
    <span class="@DisabledClass">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19c2-6 5-9 8-9s6 3 8 9"></path><path d="M12 10V4M9 6l3-2 3 2"></path></svg>성장 지표
    </span>
    <span class="@DisabledClass">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><circle cx="12" cy="12" r="4.5"></circle><path d="M12 10.5v1.5l1 1"></path></svg>목표 · 일정
    </span>

    <div class="flex-1"></div>
    @if (TeamName is not null)
    {
        <div class="bg-surface-alt rounded-xl px-3.5 py-[13px] flex flex-col gap-1.5">
            <span class="text-[11.5px] font-extrabold text-text-strong">소속팀 연결됨</span>
            <span class="text-[11px] text-text-body leading-[1.5] break-keep">@TeamName · 경기 기록이 자동으로 쌓여요</span>
        </div>
    }
</aside>

@code {
    [Parameter, EditorRequired]
    public SoccerPlayerDashboardSection ActiveSection { get; set; }

    [Parameter, EditorRequired]
    public string PlayerName { get; set; } = string.Empty;

    /// <summary>선수 요약 라인 (예: "U15 · FW · #9 · FC 한강").</summary>
    [Parameter, EditorRequired]
    public string Summary { get; set; } = string.Empty;

    /// <summary>소속팀 이름 — null이면 소속팀 안내 박스를 렌더하지 않는다.</summary>
    [Parameter]
    public string? TeamName { get; set; }

    private string PlayerInitial => PlayerName.Length > 1 ? PlayerName[1..2] : PlayerName;

    private string NavClass(SoccerPlayerDashboardSection section) =>
        "flex items-center gap-2.5 px-2.5 py-[9px] rounded-[10px] text-[13.5px] font-bold whitespace-nowrap transition-colors " +
        (ActiveSection == section ? "bg-navy text-white" : "text-text-strong hover:bg-surface-alt");

    private const string DisabledClass =
        "flex items-center gap-2.5 px-2.5 py-[9px] text-[13.5px] font-bold text-text-faint opacity-55 whitespace-nowrap";

    private static RenderFragment MenuIcon(SoccerPlayerDashboardSection section) => section switch
    {
        SoccerPlayerDashboardSection.Career =>
            @<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v16M12 8l4-2M12 14l-4-2"></path><circle cx="18" cy="5" r="2"></circle><circle cx="6" cy="11" r="2"></circle><circle cx="12" cy="20" r="2"></circle></svg>,
        SoccerPlayerDashboardSection.Stats =>
            @<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 20V11M12 20V4M19 20v-6"></path></svg>,
        SoccerPlayerDashboardSection.Portfolio =>
            @<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14.5" rx="3"></rect><path d="M10 9.5l5 3-5 3z"></path></svg>,
        _ =>
            @<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.5"></circle><path d="M5 20c0-3.5 3-5.8 7-5.8s7 2.3 7 5.8"></path></svg>,
    };
}
