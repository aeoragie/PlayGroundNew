@* 프로필 섹션(PC): [기본 카드+공개 설정 | 우측 340px(가족 계정)] — SPEC.PLAYERDASHBOARD.md §1
   공개 프로필 카드(URL·방문 통계)는 공개 선수 프로필 구현 전이라 미노출 (빈 데이터 노출 금지).
   공개 토글은 관리 주체 계정으로만 저장된다 (서버가 UserId로 소유 선수 해석). *@
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Player
@inject PlayerClient Players

<div class="flex flex-col gap-[18px]">
    <div class="flex justify-between items-center">
        <h1 class="@Css.Dashboard.SectionTitle">프로필</h1>
        <button type="button" class="@Css.Dashboard.PrimaryButton">프로필 수정</button>
    </div>

    <div class="grid grid-cols-[1fr_340px] gap-[18px] items-start">
        <div class="@($"{Css.Dashboard.Card} p-[26px] flex flex-col gap-5")">
            <div class="flex gap-5 items-start">
                <div class="w-[120px] aspect-[3/4] rounded-[14px] overflow-hidden bg-surface-icon shrink-0">
                    @if (Info.Profile.PhotoUrl is not null)
                    {
                        <img src="@Info.Profile.PhotoUrl" alt="프로필 사진" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <span class="w-full h-full flex items-center justify-center text-xs text-text-faint">프로필 사진</span>
                    }
                </div>
                <div class="flex flex-col gap-2.5 flex-1">
                    <div class="flex items-center gap-2.5 flex-wrap">
                        <span class="text-[21px] font-extrabold text-navy-deep whitespace-nowrap">@Info.Profile.Name</span>
                        @if (HasLinkedFamily)
                        {
                            <span class="@Css.Dashboard.BadgeTeal">가족 연결됨</span>
                        }
                    </div>
                    <div class="grid grid-cols-[repeat(auto-fit,minmax(130px,1fr))] gap-2.5">
                        @if (PositionText is not null)
                        {
                            <span class="flex flex-col gap-0.5"><span class="text-[11px] font-bold text-text-muted">포지션</span><span class="text-sm font-extrabold text-navy-deep whitespace-nowrap">@PositionText</span></span>
                        }
                        @if (BirthText is not null)
                        {
                            <span class="flex flex-col gap-0.5"><span class="text-[11px] font-bold text-text-muted">생년</span><span class="text-sm font-extrabold text-navy-deep whitespace-nowrap">@BirthText</span></span>
                        }
                        @if (Info.Profile.TeamName is not null)
                        {
                            <span class="flex flex-col gap-0.5"><span class="text-[11px] font-bold text-text-muted">소속</span><span class="text-sm font-extrabold text-navy-deep whitespace-nowrap">@Info.Profile.TeamName</span></span>
                        }
                    </div>
                </div>
            </div>
            @if (FieldRows.Count > 0)
            {
                <div class="border-t border-surface-icon pt-4 flex flex-col gap-2.5">
                    <div class="flex items-center gap-2">
                        <span class="text-sm font-extrabold text-navy-deep">항목별 공개 설정</span>
                        <span class="text-[11.5px] text-text-muted break-keep">보호자만 변경할 수 있어요</span>
                    </div>
                    @foreach (FieldRow row in FieldRows)
                    {
                        <div class="flex items-center gap-3 border border-border rounded-[11px] px-[15px] py-[11px]">
                            <span class="text-[13px] font-bold text-navy-deep w-[110px] shrink-0 whitespace-nowrap">@row.Label</span>
                            <span class="text-[13px] text-text-body flex-1 whitespace-nowrap">@row.Value</span>
                            <button type="button" class="@ToggleClass(row.Visibility.IsPublic)"
                                    @onclick="() => ToggleAsync(row.Visibility)">@(row.Visibility.IsPublic ? "공개" : "비공개")</button>
                        </div>
                    }
                </div>
            }
        </div>

        @if (Info.Family.Count > 0)
        {
            <div class="@($"{Css.Dashboard.Card} p-[22px] flex flex-col gap-3")">
                <span class="text-sm font-extrabold text-navy-deep">가족 계정</span>
                @foreach (PlayerFamilyMemberDto member in Info.Family)
                {
                    <div class="flex items-center gap-[11px]">
                        <span class="w-[38px] h-[38px] rounded-full bg-surface-icon flex items-center justify-center text-[13px] font-extrabold text-navy shrink-0">@(member.MemberName[..1])</span>
                        <span class="flex flex-col gap-px flex-1 min-w-0">
                            <span class="text-[13px] font-extrabold text-navy-deep whitespace-nowrap">@member.MemberName (@RoleSuffix(member))</span>
                            <span class="text-[11.5px] text-text-muted whitespace-nowrap">@RoleDescription(member)</span>
                        </span>
                        @if (IsGuardian(member))
                        {
                            <span class="text-[10.5px] font-bold text-teal-ink bg-teal/[.12] rounded-full px-2.5 py-[3px] whitespace-nowrap">관리자</span>
                        }
                        else
                        {
                            <span class="text-[10.5px] font-bold text-text-muted bg-surface-icon rounded-full px-2.5 py-[3px] whitespace-nowrap">열람</span>
                        }
                    </div>
                }
                <button type="button" class="@Css.Dashboard.DashedButton">＋ 가족 초대</button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public PlayerInfoResponse Info { get; set; } = new();

    internal sealed record FieldRow(string Label, string Value, PlayerFieldVisibilityDto Visibility);

    private bool HasLinkedFamily => Info.Family.Any(m => m.HasAccount);

    private string? PositionText => Compose(Info.Profile.Position,
        Info.Profile.JerseyNumber is not null ? $"등번호 {Info.Profile.JerseyNumber}" : null);

    private string? BirthText => Compose(Info.Profile.BirthYear?.ToString(), Info.Profile.Grade);

    private List<FieldRow> FieldRows => BuildFieldRows(Info);

    // 값이 없는 항목은 행 자체를 렌더하지 않는다 (빈 데이터 노출 금지). 모바일 섹션과 공유.
    internal static List<FieldRow> BuildFieldRows(PlayerInfoResponse info)
    {
        List<FieldRow> rows = new();
        foreach (PlayerFieldVisibilityDto visibility in info.Visibilities)
        {
            (string Label, string? Value) field = visibility.FieldName switch
            {
                "Height" => ("키", info.Profile.HeightCm is not null ? $"{info.Profile.HeightCm}cm" : null),
                "Weight" => ("몸무게", info.Profile.WeightKg is not null ? $"{info.Profile.WeightKg}kg" : null),
                "PreferredFoot" => ("주발", SoccerPreferredFootExtensions.ParseLabelOrNull(info.Profile.PreferredFoot)),
                "School" => ("학교", info.Profile.SchoolName),
                "GuardianPhone" => ("보호자 연락처", info.Profile.GuardianPhoneMasked),
                _ => (visibility.FieldName, null),
            };

            if (field.Value is not null)
            {
                rows.Add(new FieldRow(field.Label, field.Value, visibility));
            }
        }

        return rows;
    }

    // 성공 시에만 공유 DTO를 갱신 (PC·모바일 트리가 같은 인스턴스를 참조 — 상태 일관 유지)
    private async Task ToggleAsync(PlayerFieldVisibilityDto visibility)
    {
        bool next = !visibility.IsPublic;
        if (await Players.SetFieldVisibilityAsync(visibility.FieldName, next))
        {
            visibility.IsPublic = next;
        }
    }

    internal static bool IsGuardian(PlayerFamilyMemberDto member) => member.Role == "Guardian";

    internal static string RoleSuffix(PlayerFamilyMemberDto member) => IsGuardian(member) ? "보호자" : "본인";

    internal static string RoleDescription(PlayerFamilyMemberDto member) =>
        IsGuardian(member) ? "프로필 관리 · 공개 설정 권한" : "만 14세 이상 시 관리 권한 이전 가능";

    private static string? Compose(string? first, string? second)
    {
        string[] parts = new[] { first, second }.Where(p => p is not null).Cast<string>().ToArray();
        return parts.Length > 0 ? string.Join(" · ", parts) : null;
    }

    internal static string ToggleClass(bool isPublic) =>
        "h-[30px] px-3.5 rounded-full text-[11.5px] font-bold whitespace-nowrap border-1.5 cursor-pointer transition-colors " +
        (isPublic ? "border-teal/40 bg-teal/[.12] text-teal-ink" : "border-border bg-surface-soft text-text-muted");
}
