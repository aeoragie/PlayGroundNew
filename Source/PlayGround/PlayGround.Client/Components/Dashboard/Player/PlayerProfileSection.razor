@* 프로필 섹션(PC): [기본 카드+공개 설정 | 우측 340px(가족 계정)] — SPEC.PLAYERDASHBOARD.md §1
   공개 프로필 카드(URL·방문 통계)는 공개 선수 프로필 구현 전이라 미노출 (빈 데이터 노출 금지).
   공개 토글은 관리 주체 계정으로만 저장된다 (서버가 UserId로 소유 선수 해석). *@
@using PlayGround.Client.Styles
@using PlayGround.Client.Services.Feedback
@using PlayGround.Contracts.Player
@using PlayGround.Domain.Soccer
@inject PlayerClient Players
@inject ToastService Toasts
@inject ConfirmService Confirm

<div class="flex flex-col gap-[18px]">
    <div class="flex justify-between items-center">
        <h1 class="@Css.Dashboard.SectionTitle">프로필</h1>
        <button type="button" class="@Css.Dashboard.PrimaryButton">프로필 수정</button>
    </div>

    <div class="grid grid-cols-[1fr_340px] gap-[18px] items-start">
        <div class="@($"{Css.Dashboard.Card} p-[26px] flex flex-col gap-5")">
            <div class="flex gap-5 items-start">
                @* 사진 업로드는 보호자만 — 권한이 없으면 버튼을 비활성이 아니라 아예 렌더하지 않는다 *@
                @if (Info.Profile.CanEditPhoto)
                {
                    <AvatarUploader Value="@Info.Profile.PhotoUrl" ValueChanged="SavePhotoAsync"
                                    Shape="AvatarUploader.CropShape.Portrait" FrameClass="w-[120px] aspect-[3/4]"
                                    Placeholder="@Info.Profile.Name" InitialSize="56"
                                    Label="선수 사진" Category="player-photo" ConfirmDelete="ConfirmPhotoDeleteAsync" />
                }
                else
                {
                    <div class="w-[120px] aspect-[3/4] rounded-[14px] overflow-hidden bg-surface-icon shrink-0">
                        @if (Info.Profile.PhotoUrl is not null)
                        {
                            <img src="@Info.Profile.PhotoUrl" alt="@Info.Profile.Name" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <span class="w-full h-full flex items-center justify-center">
                                <Avatar Name="@Info.Profile.Name" Size="56" />
                            </span>
                        }
                    </div>
                }
                <div class="flex flex-col gap-2.5 flex-1">
                    <div class="flex items-center gap-2.5 flex-wrap">
                        <span class="text-[21px] font-extrabold text-navy-deep whitespace-nowrap">@Info.Profile.Name</span>
                        @if (HasLinkedFamily)
                        {
                            <span class="@Css.Dashboard.BadgeTeal">가족 연결됨</span>
                        }
                    </div>
                    <div class="grid grid-cols-[repeat(auto-fit,minmax(130px,1fr))] gap-2.5">
                        @if (PositionText is not null)
                        {
                            <span class="flex flex-col gap-0.5"><span class="text-[11px] font-bold text-text-muted">포지션</span><span class="text-sm font-extrabold text-navy-deep whitespace-nowrap">@PositionText</span></span>
                        }
                        @if (BirthText is not null)
                        {
                            <span class="flex flex-col gap-0.5"><span class="text-[11px] font-bold text-text-muted">생년</span><span class="text-sm font-extrabold text-navy-deep whitespace-nowrap">@BirthText</span></span>
                        }
                        @if (Info.Profile.TeamName is not null)
                        {
                            <span class="flex flex-col gap-0.5"><span class="text-[11px] font-bold text-text-muted">소속</span><span class="text-sm font-extrabold text-navy-deep whitespace-nowrap">@Info.Profile.TeamName</span></span>
                        }
                    </div>
                </div>
            </div>
            @if (FieldRows.Count > 0)
            {
                @* 계층 스위치 (Design.ToggleSwitch) — 상위 "프로필 공개"를 끄면 하위 항목이 비활성+dimmed *@
                <div class="border-t border-surface-icon pt-4 flex flex-col gap-1">
                    <div class="flex items-center gap-2">
                        <span class="text-sm font-extrabold text-navy-deep">항목별 공개 설정</span>
                        <span class="text-[11.5px] text-text-muted break-keep">보호자만 변경할 수 있어요</span>
                    </div>
                    @if (ProfileVisibility is PlayerFieldVisibilityDto profile)
                    {
                        <Switch Label="프로필 공개" Description="끄면 검색·팀 선수단에서 숨겨져요"
                                Value="@profile.IsPublic" ValueChanged="@(v => ApplyVisibility(profile, v))"
                                Save="@(v => SaveVisibilityAsync(profile, v))"
                                ErrorMessage="공개 설정을 저장하지 못했어요." />
                    }
                    <div class="@SubGroupClass">
                        @foreach (FieldRow row in FieldRows)
                        {
                            <Switch Label="@row.Label" Description="@row.Value" Disabled="@(!ProfileIsPublic)"
                                    Value="@row.Visibility.IsPublic" ValueChanged="@(v => ApplyVisibility(row.Visibility, v))"
                                    Save="@(v => SaveVisibilityAsync(row.Visibility, v))"
                                    ErrorMessage="공개 설정을 저장하지 못했어요." />
                        }
                    </div>
                </div>
            }
        </div>

        <div class="flex flex-col gap-[18px]">
        @if (Info.Profile.TeamName is null)
        {
            <PlayerClaimCard OnClaimed="OnClaimed" />
        }
        @if (Info.Family.Count > 0)
        {
            <div class="@($"{Css.Dashboard.Card} p-[22px] flex flex-col gap-3")">
                <span class="text-sm font-extrabold text-navy-deep">가족 계정</span>
                @foreach (PlayerFamilyMemberDto member in Info.Family)
                {
                    <div class="flex items-center gap-[11px]">
                        @* 가족 구성원 = 개인 teal (Design.AvatarBadge — 기존 회색 원은 유형 색 규칙 위반이라 교정) *@
                        <Avatar Name="@member.MemberName" Size="32" Class="shrink-0" />
                        <span class="flex flex-col gap-px flex-1 min-w-0">
                            <span class="text-[13px] font-extrabold text-navy-deep whitespace-nowrap">@member.MemberName (@RoleSuffix(member))</span>
                            <span class="text-[11.5px] text-text-muted whitespace-nowrap">@RoleDescription(member)</span>
                        </span>
                        @if (IsGuardian(member))
                        {
                            <span class="@Css.Badge.Positive">관리자</span>
                        }
                        else
                        {
                            <span class="@Css.Badge.Neutral">열람</span>
                        }
                    </div>
                }
                <button type="button" class="@Css.Dashboard.DashedButton">＋ 가족 초대</button>
            </div>
        }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public PlayerInfoResponse Info { get; set; } = new();

    /// <summary>어느 자녀의 프로필인지 — 공개 설정 저장이 이 자녀에게 가야 한다.</summary>
    [Parameter]
    public Guid? PlayerId { get; set; }

    /// <summary>초대코드 Claim 성공 시 상위(페이지)로 전달 — 프로필 재로드.</summary>
    [Parameter]
    public EventCallback OnClaimed { get; set; }

    internal sealed record FieldRow(string Label, string Value, PlayerFieldVisibilityDto Visibility);

    private bool HasLinkedFamily => Info.Family.Any(m => m.HasAccount);

    private string? PositionText => Compose(Info.Profile.Position,
        Info.Profile.JerseyNumber is not null ? $"등번호 {Info.Profile.JerseyNumber}" : null);

    private string? BirthText => Compose(Info.Profile.BirthYear?.ToString(), Info.Profile.Grade);

    private List<FieldRow> FieldRows => BuildFieldRows(Info);

    private PlayerFieldVisibilityDto? ProfileVisibility =>
        Info.Visibilities.FirstOrDefault(v => v.FieldName == nameof(SoccerPlayerProfileField.Profile));

    private bool ProfileIsPublic => ProfileVisibility?.IsPublic ?? true;

    private string SubGroupClass =>
        Css.Toggle.SubGroup + (ProfileIsPublic ? string.Empty : $" {Css.Toggle.SubGroupDimmed}");

    // 값이 없는 항목은 행 자체를 렌더하지 않는다 (빈 데이터 노출 금지). 모바일 섹션과 공유.
    internal static List<FieldRow> BuildFieldRows(PlayerInfoResponse info)
    {
        List<FieldRow> rows = new();
        foreach (PlayerFieldVisibilityDto visibility in info.Visibilities)
        {
            (string Label, string? Value) field = visibility.FieldName switch
            {
                "Height" => ("키", info.Profile.HeightCm is not null ? $"{info.Profile.HeightCm}cm" : null),
                "Weight" => ("몸무게", info.Profile.WeightKg is not null ? $"{info.Profile.WeightKg}kg" : null),
                "PreferredFoot" => ("주발", SoccerPreferredFootExtensions.ParseLabelOrNull(info.Profile.PreferredFoot)),
                "School" => ("학교", info.Profile.SchoolName),
                "GuardianPhone" => ("보호자 연락처", info.Profile.GuardianPhoneMasked),
                _ => (visibility.FieldName, null),
            };

            if (field.Value is not null)
            {
                rows.Add(new FieldRow(field.Label, field.Value, visibility));
            }
        }

        return rows;
    }

    // 스위치 Save 콜백 — 실패 롤백·오류 토스트는 Switch가 처리한다
    private async Task<bool> SaveVisibilityAsync(PlayerFieldVisibilityDto visibility, bool value)
    {
        return await Players.SetFieldVisibilityAsync(visibility.FieldName, value, PlayerId);
    }

    // 저장 확정값을 공유 DTO에 반영 (PC·모바일 트리가 같은 인스턴스를 참조 — 상태 일관 유지)
    private void ApplyVisibility(PlayerFieldVisibilityDto visibility, bool value)
    {
        visibility.IsPublic = value;

        // 상위를 끄면 효과가 다른 화면(공개 홈 선수단)에 있어 여기서는 안 보인다 — 실행취소 토스트로 알린다
        if (visibility.FieldName == nameof(SoccerPlayerProfileField.Profile) && !value)
        {
            Toasts.ShowSuccess("프로필을 비공개로 바꿨어요.", "실행취소", () => RestoreProfileAsync(visibility));
        }
    }

    private async Task RestoreProfileAsync(PlayerFieldVisibilityDto visibility)
    {
        if (await Players.SetFieldVisibilityAsync(visibility.FieldName, true, PlayerId))
        {
            visibility.IsPublic = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        Toasts.ShowError("공개 설정을 저장하지 못했어요.");
    }

    private Task SavePhotoAsync(string? photoUrl) => SavePhotoAsync(Players, Toasts, Info, photoUrl);

    private Task<bool> ConfirmPhotoDeleteAsync() => ConfirmPhotoDeleteAsync(Confirm, Info.Profile.Name);

    /// <summary>사진 저장·삭제는 즉시 반영된다(폼이 없다) — 성공 시에만 공유 DTO를 갱신한다.
    /// PC·모바일이 같은 Info 인스턴스를 참조하므로 한쪽에서 바꾸면 양쪽이 맞는다.</summary>
    internal static async Task SavePhotoAsync(PlayerClient players, ToastService toasts,
        PlayerInfoResponse info, string? photoUrl)
    {
        if (await players.SetPlayerPhotoAsync(info.Profile.PlayerId, photoUrl))
        {
            info.Profile.PhotoUrl = photoUrl;
            toasts.ShowSuccess(photoUrl is null ? "사진을 삭제했어요." : "사진을 저장했어요.");
            return;
        }

        // 업로드 실패는 업로더가 인라인으로 알린다 — 여기는 "저장" 단계 실패다
        toasts.ShowError("사진을 저장하지 못했어요.", "재시도", () => SavePhotoAsync(players, toasts, info, photoUrl));
    }

    /// <summary>삭제는 즉시 서버에 반영되므로 사전 확인을 건다 (Design.FeedbackPatterns — 대상 이름 명시).</summary>
    internal static Task<bool> ConfirmPhotoDeleteAsync(ConfirmService confirm, string playerName)
    {
        return confirm.ShowAsync(new ConfirmRequest
        {
            Kind = ConfirmKind.Destructive,
            Title = $"{playerName} 선수의 사진을 삭제할까요?",
            Description = "삭제하면 이니셜 아바타로 돌아가요. 되돌릴 수 없어요.",
            ConfirmLabel = "삭제",
        });
    }

    internal static bool IsGuardian(PlayerFamilyMemberDto member) => member.Role == "Guardian";

    internal static string RoleSuffix(PlayerFamilyMemberDto member) => IsGuardian(member) ? "보호자" : "본인";

    internal static string RoleDescription(PlayerFamilyMemberDto member) =>
        IsGuardian(member) ? "프로필 관리 · 공개 설정 권한" : "만 14세 이상 시 관리 권한 이전 가능";

    private static string? Compose(string? first, string? second)
    {
        string[] parts = new[] { first, second }.Where(p => p is not null).Cast<string>().ToArray();
        return parts.Length > 0 ? string.Join(" · ", parts) : null;
    }
}
