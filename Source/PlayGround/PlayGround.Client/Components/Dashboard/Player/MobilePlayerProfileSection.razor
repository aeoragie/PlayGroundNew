@* 프로필(모바일): 세로 스택 — 기본 카드(사진+수정 버튼) → 공개 프로필 → 항목별 공개 설정 → 가족 계정
   데이터는 백엔드 연동 전 레퍼런스 예시. 공개 토글 쓰기는 보호자 role 가드(연동 시) *@
@using PlayGround.Client.Styles

<div class="flex flex-col gap-3.5">
    <div class="@($"{Css.Dashboard.Card} p-[18px] flex flex-col gap-4")">
        <div class="flex gap-3.5">
            <div class="w-[92px] aspect-[3/4] rounded-xl overflow-hidden bg-surface-icon shrink-0">
                @if (PhotoUrl is not null)
                {
                    <img src="@PhotoUrl" alt="프로필 사진" class="w-full h-full object-cover" />
                }
                else
                {
                    <span class="w-full h-full flex items-center justify-center text-xs text-text-faint">프로필 사진</span>
                }
            </div>
            <div class="flex flex-col gap-2 flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-lg font-extrabold text-navy-deep whitespace-nowrap">김민준</span>
                    <span class="text-[10.5px] font-bold text-teal-ink bg-teal/[.12] border border-teal/[.35] rounded-full px-[9px] py-0.5 whitespace-nowrap">가족 연결됨</span>
                </div>
                <div class="flex flex-col gap-[5px]">
                    <span class="text-[12.5px] text-text-body whitespace-nowrap">FW · 등번호 9 · 2012 · 중2</span>
                    <span class="text-[12.5px] text-text-body whitespace-nowrap">FC 한강 유나이티드</span>
                </div>
                <button type="button" class="mt-auto h-[38px] rounded-[9px] bg-orange hover:bg-orange-hover text-[12.5px] font-bold text-white whitespace-nowrap shadow-cta-orange-sm border-0 cursor-pointer transition-colors">프로필 수정</button>
            </div>
        </div>
    </div>

    <div class="bg-gradient-navy rounded-[16px] p-[18px] flex flex-col gap-2 text-white">
        <span class="text-xs font-extrabold text-teal">공개 프로필</span>
        <span class="text-[13px] font-bold whitespace-nowrap overflow-hidden text-ellipsis">playground.kr/player/kim-minjun</span>
        <span class="text-[11.5px] text-white/65 leading-[1.55] break-keep">이번 주 방문 34회 · 에이전트 열람 요청 1건</span>
        <div class="flex gap-2 mt-1">
            <button type="button" class="flex-1 flex items-center justify-center h-10 rounded-[9px] bg-white text-[12.5px] font-bold text-navy-deep whitespace-nowrap border-0 cursor-pointer">공개 뷰 보기</button>
            <button type="button" class="flex-1 flex items-center justify-center h-10 rounded-[9px] bg-white/[.12] border border-white/25 text-[12.5px] font-bold text-white whitespace-nowrap cursor-pointer">선수 카드 공유</button>
        </div>
    </div>

    <div class="@($"{Css.Dashboard.Card} p-[18px] flex flex-col gap-[11px]")">
        <div class="flex flex-col gap-0.5">
            <span class="text-[15px] font-extrabold text-navy-deep">항목별 공개 설정</span>
            <span class="text-[11.5px] text-text-muted break-keep">보호자만 변경할 수 있어요</span>
        </div>
        @foreach (VisibilityField field in mFields)
        {
            <div class="flex items-center gap-2.5 border border-border rounded-[11px] px-3.5 py-[11px]">
                <span class="flex flex-col gap-px flex-1 min-w-0">
                    <span class="text-[12.5px] font-bold text-navy-deep whitespace-nowrap">@field.Label</span>
                    <span class="text-xs text-text-muted whitespace-nowrap">@field.Value</span>
                </span>
                <button type="button" class="@ToggleClass(field.IsPublic)" @onclick="() => field.IsPublic = !field.IsPublic">@(field.IsPublic ? "공개" : "비공개")</button>
            </div>
        }
    </div>

    <div class="@($"{Css.Dashboard.Card} p-[18px] flex flex-col gap-3")">
        <span class="text-[15px] font-extrabold text-navy-deep">가족 계정</span>
        <div class="flex items-center gap-[11px]">
            <span class="w-9 h-9 rounded-full bg-surface-icon flex items-center justify-center text-[13px] font-extrabold text-navy shrink-0">김</span>
            <span class="flex flex-col gap-px flex-1 min-w-0">
                <span class="text-[12.5px] font-extrabold text-navy-deep whitespace-nowrap">김OO (보호자)</span>
                <span class="text-[11px] text-text-muted whitespace-nowrap">프로필 관리 · 공개 설정 권한</span>
            </span>
            <span class="text-[10px] font-bold text-teal-ink bg-teal/[.12] rounded-full px-[9px] py-[3px] whitespace-nowrap">관리자</span>
        </div>
        <div class="flex items-center gap-[11px]">
            <span class="w-9 h-9 rounded-full bg-surface-icon flex items-center justify-center text-[13px] font-extrabold text-navy shrink-0">민</span>
            <span class="flex flex-col gap-px flex-1 min-w-0">
                <span class="text-[12.5px] font-extrabold text-navy-deep whitespace-nowrap">김민준 (본인)</span>
                <span class="text-[11px] text-text-muted break-keep">만 14세 이상 시 관리 권한 이전 가능</span>
            </span>
            <span class="text-[10px] font-bold text-text-muted bg-surface-icon rounded-full px-[9px] py-[3px] whitespace-nowrap">열람</span>
        </div>
        <button type="button" class="@Css.Dashboard.DashedButton">＋ 가족 초대</button>
    </div>
</div>

@code {
    private const string PhotoUrl = "https://images.pexels.com/photos/31855946/pexels-photo-31855946.jpeg?auto=compress&cs=tinysrgb&w=600";

    private sealed class VisibilityField
    {
        public required string Label { get; init; }
        public required string Value { get; init; }
        public bool IsPublic { get; set; }
    }

    // 기본값: 키·몸무게·주발 공개, 학교·연락처 비공개 (SPEC §1)
    private readonly List<VisibilityField> mFields = new()
    {
        new() { Label = "키", Value = "168cm", IsPublic = true },
        new() { Label = "몸무게", Value = "54kg", IsPublic = true },
        new() { Label = "주발", Value = "왼발", IsPublic = true },
        new() { Label = "학교", Value = "강동중학교", IsPublic = false },
        new() { Label = "보호자 연락처", Value = "010-****-1234", IsPublic = false },
    };

    private static string ToggleClass(bool isPublic) =>
        "h-[30px] px-[13px] rounded-full text-[11px] font-bold whitespace-nowrap shrink-0 border-1.5 cursor-pointer transition-colors " +
        (isPublic ? "border-teal/40 bg-teal/[.12] text-teal-ink" : "border-border bg-surface-soft text-text-muted");
}
