@* 프로필(모바일): 세로 스택 — 기본 카드(사진+수정 버튼) → 항목별 공개 설정 → 가족 계정 — SPEC §1
   공개 프로필 카드(URL·방문 통계)는 공개 선수 프로필 구현 전이라 미노출 (빈 데이터 노출 금지) *@
@using PlayGround.Client.Styles
@using PlayGround.Client.Services.Feedback
@using PlayGround.Contracts.Player
@using PlayGround.Domain.Soccer
@inject PlayerClient Players
@inject ToastService Toasts
@inject ConfirmService Confirm

<div class="flex flex-col gap-3.5">
    <div class="@($"{Css.Dashboard.Card} p-[18px] flex flex-col gap-4")">
        <div class="flex gap-3.5">
            @* 사진 업로드는 보호자만 — 권한이 없으면 버튼을 렌더하지 않는다 *@
            @if (Info.Profile.CanEditPhoto)
            {
                <AvatarUploader Value="@Info.Profile.PhotoUrl" ValueChanged="SavePhotoAsync"
                                Shape="AvatarUploader.CropShape.Portrait" FrameClass="w-[92px] aspect-[3/4]"
                                Placeholder="@Info.Profile.Name" InitialSize="44"
                                Label="선수 사진" Category="player-photo" ConfirmDelete="ConfirmPhotoDeleteAsync" />
            }
            else
            {
                <div class="w-[92px] aspect-[3/4] rounded-xl overflow-hidden bg-surface-icon shrink-0">
                    @if (Info.Profile.PhotoUrl is not null)
                    {
                        <img src="@Info.Profile.PhotoUrl" alt="@Info.Profile.Name" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <span class="w-full h-full flex items-center justify-center">
                            <InitialAvatar Name="@Info.Profile.Name" Size="44" />
                        </span>
                    }
                </div>
            }
            <div class="flex flex-col gap-2 flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-lg font-extrabold text-navy-deep whitespace-nowrap">@Info.Profile.Name</span>
                    @if (Info.Family.Any(m => m.HasAccount))
                    {
                        <span class="text-[10.5px] font-bold text-teal-ink bg-teal/[.12] border border-teal/[.35] rounded-full px-[9px] py-0.5 whitespace-nowrap">가족 연결됨</span>
                    }
                </div>
                <div class="flex flex-col gap-[5px]">
                    @if (SummaryLine is not null)
                    {
                        <span class="text-[12.5px] text-text-body whitespace-nowrap">@SummaryLine</span>
                    }
                    @if (Info.Profile.TeamName is not null)
                    {
                        <span class="text-[12.5px] text-text-body whitespace-nowrap">@Info.Profile.TeamName</span>
                    }
                </div>
                <button type="button" class="mt-auto h-[38px] rounded-[9px] bg-orange hover:bg-orange-hover text-[12.5px] font-bold text-white whitespace-nowrap shadow-cta-orange-sm border-0 cursor-pointer transition-colors">프로필 수정</button>
            </div>
        </div>
    </div>

    @if (Info.Profile.TeamName is null)
    {
        <PlayerClaimCard OnClaimed="OnClaimed" />
    }

    @if (FieldRows.Count > 0)
    {
        @* 계층 스위치 (Design.ToggleSwitch) — 상위 "프로필 공개"를 끄면 하위 항목이 비활성+dimmed *@
        <div class="@($"{Css.Dashboard.Card} p-[18px] flex flex-col gap-1")">
            <div class="flex flex-col gap-0.5">
                <span class="text-[15px] font-extrabold text-navy-deep">항목별 공개 설정</span>
                <span class="text-[11.5px] text-text-muted break-keep">보호자만 변경할 수 있어요</span>
            </div>
            @if (ProfileVisibility is PlayerFieldVisibilityDto profile)
            {
                <Switch Label="프로필 공개" Description="끄면 검색·팀 선수단에서 숨겨져요"
                        Value="@profile.IsPublic" ValueChanged="@(v => ApplyVisibility(profile, v))"
                        Save="@(v => SaveVisibilityAsync(profile, v))"
                        ErrorMessage="공개 설정을 저장하지 못했어요." />
            }
            <div class="@SubGroupClass">
                @foreach (PlayerProfileSection.FieldRow row in FieldRows)
                {
                    <Switch Label="@row.Label" Description="@row.Value" Disabled="@(!ProfileIsPublic)"
                            Value="@row.Visibility.IsPublic" ValueChanged="@(v => ApplyVisibility(row.Visibility, v))"
                            Save="@(v => SaveVisibilityAsync(row.Visibility, v))"
                            ErrorMessage="공개 설정을 저장하지 못했어요." />
                }
            </div>
        </div>
    }

    @if (Info.Family.Count > 0)
    {
        <div class="@($"{Css.Dashboard.Card} p-[18px] flex flex-col gap-3")">
            <span class="text-[15px] font-extrabold text-navy-deep">가족 계정</span>
            @foreach (PlayerFamilyMemberDto member in Info.Family)
            {
                <div class="flex items-center gap-[11px]">
                    <span class="w-9 h-9 rounded-full bg-surface-icon flex items-center justify-center text-[13px] font-extrabold text-navy shrink-0">@(member.MemberName[..1])</span>
                    <span class="flex flex-col gap-px flex-1 min-w-0">
                        <span class="text-[12.5px] font-extrabold text-navy-deep whitespace-nowrap">@member.MemberName (@PlayerProfileSection.RoleSuffix(member))</span>
                        <span class="text-[11px] text-text-muted break-keep">@PlayerProfileSection.RoleDescription(member)</span>
                    </span>
                    @if (PlayerProfileSection.IsGuardian(member))
                    {
                        <span class="text-[10px] font-bold text-teal-ink bg-teal/[.12] rounded-full px-[9px] py-[3px] whitespace-nowrap">관리자</span>
                    }
                    else
                    {
                        <span class="text-[10px] font-bold text-text-muted bg-surface-icon rounded-full px-[9px] py-[3px] whitespace-nowrap">열람</span>
                    }
                </div>
            }
            <button type="button" class="@Css.Dashboard.DashedButton">＋ 가족 초대</button>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public PlayerInfoResponse Info { get; set; } = new();

    /// <summary>어느 자녀의 프로필인지.</summary>
    [Parameter]
    public Guid? PlayerId { get; set; }

    /// <summary>초대코드 Claim 성공 시 상위(페이지)로 전달 — 프로필 재로드.</summary>
    [Parameter]
    public EventCallback OnClaimed { get; set; }

    private List<PlayerProfileSection.FieldRow> FieldRows => PlayerProfileSection.BuildFieldRows(Info);

    // 저장·확인 로직은 PC 섹션과 공유 (같은 Info 인스턴스를 갱신한다)
    private Task SavePhotoAsync(string? photoUrl) => PlayerProfileSection.SavePhotoAsync(Players, Toasts, Info, photoUrl);

    private Task<bool> ConfirmPhotoDeleteAsync() => PlayerProfileSection.ConfirmPhotoDeleteAsync(Confirm, Info.Profile.Name);

    // "FW · 등번호 9 · 2012 · 중2" — 있는 항목만 조합
    private string? SummaryLine
    {
        get
        {
            List<string> parts = new();
            if (Info.Profile.Position is not null)
            {
                parts.Add(Info.Profile.Position);
            }

            if (Info.Profile.JerseyNumber is not null)
            {
                parts.Add($"등번호 {Info.Profile.JerseyNumber}");
            }

            if (Info.Profile.BirthYear is not null)
            {
                parts.Add(Info.Profile.BirthYear.ToString()!);
            }

            if (Info.Profile.Grade is not null)
            {
                parts.Add(Info.Profile.Grade);
            }

            return parts.Count > 0 ? string.Join(" · ", parts) : null;
        }
    }

    private PlayerFieldVisibilityDto? ProfileVisibility =>
        Info.Visibilities.FirstOrDefault(v => v.FieldName == nameof(SoccerPlayerProfileField.Profile));

    private bool ProfileIsPublic => ProfileVisibility?.IsPublic ?? true;

    private string SubGroupClass =>
        Css.Toggle.SubGroup + (ProfileIsPublic ? string.Empty : $" {Css.Toggle.SubGroupDimmed}");

    // 스위치 Save 콜백 — 실패 롤백·오류 토스트는 Switch가 처리한다
    private async Task<bool> SaveVisibilityAsync(PlayerFieldVisibilityDto visibility, bool value)
    {
        return await Players.SetFieldVisibilityAsync(visibility.FieldName, value, PlayerId);
    }

    // 저장 확정값을 공유 DTO에 반영 — 상위 끄기는 실행취소 토스트 (PC 섹션과 같은 규칙)
    private void ApplyVisibility(PlayerFieldVisibilityDto visibility, bool value)
    {
        visibility.IsPublic = value;

        if (visibility.FieldName == nameof(SoccerPlayerProfileField.Profile) && !value)
        {
            Toasts.ShowSuccess("프로필을 비공개로 바꿨어요.", "실행취소", () => RestoreProfileAsync(visibility));
        }
    }

    private async Task RestoreProfileAsync(PlayerFieldVisibilityDto visibility)
    {
        if (await Players.SetFieldVisibilityAsync(visibility.FieldName, true, PlayerId))
        {
            visibility.IsPublic = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        Toasts.ShowError("공개 설정을 저장하지 못했어요.");
    }
}
