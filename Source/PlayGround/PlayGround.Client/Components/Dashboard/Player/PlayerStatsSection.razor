@* 시즌 통계 섹션(PC): 시즌 pill + 요약 4카드 + 경기별 기록 6열 테이블 — SPEC.PLAYERDASHBOARD.md §3
   읽기전용(팀 경기 결과에서 자동 집계 — 직접 입력 UI 없음). 출전 기록 없으면 안내 카드 *@
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Player
@using PlayGround.Contracts.Team

<div class="flex flex-col gap-[18px]">
    <div class="flex justify-between items-center">
        <h1 class="@Css.Dashboard.SectionTitle">시즌 통계</h1>
        @if (Stats.SeasonYears.Count > 0)
        {
            <div class="flex gap-2">
                @foreach (int season in Stats.SeasonYears)
                {
                    int tab = season;
                    <button type="button" class="@(Stats.SeasonYear == tab ? Css.Dashboard.FilterChipOn : Css.Dashboard.FilterChipOff)"
                            @onclick="() => OnSeasonSelected.InvokeAsync(tab)">@tab 시즌</button>
                }
            </div>
        }
    </div>

    @if (Stats.Matches.Count == 0)
    {
        @* 빈 상태 Tier A — 자동 집계 섹션이라 CTA 없이 입력 부담 제거 문구(카탈로그 인스턴스 6) *@
        <EmptyState Kind="EmptyState.Art.Record" Title="아직 경기 기록이 없어요">
            <Description>첫 경기 결과가 반영되면 자동으로 채워져요. 따로 입력할 필요 없어요.</Description>
        </EmptyState>
    }
    else
    {
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3.5">
            <div class="bg-gradient-navy rounded-[14px] px-[22px] py-5 flex flex-col gap-[3px] text-white">
                <span class="text-xs font-bold text-white/60">출전 (공식)</span>
                <span class="text-[23px] font-extrabold whitespace-nowrap">@(OfficialMatches.Count)경기 @if (TotalMinutes > 0)
                    {<span class="text-[13px] font-bold text-white/60">@(TotalMinutes)'</span>}</span>
            </div>
            <div class="@($"{Css.Dashboard.Card} rounded-[14px] px-[22px] py-5 flex flex-col gap-[3px]")">
                <span class="text-xs font-bold text-text-muted">시즌 득점 (공식)</span>
                <span class="text-[23px] font-extrabold text-navy-deep">@TotalGoals</span>
                @if (FriendlyGoals > 0)
                {
                    <span class="text-[11.5px] font-bold @Css.FriendlyMatch.SupplementValue">친선경기 별도 +@FriendlyGoals</span>
                }
            </div>
            <div class="@($"{Css.Dashboard.Card} rounded-[14px] px-[22px] py-5 flex flex-col gap-[3px]")">
                <span class="text-xs font-bold text-text-muted">도움 (공식)</span>
                <span class="text-[23px] font-extrabold text-navy-deep">@TotalAssists</span>
                @if (FriendlyAssists > 0)
                {
                    <span class="text-[11.5px] font-bold @Css.FriendlyMatch.SupplementValue">친선경기 별도 +@FriendlyAssists</span>
                }
            </div>
            @if (AverageMinutes is not null)
            {
                <div class="@($"{Css.Dashboard.Card} rounded-[14px] px-[22px] py-5 flex flex-col gap-[3px]")">
                    <span class="text-xs font-bold text-text-muted">경기당 평균 출전</span>
                    <span class="text-[23px] font-extrabold text-navy-deep whitespace-nowrap">@(AverageMinutes)분</span>
                </div>
            }
        </div>

        <div class="@($"{Css.Dashboard.Card} overflow-hidden")">
            <div class="px-6 py-4 border-b border-surface-icon flex items-center gap-2.5">
                <h3 class="m-0 text-[15px] font-extrabold text-navy-deep">경기별 기록</h3>
                <span class="@Css.Badge.Positive">팀 경기 결과에서 자동 집계</span>
            </div>
            <div class="@($"{RowGrid} bg-surface-soft text-[11.5px] font-extrabold text-text-muted py-2.5")">
                <span>날짜</span><span>경기</span><span>대회</span><span class="text-center">득점</span><span class="text-center">도움</span><span class="text-center">출전</span><span></span>
            </div>
            @foreach (PlayerMatchStatDto match in Stats.Matches)
            {
                bool isFriendly = SoccerMatchTypeExtensions.IsFriendly(match.MatchType);
                <div class="@($"{RowGrid} items-center py-[13px] border-b border-surface-icon {(isFriendly ? "bg-surface-friendly" : "")}")">
                    <span class="text-[12.5px] text-text-muted whitespace-nowrap">@DateLabel(match)</span>
                    <span class="text-[13.5px] font-bold text-navy-deep break-keep">@TitleLabel(match)</span>
                    <span>
                        @if (isFriendly)
                        {
                            <span class="@Css.FriendlyMatch.Label">친선경기</span>
                        }
                        else
                        {
                            <span class="@CompClass(CompetitionOf(match).ToLabel())">@CompetitionOf(match).ToLabel()</span>
                        }
                    </span>
                    <span class="text-[13.5px] font-extrabold text-navy-deep text-center">@match.Goals</span>
                    <span class="text-[13.5px] font-extrabold text-navy-deep text-center">@match.Assists</span>
                    <span class="text-[12.5px] text-text-body text-center whitespace-nowrap">@(match.MinutesPlayed is null ? "-" : $"{match.MinutesPlayed}'")</span>
                    @* 기록 수정 신청은 공식 경기에만 — 친선은 직접 고칠 수 있어 신청이 필요 없다 *@
                    <span class="flex justify-end">
                        @if (!isFriendly)
                        {
                            <OverflowMenu Target="@($"vs {match.OpponentName}")"
                                          Items="@BuildMatchMenu(match)" DisabledItems="@BuildMatchDisabled(match)" />
                        }
                    </span>
                </div>
            }
        </div>

        @* 내 신청 목록 — 신청이 시작된 자리 바로 아래(B6 팀 대시보드와 같은 배치) *@
        <CorrectionListSection Corrections="@Corrections" OnCancel="OnCancelCorrection" />
    }
</div>

@code {
    private const string RowGrid = "grid grid-cols-[90px_1fr_110px_60px_60px_70px_44px] px-6";

    [Parameter, EditorRequired]
    public PlayerSeasonStatsResponse Stats { get; set; } = new();

    [Parameter]
    public EventCallback<int> OnSeasonSelected { get; set; }

    /// <summary>기록 수정 신청 — 페이지가 폼을 연다.</summary>
    [Parameter]
    public EventCallback<PlayerMatchStatDto> OnRequestCorrection { get; set; }

    /// <summary>내 미처리 신청이 있는 경기 — ⋯를 "신청 처리 중" 비활성으로 바꾼다(중복 신청 차단).</summary>
    [Parameter]
    public HashSet<Guid> PendingCorrectionMatchIds { get; set; } = new();

    /// <summary>이 자녀의 경기에 대한 내 신청 목록.</summary>
    [Parameter]
    public List<RecordCorrectionDto> Corrections { get; set; } = new();

    /// <summary>신청 취소 — 확인 모달·재조회는 페이지가 맡는다.</summary>
    [Parameter]
    public EventCallback<RecordCorrectionDto> OnCancelCorrection { get; set; }

    private List<OverflowMenu.MenuItem> BuildMatchMenu(PlayerMatchStatDto match)
    {
        if (PendingCorrectionMatchIds.Contains(match.MatchId))
        {
            return new List<OverflowMenu.MenuItem>();
        }

        return new List<OverflowMenu.MenuItem>
        {
            new("기록 수정 신청", () => OnRequestCorrection.InvokeAsync(match)),
        };
    }

    private List<string> BuildMatchDisabled(PlayerMatchStatDto match) =>
        PendingCorrectionMatchIds.Contains(match.MatchId)
            ? new List<string> { "신청 처리 중" }
            : new List<string>();

    // 집계는 공식 경기만 — 친선분은 합산하지 않고 "별도 +N"으로 보여 준다(Design.FriendlyMatch)
    internal List<PlayerMatchStatDto> OfficialMatches => OfficialOf(Stats.Matches);

    private int TotalGoals => OfficialMatches.Sum(m => m.Goals);
    private int TotalAssists => OfficialMatches.Sum(m => m.Assists);
    private int TotalMinutes => OfficialMatches.Sum(m => m.MinutesPlayed ?? 0);

    private int FriendlyGoals => FriendlyOf(Stats.Matches).Sum(m => m.Goals);
    private int FriendlyAssists => FriendlyOf(Stats.Matches).Sum(m => m.Assists);

    internal static List<PlayerMatchStatDto> OfficialOf(IEnumerable<PlayerMatchStatDto> matches) =>
        matches.Where(m => !SoccerMatchTypeExtensions.IsFriendly(m.MatchType)).ToList();

    internal static List<PlayerMatchStatDto> FriendlyOf(IEnumerable<PlayerMatchStatDto> matches) =>
        matches.Where(m => SoccerMatchTypeExtensions.IsFriendly(m.MatchType)).ToList();

    // 분이 기록된 경기 기준 평균 (전부 미상이면 카드 숨김) — 공식 경기만
    private int? AverageMinutes
    {
        get
        {
            List<int> minutes = OfficialMatches.Where(m => m.MinutesPlayed is not null).Select(m => m.MinutesPlayed!.Value).ToList();
            return minutes.Count == 0 ? null : (int)Math.Round(minutes.Average());
        }
    }

    //.// 표시 파생 — PC·모바일 공유

    internal static SoccerCompetitionType CompetitionOf(PlayerMatchStatDto match)
    {
        return Enum.TryParse(match.CompetitionType, out SoccerCompetitionType parsed) ? parsed : SoccerCompetitionType.Friendly;
    }

    internal static string DateLabel(PlayerMatchStatDto match)
    {
        return match.MatchedAt is null ? "-" : $"{match.MatchedAt.Value.Month}/{match.MatchedAt.Value.Day}";
    }

    // "vs 강동 SC (3:1 승)"
    internal static string TitleLabel(PlayerMatchStatDto match)
    {
        string outcome = match.TeamScore > match.OpponentScore ? "승" : match.TeamScore == match.OpponentScore ? "무" : "패";
        return $"vs {match.OpponentName} ({match.TeamScore}:{match.OpponentScore} {outcome})";
    }

    internal static string CompClass(string label) =>
        "text-[11px] font-bold rounded-full px-2.5 py-[3px] whitespace-nowrap " + label switch
        {
            "리그" => "text-navy bg-surface-icon",
            "컵" => "text-orange-ink bg-surface-orange-badge",
            _ => "text-teal-ink bg-teal/[.12]",
        };
}
