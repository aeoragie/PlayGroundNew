@* 코칭스태프 프로필 카드: 이니셜 아바타 + 이름·직책 + 경력 + KFA 뱃지 + 지도 철학 인용문 + 실적 칩 + SNS 링크 *@
@using PlayGround.Client.Styles

<div class="border border-border rounded-[14px] p-[22px] flex flex-col gap-3.5">
    <div class="flex items-center gap-3.5">
        <span class="w-[50px] h-[50px] rounded-full bg-navy-deep flex items-center justify-center text-lg font-extrabold text-white shrink-0">@(Name[..1])</span>
        <span class="flex flex-col gap-[3px] flex-1 min-w-0">
            <span class="text-base font-extrabold text-navy-deep whitespace-nowrap">@Name <span class="text-[13px] font-bold text-text-body">@Role</span></span>
            <span class="text-[12.5px] text-text-body whitespace-nowrap">@Career</span>
        </span>
        <span class="text-[11px] font-bold text-navy bg-surface-icon rounded-full px-2.5 py-[3px] whitespace-nowrap">@Certification</span>
    </div>
    <div class="border-l-[3px] border-l-teal pl-3.5 py-0.5 text-[13.5px] text-text-strong leading-[1.65] break-keep">@Quote</div>
    @if (Achievements.Length > 0)
    {
        <div class="flex gap-2 flex-wrap">
            @foreach (string chip in Achievements)
            {
                <span class="text-[11.5px] font-bold text-text-strong bg-surface-icon rounded-full px-[11px] py-1 whitespace-nowrap">@chip</span>
            }
        </div>
    }
    @if (InstagramUrl is not null || YoutubeUrl is not null || ShowEmptySnsPlaceholder)
    {
        <div class="flex gap-2">
            @if (InstagramUrl is not null)
            {
                <a href="@InstagramUrl" class="@SnsLinkClass"><BrandIcon Type="BrandIcon.BrandIconType.Instagram" />인스타그램</a>
            }
            else if (ShowEmptySnsPlaceholder)
            {
                <span class="@SnsEmptyClass">인스타그램 미등록</span>
            }
            @if (YoutubeUrl is not null)
            {
                <a href="@YoutubeUrl" class="@SnsLinkClass"><BrandIcon Type="BrandIcon.BrandIconType.YouTube" />유튜브 채널</a>
            }
            else if (ShowEmptySnsPlaceholder)
            {
                <span class="@SnsEmptyClass">유튜브 미등록</span>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string Name { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Role { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Career { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Certification { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Quote { get; set; } = string.Empty;

    [Parameter]
    public string[] Achievements { get; set; } = [];

    [Parameter]
    public string? InstagramUrl { get; set; }

    [Parameter]
    public string? YoutubeUrl { get; set; }

    /// <summary>SNS 미등록 표시 여부 — 관리자 대시보드는 true, 공개 홈페이지는 false(빈 데이터 노출 금지).</summary>
    [Parameter]
    public bool ShowEmptySnsPlaceholder { get; set; } = true;

    private const string SnsLinkClass =
        "flex items-center gap-[7px] h-[34px] px-[13px] border-1.5 border-border rounded-[9px] text-[12.5px] font-bold " +
        "text-text-strong hover:border-navy hover:text-navy transition-colors";

    private const string SnsEmptyClass =
        "flex items-center h-[34px] px-[13px] text-[12.5px] text-text-faint";
}
