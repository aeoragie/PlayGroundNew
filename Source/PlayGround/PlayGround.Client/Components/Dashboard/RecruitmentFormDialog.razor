@* 모집 공고 작성·수정 — PC 중앙 모달 / 모바일 전체 시트 (Css.MatchForm 골격 재사용).
   마감일은 미래만(FutureOnly — 아직 안 끝난 모집), 조건은 쉼표로 구분해 칩이 된다.
   저장 성공 = 토스트(A2), 검증 오류 = 인라인(폼 오류에 토스트 금지). *@
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Team
@inject TeamClient Teams
@inject ToastService Toasts

@if (IsOpen)
{
    <div class="@Css.MatchForm.Overlay">
        <div class="fixed inset-0" @onclick="CancelAsync"></div>

        <div class="@Css.MatchForm.Card">
            <span class="@Css.MatchForm.GrabBar"></span>

            <div class="@Css.MatchForm.Header">
                <span class="flex flex-col gap-1 min-w-0">
                    <h2 class="@Css.MatchForm.Title">@(IsEdit ? "모집 공고 수정" : "모집 공고 올리기")</h2>
                    <span class="@Css.MatchForm.Subtitle">저장하면 공개 홈페이지 모집 탭과 팀 탐색의 모집중 뱃지에 바로 반영돼요.</span>
                </span>
                <button type="button" aria-label="닫기" class="@Css.MatchForm.CloseButton" @onclick="CancelAsync">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
                         stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg>
                </button>
            </div>

            <CascadingValue Value="@mForm" IsFixed="true">
                <div class="@Css.MatchForm.Body">
                    <TextField Label="공고 제목" @bind-Value="mTitle" Placeholder="U15 공격수 모집"
                               Validator="ValidateTitle" MaxLength="100" />

                    <TextField Label="공고 내용" @bind-Value="mDescription" Multiline="true" Rows="4"
                               Placeholder="어떤 선수를 찾는지, 테스트·합류 방식은 어떻게 되는지 적어 주세요."
                               Validator="ValidateDescription" MaxLength="500" />

                    <TextField Label="조건 칩" @bind-Value="mConditions" IsOptional="true" MaxLength="130"
                               Placeholder="테스트 1회 · 주말, 9월 리그 등록 가능"
                               Validator="ValidateConditions"
                               Helper="쉼표(,)로 구분하면 칩으로 나뉘어요. 최대 4개." />

                    <div class="@Css.MatchForm.PickerField">
                        <label class="@Css.Form.Label">마감일<span class="@Css.Form.OptionalMark"> (선택)</span></label>
                        <Calendar @bind-Value="mDeadline" Range="Calendar.DateRange.FutureOnly" />
                        @if (mDeadline is not null)
                        {
                            <button type="button" class="self-start text-xs font-bold text-text-muted bg-transparent border-0 cursor-pointer p-0"
                                    @onclick="() => mDeadline = null">마감일 비우기</button>
                        }
                    </div>
                </div>

                <div class="@Css.MatchForm.Footer">
                    <button type="button" class="@Css.MatchForm.CancelButton" @onclick="CancelAsync">취소</button>
                    <SubmitButton Label="@(IsEdit ? "공고 저장" : "공고 올리기")" BusyLabel="저장 중…" IsBusy="@mSaving"
                                  OnClick="SubmitAsync" Class="@Css.MatchForm.SubmitWidth" />
                </div>
            </CascadingValue>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    /// <summary>수정 대상 — null이면 신규 작성.</summary>
    [Parameter]
    public TeamRecruitmentDto? Editing { get; set; }

    /// <summary>저장 성공 후 — 부모가 목록을 다시 불러온다.</summary>
    [Parameter]
    public EventCallback OnSaved { get; set; }

    private readonly FormFieldContext mForm = new();

    private string mTitle = string.Empty;
    private string mDescription = string.Empty;
    private string mConditions = string.Empty;
    private DateTime? mDeadline;
    private bool mSaving;
    private Guid mLoadedFor;

    private bool IsEdit => Editing is not null;

    protected override void OnParametersSet()
    {
        if (!IsOpen)
        {
            mLoadedFor = Guid.Empty;
            return;
        }

        // 열릴 때 1회 프리필 (수정) — 재렌더마다 입력을 덮어쓰지 않는다
        Guid target = Editing?.RecruitmentId ?? Guid.Empty;
        if (Editing is not null && mLoadedFor != target)
        {
            mLoadedFor = target;
            mTitle = Editing.Title;
            mDescription = Editing.Description;
            mConditions = string.Join(", ", Editing.Conditions);
            mDeadline = Editing.DeadlineDate;
        }
    }

    private static string? ValidateTitle(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "공고 제목을 입력해 주세요." : null;

    private static string? ValidateDescription(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "공고 내용을 입력해 주세요." : null;

    private static string? ValidateConditions(string? value)
    {
        List<string> parsed = ParseConditions(value);
        if (parsed.Count > 4)
        {
            return "조건은 4개까지만 적을 수 있어요.";
        }

        return parsed.Any(c => c.Length > 30) ? "조건 하나는 30자를 넘을 수 없어요." : null;
    }

    private static List<string> ParseConditions(string? value) =>
        (value ?? string.Empty).Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    private async Task SubmitAsync()
    {
        bool fieldsValid = await mForm.ValidateAllAsync();
        if (!fieldsValid)
        {
            return;
        }

        var request = new SaveTeamRecruitmentRequest
        {
            RecruitmentId = Editing?.RecruitmentId ?? Guid.Empty,
            Title = mTitle.Trim(),
            Description = mDescription.Trim(),
            Conditions = ParseConditions(mConditions),
            DeadlineDate = mDeadline,
        };

        mSaving = true;
        RecruitmentSaveResult result = await Teams.SaveRecruitmentAsync(request);
        mSaving = false;

        if (!result.Success)
        {
            if (result.IsNetworkError)
            {
                Toasts.ShowError(result.Error ?? "저장하지 못했어요.", "재시도", SubmitAsync);
            }
            else
            {
                Toasts.ShowError(result.Error ?? "저장하지 못했어요.");
            }

            return;
        }

        Toasts.ShowSuccess(IsEdit ? "공고를 저장했어요." : "공고를 올렸어요. 공개 홈페이지에서 확인할 수 있어요.");
        Reset();
        await IsOpenChanged.InvokeAsync(false);
        await OnSaved.InvokeAsync();
    }

    private async Task CancelAsync()
    {
        Reset();
        await IsOpenChanged.InvokeAsync(false);
    }

    private void Reset()
    {
        mTitle = string.Empty;
        mDescription = string.Empty;
        mConditions = string.Empty;
        mDeadline = null;
        mLoadedFor = Guid.Empty;
    }
}
