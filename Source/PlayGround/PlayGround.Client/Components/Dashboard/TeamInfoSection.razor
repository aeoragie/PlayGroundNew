@* 팀 정보 섹션: 기본+홈페이지 카드 / 핵심가치 / 코칭스태프 / 공식 채널 — SPEC.TEAMDASHBOARD.md §1
   데이터 없는 카드는 렌더하지 않는다 (빈 데이터 노출 금지) *@
@using PlayGround.Client.Models
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Team

<div class="flex flex-col gap-5">
    <div class="flex justify-between items-center">
        <h1 class="@Css.Dashboard.SectionTitle">팀 정보</h1>
        <button type="button" class="@Css.Dashboard.SecondaryButton" @onclick="OnEdit">정보 수정</button>
    </div>

    @* 기본 카드 + 공개 홈페이지 카드 *@
    <div class="grid grid-cols-[repeat(auto-fit,minmax(340px,1fr))] gap-[18px]">
        <div class="@($"{Css.Dashboard.Card} p-[26px] flex flex-col gap-[18px]")">
            <div class="flex gap-[18px] items-center">
                <TeamEmblem LogoUrl="@Info.Profile.LogoUrl" ContainerClass="w-[72px] h-[72px] rounded-[16px]" IconSize="34" />
                <span class="flex flex-col gap-[5px]">
                    <span class="text-xl font-extrabold text-navy-deep break-keep">@Info.Profile.TeamName</span>
                    <span class="flex gap-1.5 flex-wrap">
                        @if (Info.Profile.IsVerified)
                        {
                            <span class="@Css.Dashboard.BadgeOrange">✓ 인증팀</span>
                        }
                        @if (Info.Profile.TeamType is not null)
                        {
                            <span class="@Css.Dashboard.BadgeGray">@Info.Profile.TeamType</span>
                        }
                        @if (Info.Profile.Region is not null)
                        {
                            <span class="@Css.Dashboard.BadgeGray">@Info.Profile.Region</span>
                        }
                        @if (Info.Profile.FoundedYear is not null)
                        {
                            <span class="@Css.Dashboard.BadgeGray">@(Info.Profile.FoundedYear) 창단</span>
                        }
                    </span>
                </span>
            </div>
            @if (Info.Profile.MonthlyFee is not null || Info.Profile.TrainingDays is not null)
            {
                <div class="grid grid-cols-2 gap-3">
                    @if (Info.Profile.MonthlyFee is not null)
                    {
                        <div class="bg-surface-alt rounded-xl px-4 py-3.5 flex flex-col gap-1">
                            <span class="text-xs font-bold text-text-muted">월 회비</span>
                            <span class="text-base font-extrabold text-navy-deep">@($"{Info.Profile.MonthlyFee:N0}")원 <span class="text-xs font-semibold text-text-body">· @(Info.Profile.IsMonthlyFeePublic ? "공개" : "비공개")</span></span>
                        </div>
                    }
                    @if (Info.Profile.TrainingDays is not null)
                    {
                        <div class="bg-surface-alt rounded-xl px-4 py-3.5 flex flex-col gap-1">
                            <span class="text-xs font-bold text-text-muted">훈련</span>
                            <span class="text-base font-extrabold text-navy-deep">주 @(Info.Profile.TrainingDays.Length)회 <span class="text-xs font-semibold text-text-body">· @Info.Profile.TrainingDays</span></span>
                        </div>
                    }
                </div>
            }
        </div>
        @if (Info.Profile.Slug is not null)
        {
            <div class="bg-gradient-navy rounded-[16px] px-6 py-[22px] flex flex-col gap-2.5 text-white justify-center">
                <span class="text-[13px] font-extrabold text-teal">공개 팀 홈페이지</span>
                <span class="text-[14.5px] font-bold">playground.kr/team/@Info.Profile.Slug</span>
                <span class="text-[12.5px] text-white/65 leading-[1.6] break-keep">팀 정보의 핵심가치와 코칭스태프가 홈페이지 소개 탭에 그대로 노출돼요</span>
            </div>
        }
    </div>

    @* 핵심가치 — 학부모 대상 최중요 요소 *@
    @if (Info.Values.Count > 0)
    {
        <SectionCard Title="핵심가치" ShowExposedBadge="true">
            <HeaderRight>
                <span class="text-[12.5px] text-text-muted break-keep">학부모가 팀을 고르는 첫 번째 기준이에요</span>
            </HeaderRight>
            <ChildContent>
                <div class="grid grid-cols-[repeat(auto-fit,minmax(260px,1fr))] gap-3.5">
                    @foreach (TeamValueDto value in Info.Values)
                    {
                        <ValueCard Title="@value.Title" Description="@value.Description" />
                    }
                </div>
            </ChildContent>
        </SectionCard>
    }

    @* 코칭스태프 *@
    @if (Info.Coaches.Count > 0)
    {
        <SectionCard Title="코칭스태프" ShowExposedBadge="true">
            <HeaderRight>
                <button type="button" class="@Css.Dashboard.DashedButton">＋ 코치 초대</button>
            </HeaderRight>
            <ChildContent>
                <div class="grid grid-cols-[repeat(auto-fit,minmax(320px,1fr))] gap-3.5">
                    @foreach (TeamCoachDto coach in Info.Coaches)
                    {
                        <CoachCard Name="@coach.Name" Role="@coach.Role" Career="@(coach.Career ?? string.Empty)"
                                   Certification="@(coach.Certification ?? string.Empty)"
                                   Quote="@(coach.Quote ?? string.Empty)"
                                   Achievements="@coach.Achievements.ToArray()"
                                   InstagramUrl="@coach.InstagramUrl" YoutubeUrl="@coach.YoutubeUrl" />
                    }
                </div>
            </ChildContent>
        </SectionCard>
    }

    @* 공식 채널 *@
    @if (Info.Channels.Count > 0)
    {
        <SectionCard Title="공식 채널" ShowExposedBadge="true">
            <HeaderRight>
                <button type="button" class="@Css.Dashboard.DashedButton">＋ 채널 추가</button>
            </HeaderRight>
            <ChildContent>
                <div class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-3.5">
                    @foreach (TeamChannelDto channel in Info.Channels)
                    {
                        <ChannelRow IconType="@ChannelIcon(channel)" Name="@channel.Name"
                                    Meta="@ChannelMeta(channel)" LinkLabel="@ChannelLinkLabel(channel)"
                                    Url="@channel.Url" />
                    }
                </div>
            </ChildContent>
        </SectionCard>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public TeamInfoResponse Info { get; set; } = new();

    /// <summary>"정보 수정" — 페이지가 수정 다이얼로그를 연다.</summary>
    [Parameter]
    public EventCallback OnEdit { get; set; }

    private static SoccerChannelType ParseChannelType(TeamChannelDto channel)
    {
        return Enum.TryParse(channel.ChannelType, out SoccerChannelType parsed) ? parsed : SoccerChannelType.YouTube;
    }

    private static BrandIcon.BrandIconType ChannelIcon(TeamChannelDto channel)
    {
        return ParseChannelType(channel) switch
        {
            SoccerChannelType.Instagram => BrandIcon.BrandIconType.Instagram,
            _ => BrandIcon.BrandIconType.YouTube
        };
    }

    // "youtube.com/@handle · 경기 하이라이트" 형태 — URL 표시부 + 설명
    private static string ChannelMeta(TeamChannelDto channel)
    {
        string display = channel.Url
            .Replace("https://", string.Empty)
            .Replace("http://", string.Empty)
            .TrimEnd('/');
        return channel.Description is null ? display : $"{display} · {channel.Description}";
    }

    private static string ChannelLinkLabel(TeamChannelDto channel)
    {
        return ParseChannelType(channel) switch
        {
            SoccerChannelType.Instagram => "프로필 열기 →",
            _ => "채널 열기 →"
        };
    }
}
