@* 내 팀 — 네이비 그라디언트 카드. "팀 대시보드"가 허브의 유일한 오렌지 버튼이다. *@
@using PlayGround.Contracts.Team
@using PlayGround.Client.Styles

<article class="@Css.Hub.TeamCard">
    <span class="@Css.Hub.TeamDecor"></span>

    <div class="relative flex items-center gap-3.5">
        <span class="@Css.Hub.TeamIconBox">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                 stroke-linecap="round" stroke-linejoin="round" class="text-white/80"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        </span>

        <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 flex-wrap">
                <h3 class="@Css.Hub.TeamName">@Team.TeamName</h3>
                @if (Team.IsVerified)
                {
                    <span class="@Css.Hub.TeamVerified">✓ 인증팀</span>
                }
            </div>
            @* 요약은 값이 있는 조각만 잇는다 — "미처리 연결 요청 0건"을 쓰지 않는다 *@
            <p class="@Css.Hub.TeamSummary">@Summary</p>
        </div>
    </div>

    @* 다음 경기 줄은 일정 데이터가 실제로 연결될 때 붙인다(현재 팀 일정은 목데이터) *@

    <div class="relative mt-4 flex gap-2">
        <a href="@Routes.TeamDashboard" class="@($"{Css.Hub.TeamPrimary} flex-1 md:flex-none")">팀 대시보드</a>
        @if (!string.IsNullOrWhiteSpace(Team.Slug))
        {
            <a href="@Routes.TeamPublicHome(Team.Slug)" class="@($"{Css.Hub.TeamGhost} flex-1 md:flex-none")">공개 홈페이지</a>
        }
    </div>
</article>

@code {
    [Parameter]
    public HubTeamDto Team { get; set; } = new();

    private string Summary
    {
        get
        {
            var parts = new List<string> { $"선수 {Team.PlayerCount}명" };
            if (Team.PendingInviteCount > 0)
            {
                parts.Add($"미처리 연결 요청 {Team.PendingInviteCount}건");
            }

            return string.Join(" · ", parts);
        }
    }
}
