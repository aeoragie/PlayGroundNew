@* 일정 섹션: 이벤트 행(날짜 컬럼 + 유형 pill + 제목·메타 + 시간) — SPEC.TEAMDASHBOARD.md §3
   데이터는 백엔드 연동 전 레퍼런스 예시 *@
@using PlayGround.Client.Styles

<div class="flex flex-col gap-[18px]">
    <div class="flex justify-between items-center">
        <h1 class="@Css.Dashboard.SectionTitle">일정 <span class="text-sm font-bold text-text-muted">2026년 7월</span></h1>
        <button type="button" class="@Css.Dashboard.PrimaryButton">＋ 일정 추가</button>
    </div>

    <div class="flex flex-col gap-3">
        @foreach (ScheduleEvent scheduleEvent in Events)
        {
            <div class="@($"{Css.Dashboard.Card} rounded-[14px] px-5 py-4 flex items-center gap-[18px]")">
                <span class="flex flex-col items-center w-[52px] shrink-0">
                    <span class="text-[11.5px] font-bold text-text-muted">@scheduleEvent.Day</span>
                    <span class="text-[21px] font-extrabold text-navy-deep">@scheduleEvent.Date</span>
                </span>
                <span class="@TypeClass(scheduleEvent.Type)">@scheduleEvent.Type.ToLabel()</span>
                <span class="flex flex-col gap-[3px] flex-1 min-w-0">
                    <span class="text-[15px] font-bold text-navy-deep break-keep">@scheduleEvent.Title</span>
                    <span class="text-[12.5px] text-text-body">@scheduleEvent.Meta</span>
                </span>
                <span class="text-[13px] font-bold text-text-strong whitespace-nowrap">@scheduleEvent.Time</span>
            </div>
        }
    </div>

    <div class="text-[12.5px] text-text-muted break-keep">경기 일정은 공개 홈페이지 Schedule 탭에 자동 노출 · 학부모는 구독 캘린더(Google/Apple)로 받아볼 수 있어요</div>
</div>

@code {
    private sealed record ScheduleEvent(string Day, string Date, SoccerScheduleEventType Type, string Title, string Meta, string Time);

    private static readonly ScheduleEvent[] Events =
    [
        new("화", "14", SoccerScheduleEventType.Training, "전술 훈련 — 빌드업", "강동 보조구장 · U15 전원", "19:00–21:00"),
        new("토", "18", SoccerScheduleEventType.Match, "서울 유스리그 12R vs 송파 FC", "송파 구장 · 원정 · 집결 08:30", "10:00"),
        new("일", "19", SoccerScheduleEventType.Training, "리커버리 + 개인 피드백", "강동 보조구장", "17:00–18:30"),
        new("토", "25", SoccerScheduleEventType.Tournament, "한강배 유소년컵 조별 1차전", "난지 천연잔디 · 대진 추후 공지", "13:00"),
    ];

    private static string TypeClass(SoccerScheduleEventType type) =>
        "text-xs font-bold rounded-full px-[13px] py-[5px] whitespace-nowrap shrink-0 " + type switch
        {
            SoccerScheduleEventType.Match => "text-white bg-navy",
            SoccerScheduleEventType.Tournament => "text-orange-ink bg-surface-orange-badge",
            _ => "text-teal-ink bg-teal/[.12]",
        };
}
