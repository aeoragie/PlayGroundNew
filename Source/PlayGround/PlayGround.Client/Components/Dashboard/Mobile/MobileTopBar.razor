@* 모바일 상단 바: 엠블럼 + 팀명 + 인증 요약 + 공개 홈페이지·알림 아이콘 버튼(36px) — sticky *@
@using PlayGround.Contracts.Team
<header class="sticky top-0 z-40 bg-navy-deep px-4 py-3 flex items-center gap-[11px]">
    <TeamEmblem LogoUrl="@(Team?.LogoUrl)" ContainerClass="w-9 h-9 rounded-[10px]" IconSize="19" />
    <span class="flex flex-col gap-px min-w-0 flex-1">
        <span class="text-[15px] font-extrabold text-white whitespace-nowrap overflow-hidden text-ellipsis">@(Team?.TeamName)</span>
        <span class="text-[11px] font-bold text-teal whitespace-nowrap">@(Team is { IsVerified: true } ? "✓ 인증팀 · 팀 관리자 모드" : "팀 관리자 모드")</span>
    </span>
    @if (Team?.Slug is not null)
    {
        <a href="@Routes.TeamPublicHome(Team.Slug)" target="_blank" aria-label="공개 홈페이지" class="w-9 h-9 rounded-[10px] bg-white/[.08] flex items-center justify-center text-white/85">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><path d="M15 3h6v6M10 14L21 3"></path></svg>
        </a>
    }
    <NotificationBell Appearance="NotificationBell.BellAppearance.Box" ContextLabel="@(Team?.TeamName)" />
</header>

@code {
    [Parameter]
    public TeamProfileDto? Team { get; set; }
}
