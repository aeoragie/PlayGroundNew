@* 모바일 하단 탭바 5개: 팀 정보/선수단/일정/경기/모집 — safe-area 대응, 배경 블러.
   경기 탭은 결과+영상 통합(서브탭) — Results·Videos 어느 쪽이든 활성 표시 *@
<nav class="fixed bottom-0 inset-x-0 z-50 max-w-[480px] mx-auto bg-bg/95 backdrop-blur-[10px] border-t border-border flex px-1 pt-1.5 pb-[calc(6px+env(safe-area-inset-bottom))]">
    @foreach (TabItem tab in Tabs)
    {
        <a href="@Routes.TeamDashboardSection(tab.Section)" class="@TabClass(tab)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">@((MarkupString)tab.IconPaths)</svg>@tab.Label
        </a>
    }
</nav>

@code {
    [Parameter]
    public SoccerTeamDashboardSection ActiveSection { get; set; } = SoccerTeamDashboardSection.Info;

    private sealed record TabItem(SoccerTeamDashboardSection Section, string Label, string IconPaths);

    private static readonly TabItem[] Tabs =
    [
        new(SoccerTeamDashboardSection.Info, "팀 정보", """<path d="M12 3l7 3v5.5c0 4.5-3 7.6-7 9.5-4-1.9-7-5-7-9.5V6z"></path>"""),
        new(SoccerTeamDashboardSection.Roster, "선수단", """<circle cx="9" cy="8" r="3.2"></circle><path d="M3.5 19.5c0-3 2.5-5.2 5.5-5.2s5.5 2.2 5.5 5.2"></path><path d="M16 5.6a2.8 2.8 0 0 1 0 5.4"></path><path d="M17.5 14.6c2 .7 3 2.4 3 4.4"></path>"""),
        new(SoccerTeamDashboardSection.Schedule, "일정", """<rect x="3.5" y="5" width="17" height="15.5" rx="2.5"></rect><path d="M3.5 10h17M8 3v4M16 3v4"></path>"""),
        new(SoccerTeamDashboardSection.Results, "경기", """<path d="M5 20V11M12 20V4M19 20v-6"></path>"""),
        new(SoccerTeamDashboardSection.Recruit, "모집", """<path d="M3 10.5v3h3.5l9.5 5v-13l-9.5 5z"></path><path d="M19.5 9.5a4 4 0 0 1 0 5"></path>"""),
    ];

    private string TabClass(TabItem tab)
    {
        bool isActive = ActiveSection == tab.Section
            || (tab.Section == SoccerTeamDashboardSection.Results && ActiveSection == SoccerTeamDashboardSection.Videos);
        return "flex-1 flex flex-col items-center gap-[3px] rounded-[10px] pt-[7px] pb-[5px] text-[10.5px] font-bold "
            + (isActive ? "text-navy" : "text-text-muted");
    }
}
