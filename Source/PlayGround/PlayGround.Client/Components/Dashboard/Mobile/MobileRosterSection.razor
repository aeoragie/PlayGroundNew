@* 선수단(모바일): 연령 탭 + 아이콘 세그먼트(리스트/그리드) — 리스트 기본, 카드 토글 시 2열
   연령 탭은 전원 AgeGroup 보유 시만 노출. Unclaimed 안내 박스는 Unclaimed 존재 시만. *@
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Team

<div class="flex flex-col gap-3">
    <div class="flex justify-between items-center">
        <h1 class="m-0 text-[19px] font-extrabold text-navy-deep">선수단 <span class="text-[13px] font-bold text-text-muted">@(Players.Count)명</span></h1>
        <button type="button" class="@Css.Dashboard.MobilePrimaryButton" @onclick="OnAdd">＋ 선수 추가</button>
    </div>

    <div class="flex gap-[7px] items-center">
        @if (HasAgeTabs)
        {
            @foreach (SoccerAgeGroup age in AgeTabs)
            {
                SoccerAgeGroup tab = age;
                <button type="button" class="@AgeChipClass(tab)" @onclick="() => mAgeTab = tab">@tab</button>
            }
        }
        <div class="flex-1"></div>
        <div class="flex border-1.5 border-border rounded-[9px] overflow-hidden h-9">
            <button type="button" aria-label="리스트 뷰" class="@ViewToggleClass(isList: true)" @onclick="() => mIsListView = true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
            <button type="button" aria-label="카드 뷰" class="@ViewToggleClass(isList: false)" @onclick="() => mIsListView = false">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="4" y="4" width="7" height="7" rx="1.5"></rect><rect x="13" y="4" width="7" height="7" rx="1.5"></rect><rect x="4" y="13" width="7" height="7" rx="1.5"></rect><rect x="13" y="13" width="7" height="7" rx="1.5"></rect></svg>
            </button>
        </div>
    </div>

    @if (Players.Count == 0)
    {
        @* 빈 상태 Tier A (주 액션은 헤더 버튼 하나 유지 — 카드 안 CTA 없음) *@
        <EmptyState Kind="EmptyState.Art.Players" Title="아직 등록된 선수가 없어요">
            <Description>선수를 등록하면 공개 홈페이지 선수단에도 함께 표시돼요.</Description>
        </EmptyState>
    }
    else if (mIsListView)
    {
        <div class="@($"{Css.Dashboard.Card} rounded-[14px] overflow-hidden")">
            @foreach (TeamRosterPlayerDto player in VisiblePlayers)
            {
                <div class="flex items-center gap-[11px] px-[15px] py-[13px] border-b border-surface-icon">
                    <span class="w-[34px] h-[34px] rounded-full bg-surface-icon flex items-center justify-center text-[12.5px] font-extrabold text-navy shrink-0">@(player.JerseyNumber ?? "-")</span>
                    <span class="flex flex-col gap-px flex-1 min-w-0">
                        @* 선수 상세 화면이 없어 링크가 아니다 (# 링크는 랜딩 오이동) *@
                        <span class="text-sm font-bold text-navy-deep whitespace-nowrap">@player.Name</span>
                        <span class="text-[11.5px] text-text-body whitespace-nowrap">@(player.Position ?? "-") · @(player.Grade ?? "-")</span>
                    </span>
                    <ClaimBadge Status="@ClaimOf(player)" />
                    <OverflowMenu Target="@player.Name" DestructiveItems="RemoveItems(player)" />
                </div>
            }
        </div>
    }
    else
    {
        <div class="grid grid-cols-2 gap-[11px]">
            @foreach (TeamRosterPlayerDto player in VisiblePlayers)
            {
                <div class="@($"{Css.Dashboard.Card} rounded-[14px] px-2.5 pt-2.5 pb-3.5 flex flex-col items-center gap-[9px] text-center")">
                    <div class="w-full aspect-[4/3] rounded-[10px] overflow-hidden relative bg-surface-icon">
                        @if (player.PhotoUrl is not null)
                        {
                            <img src="@player.PhotoUrl" alt="@player.Name" class="absolute inset-0 w-full h-full object-cover" />
                        }
                        else
                        {
                            <span class="absolute inset-0 flex items-center justify-center">
                                <Avatar Name="@player.Name" Size="32" />
                            </span>
                        }
                        <span class="absolute top-1.5 left-1.5 w-[26px] h-[26px] rounded-full bg-navy-deep/85 flex items-center justify-center text-[11.5px] font-extrabold text-white pointer-events-none">@(player.JerseyNumber ?? "-")</span>
                        @* 사진 변경 — 팀 관리자 전용 섹션 *@
                        <button type="button" class="@Css.Uploader.CameraBadge !right-1.5 !bottom-1.5"
                                aria-label="@($"{player.Name} 선수 사진 변경")" @onclick="() => OpenPhotoDialog(player)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 8h3l2-2.5h6L17 8h3v11H4z"></path><circle cx="12" cy="13" r="3.2"></circle>
                            </svg>
                        </button>
                    </div>
                    <span class="flex flex-col gap-0.5">
                        <span class="text-sm font-extrabold text-navy-deep whitespace-nowrap">@player.Name</span>
                        <span class="text-[11.5px] text-text-body whitespace-nowrap">@(player.Position ?? "-") · @(player.Grade ?? "-")</span>
                    </span>
                    <div class="flex items-center gap-1">
                        <ClaimBadge Status="@ClaimOf(player)" />
                        <OverflowMenu Target="@player.Name" DestructiveItems="RemoveItems(player)" />
                    </div>
                </div>
            }
        </div>
    }

    @if (HasUnclaimed)
    {
        <div class="flex gap-[9px] items-start bg-surface-orange border border-dashed border-orange rounded-xl px-3.5 py-3">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" class="shrink-0 mt-0.5 text-orange-ink"><circle cx="12" cy="12" r="9"></circle><path d="M12 11v5M12 8v.1"></path></svg>
            <span class="text-xs text-text-strong leading-[1.6] break-keep">Unclaimed 선수에게 <b>초대코드</b>를 보내면 학부모·선수가 직접 기록을 관리해요.</span>
        </div>
    }
</div>

@* 사진 변경 — 카드가 공유하는 다이얼로그 하나 *@
<PlayerPhotoDialog @bind-IsOpen="mPhotoDialogOpen" Player="@mPhotoPlayer" />

@code {
    [Parameter]
    public List<TeamRosterPlayerDto> Players { get; set; } = new();

    /// <summary>"＋ 선수 추가" — 페이지가 다이얼로그를 연다.</summary>
    [Parameter]
    public EventCallback OnAdd { get; set; }

    /// <summary>선수 내보내기 — 페이지가 확인 모달 + 실행취소 토스트를 맡는다.</summary>
    [Parameter]
    public EventCallback<TeamRosterPlayerDto> OnRemove { get; set; }

    // 단일 파괴 액션을 ⋯에 담는다(PC 로스터와 같은 판단 — 오클릭 방지).
    private List<OverflowMenu.MenuItem> RemoveItems(TeamRosterPlayerDto player) => new()
    {
        new OverflowMenu.MenuItem("선수 내보내기", () => OnRemove.InvokeAsync(player)),
    };

    private SoccerAgeGroup? mAgeTab;
    private bool mIsListView = true;

    private bool mPhotoDialogOpen;
    private TeamRosterPlayerDto? mPhotoPlayer;

    private void OpenPhotoDialog(TeamRosterPlayerDto player)
    {
        mPhotoPlayer = player;
        mPhotoDialogOpen = true;
    }

    // 연령 탭은 전원이 AgeGroup을 가질 때만 (혼합·전부 null이면 탭 없이 전체 표시)
    private bool HasAgeTabs => Players.Count > 0 && Players.All(p => AgeOf(p) is not null);

    private List<SoccerAgeGroup> AgeTabs =>
        Players
        .Select(AgeOf)
        .OfType<SoccerAgeGroup>()
        .Distinct()
        .OrderBy(age => age)
        .ToList();

    private IEnumerable<TeamRosterPlayerDto> VisiblePlayers =>
        HasAgeTabs && mAgeTab is not null ? Players.Where(p => AgeOf(p) == mAgeTab) : Players;

    private bool HasUnclaimed => Players.Any(p => ClaimOf(p) == SoccerClaimStatus.Unclaimed);

    protected override void OnParametersSet()
    {
        if (HasAgeTabs && (mAgeTab is null || !AgeTabs.Contains(mAgeTab.Value)))
        {
            mAgeTab = AgeTabs[0];
        }
    }

    private static SoccerAgeGroup? AgeOf(TeamRosterPlayerDto player) =>
        SoccerAgeGroupExtensions.ParseAgeGroupOrNull(player.AgeGroup);

    private static SoccerClaimStatus ClaimOf(TeamRosterPlayerDto player) =>
        SoccerClaimStatusExtensions.ParseClaimStatus(player.ClaimStatus);

    private string AgeChipClass(SoccerAgeGroup tab) =>
        "h-9 px-[15px] rounded-full text-[12.5px] font-bold border-1.5 whitespace-nowrap "
        + (mAgeTab == tab ? "border-navy bg-navy text-white" : "border-border bg-white text-text-body");

    private string ViewToggleClass(bool isList) =>
        "px-3 flex items-center border-0 cursor-pointer "
        + (mIsListView == isList ? "bg-navy text-white" : "bg-white text-text-muted");
}
