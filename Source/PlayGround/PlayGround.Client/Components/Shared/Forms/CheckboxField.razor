@* 공용 체크박스 — 법적 동의(만 14세 미만 등)·다중 선택용. Design.FormPatterns 선택 컨트롤.
   20px(모바일 22px) 네이비 채움. **기본 체크 금지** — 호출부가 false로 시작해야 한다. *@
@using PlayGround.Client.Styles
@implements IFormFieldRegistration
@implements IDisposable
@inject IJSRuntime Js

<div class="@($"flex flex-col gap-1.5 {Class}")">
    <button type="button" @ref="mElement" disabled="@Disabled"
            class="flex items-start gap-2.5 text-left disabled:cursor-not-allowed" @onclick="ToggleAsync">
        <span class="@Css.Form.CheckBox(Value, Disabled)">
            @if (Value)
            {
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"
                     stroke-linecap="round" stroke-linejoin="round"><path d="M20 6.5l-11 11-5-5"></path></svg>
            }
        </span>
        <span class="text-[13px] md:text-[12.5px] leading-[1.55] break-keep text-navy-deep">
            @Label@if (IsOptional)
            {
                <span class="@Css.Form.OptionalMark"> (선택)</span>
            }
            @ChildContent
        </span>
    </button>

    @if (HasVisibleError)
    {
        <span class="@($"{Css.Form.ErrorMessage} pl-[32px] md:pl-[30px]")">@mErrorMessage</span>
    }
    else if (Helper is not null)
    {
        <span class="@($"{Css.Form.Helper} pl-[32px] md:pl-[30px]")">@Helper</span>
    }
</div>

@code {
    private ElementReference mElement;
    private string? mErrorMessage;
    private bool mTouched;

    [CascadingParameter]
    public FormFieldContext? Form { get; set; }

    [Parameter, EditorRequired]
    public string Label { get; set; } = string.Empty;

    /// <summary>기본 체크 금지 — 호출부는 false로 시작한다.</summary>
    [Parameter]
    public bool Value { get; set; }

    [Parameter]
    public EventCallback<bool> ValueChanged { get; set; }

    /// <summary>검증 규칙 — 필수 동의는 false일 때 오류 문구를 반환한다.</summary>
    [Parameter]
    public Func<bool, string?>? Validator { get; set; }

    [Parameter]
    public string? Helper { get; set; }

    [Parameter]
    public bool IsOptional { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>레이블 뒤에 붙일 링크 등 (예: "약관 보기").</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Class { get; set; }

    public bool HasVisibleError => mTouched && mErrorMessage is not null;

    protected override void OnInitialized()
    {
        Form?.Register(this);
    }

    public void Dispose()
    {
        Form?.Unregister(this);
    }

    private async Task ToggleAsync()
    {
        bool next = !Value;
        await ValueChanged.InvokeAsync(next);

        // 토글이 곧 확정 — 즉시 검증(체크하는 순간 오류 해제)
        mTouched = true;
        mErrorMessage = Validator?.Invoke(next);
    }

    public bool ValidateOnSubmit()
    {
        mTouched = true;
        mErrorMessage = Validator?.Invoke(Value);
        StateHasChanged();
        return mErrorMessage is null;
    }

    public async Task FocusAsync()
    {
        await FormScrollInterop.ScrollIntoViewAndFocusAsync(Js, mElement);
    }
}
