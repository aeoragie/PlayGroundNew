@* 알림 센터 패널 (Design.ClaimFlow) — 네이비 헤더 + 유형 칩(데이터 파생) + 목록.
   액션형(연결 요청) = 인라인 승인/거절, 처리 후 완료 박스로 교체(요청 상태 라이브).
   이동형 = 클릭 시 읽음 처리 + 딥링크. 문구는 유형+스냅샷으로 여기서 조립한다 (카피는 클라 소유). *@
@using PlayGround.Client.Services.Feedback
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Notification
@using PlayGround.Domain.Soccer
@inject NavigationManager Nav
@inject NotificationClient Notifications
@inject ClaimClient Claims
@inject ToastService Toasts

<div class="@Css.Notification.Overlay" @onclick="() => OnClose.InvokeAsync()"></div>
<div class="@Css.Notification.Panel">
    <div class="@Css.Notification.Head">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.7 21a2 2 0 0 1-3.4 0"></path></svg>
        <span class="@Css.Notification.HeadTitle">알림</span>
        @if (Data is { UnreadCount: > 0 })
        {
            <span class="@Css.Notification.HeadCount">@Data.UnreadCount</span>
        }
        <div class="flex-1"></div>
        @if (ContextLabel is not null)
        {
            <span class="@Css.Notification.HeadContext">@ContextLabel</span>
        }
    </div>

    @if (Data is null)
    {
        <span class="@Css.Notification.EmptyText">알림을 불러오지 못했어요. 다시 열어 주세요.</span>
    }
    else
    {
        @* 유형 칩 — 존재하는 그룹만 (빈 데이터 노출 금지) *@
        @if (Groups.Count > 1)
        {
            <div class="@Css.Notification.ChipRow">
                <button type="button" class="@(mGroup is null ? Css.Notification.ChipActive : Css.Notification.Chip)"
                        @onclick="() => mGroup = null">전체 @Data.Items.Count</button>
                @foreach ((string group, int count) in Groups)
                {
                    string value = group;
                    <button type="button" class="@(mGroup == value ? Css.Notification.ChipActive : Css.Notification.Chip)"
                            @onclick="() => mGroup = value">@value @count</button>
                }
            </div>
        }

        <div class="@Css.Notification.List">
            @if (Visible.Count == 0)
            {
                <span class="@Css.Notification.EmptyText">아직 알림이 없어요.</span>
            }
            @foreach (NotificationDto item in Visible)
            {
                @if (item.Type == nameof(SoccerNotificationType.ClaimRequest))
                {
                    @* ── 액션형: 프로필 연결 요청 ── *@
                    <div class="@(item.RequestStatus == "Pending" ? Css.Notification.ActionCardPending : Css.Notification.ActionCard)">
                        <div class="flex items-start gap-[11px]">
                            <span class="@Css.Notification.ActionIcon">
                                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"></circle><path d="M3.5 19.5c0-3 2.5-5.2 5.5-5.2s5.5 2.2 5.5 5.2"></path><path d="M16 8h5M18.5 5.5v5"></path></svg>
                            </span>
                            <span class="flex flex-col gap-[3px] flex-1 min-w-0">
                                <span class="@Css.Notification.ActionTitle">프로필 연결 요청</span>
                                <span class="@Css.Notification.ActionBody"><b>@item.ActorName 님(@RelationLabel(item.Relation))</b>이 <b>@item.PlayerName</b>@(item.MetaText is not null ? $"({item.MetaText})" : "") 프로필 연결을 요청했어요</span>
                                <span class="@Css.Notification.ActionMeta">초대코드 @item.SubText 사용 · @TimeAgo(item.CreatedAt)</span>
                            </span>
                        </div>
                        @if (item.RequestStatus == "Pending")
                        {
                            <div class="flex gap-2">
                                <button type="button" class="@Css.Notification.ApproveButton" disabled="@mBusy"
                                        @onclick="() => ReviewAsync(item, true)">승인</button>
                                <button type="button" class="@Css.Notification.RejectButton" disabled="@mBusy"
                                        @onclick="() => ReviewAsync(item, false)">거절</button>
                            </div>
                            <span class="@Css.Notification.ActionFoot">승인하면 프로필 관리 권한이 보호자에게 이전돼요. 이후 팀은 소속·등번호만 관리해요.</span>
                        }
                        else if (item.RequestStatus == "Approved")
                        {
                            <div class="@Css.Notification.DoneBox">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="flex-none"><path d="M4.5 12.5l5 5 10-11"></path></svg>
                                <span>승인 완료 — @item.PlayerName 선수가 Claimed 상태가 됐어요</span>
                            </div>
                        }
                        else
                        {
                            <div class="@Css.Notification.RejectedBox">거절한 요청이에요</div>
                        }
                    </div>
                }
                else
                {
                    @* ── 이동형: 셰브론 + 딥링크 (클릭 시 읽음) ── *@
                    <button type="button" class="@(item.IsRead ? Css.Notification.MoveRowRead : Css.Notification.MoveRow)"
                            @onclick="() => OpenAsync(item)">
                        <span class="@MoveIconClass(item)">@MoveIcon(item)</span>
                        <span class="flex flex-col gap-[3px] flex-1 min-w-0">
                            <span class="flex items-center gap-1.5 flex-wrap">
                                <span class="@Css.Notification.MoveTitle">@MoveTitle(item)</span>
                                @if (item.Type == nameof(SoccerNotificationType.ViewRequest))
                                {
                                    @* 에이전트 관련 알림엔 violet 뱃지 병기 (Design.ClaimFlow 알림 절) *@
                                    <span class="@Css.Notification.AgentBadge">에이전트</span>
                                }
                            </span>
                            <span class="@Css.Notification.MoveBody">@MoveBody(item)</span>
                            <span class="@Css.Notification.MoveTime">@TimeAgo(item.CreatedAt)</span>
                        </span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-none mt-3 text-text-faint"><path d="M9 6l6 6-6 6"></path></svg>
                    </button>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public NotificationsResponse? Data { get; set; }

    [Parameter]
    public string? ContextLabel { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    /// <summary>처리(승인/거절·읽음) 후 재조회 — 벨 카운트와 목록을 함께 갱신한다.</summary>
    [Parameter]
    public EventCallback OnChanged { get; set; }

    private string? mGroup;
    private bool mBusy;

    // 유형 → 칩 그룹 (존재하는 것만 노출)
    private static string GroupOf(NotificationDto item) => item.Type switch
    {
        nameof(SoccerNotificationType.ClaimRequest) or
        nameof(SoccerNotificationType.ClaimApproved) or
        nameof(SoccerNotificationType.ClaimRejected) => "연결 요청",
        nameof(SoccerNotificationType.MatchResult) => "경기",
        nameof(SoccerNotificationType.ViewRequest) => "열람 요청",
        _ => "기록",
    };

    // 에이전트 축이 꺼져 있으면 열람 요청 알림은 갈 곳이 없다 — 행 자체를 내리지 않는다
    private IEnumerable<NotificationDto> Enabled => Data is null
        ? Enumerable.Empty<NotificationDto>()
        : Data.Items.Where(i => FeatureFlags.AgentApproval || i.Type != nameof(SoccerNotificationType.ViewRequest));

    private List<(string Group, int Count)> Groups =>
        Enabled.GroupBy(GroupOf).Select(g => (g.Key, g.Count())).ToList();

    private List<NotificationDto> Visible =>
        Enabled.Where(i => mGroup is null || GroupOf(i) == mGroup).ToList();

    private async Task ReviewAsync(NotificationDto item, bool approve)
    {
        mBusy = true;
        var reviewed = await Claims.ReviewAsync(item.RefId, approve);
        mBusy = false;

        if (reviewed is null)
        {
            Toasts.ShowError("요청을 처리하지 못했어요. 다시 시도해 주세요.");
            return;
        }

        await OnChanged.InvokeAsync();
    }

    private async Task OpenAsync(NotificationDto item)
    {
        if (!item.IsRead)
        {
            await Notifications.MarkReadAsync(item.NotificationId);
            await OnChanged.InvokeAsync();
        }

        string? route = RouteOf(item);
        if (route is not null)
        {
            await OnClose.InvokeAsync();
            Nav.NavigateTo(route);
        }
    }

    // 딥링크는 여기서만 조립 — SQL에 라우트를 저장하지 않는다 (Routes.cs 단일 관리)
    private static string? RouteOf(NotificationDto item) => item.Type switch
    {
        nameof(SoccerNotificationType.ClaimApproved) when item.TargetPlayerId is not null =>
            $"{Routes.PlayerDashboard}?playerId={item.TargetPlayerId}",
        nameof(SoccerNotificationType.ClaimRejected) => Routes.Claim,
        nameof(SoccerNotificationType.MatchResult) when item.TargetPlayerId is not null =>
            $"{Routes.PlayerDashboardSection(SoccerPlayerDashboardSection.Stats)}?playerId={item.TargetPlayerId}",
        nameof(SoccerNotificationType.CorrectionReviewed) =>
            Routes.TeamDashboardSection(SoccerTeamDashboardSection.Results),
        nameof(SoccerNotificationType.ViewRequest) => Routes.AgentApproval(item.RefId),
        _ => null,
    };

    private static string MoveTitle(NotificationDto item) => item.Type switch
    {
        nameof(SoccerNotificationType.ClaimApproved) => "프로필 연결 승인",
        nameof(SoccerNotificationType.ClaimRejected) => "연결 요청이 거절됐어요",
        nameof(SoccerNotificationType.MatchResult) => "경기 결과 반영",
        nameof(SoccerNotificationType.ViewRequest) => "상세 정보 열람 요청",
        _ => item.SubText == "Accepted" ? "기록 수정 신청 반영" : "기록 수정 신청 반려",
    };

    private static string MoveBody(NotificationDto item) => item.Type switch
    {
        nameof(SoccerNotificationType.ClaimApproved) => $"{item.PlayerName} 선수와 연결됐어요 — {item.TeamName}",
        nameof(SoccerNotificationType.ClaimRejected) => $"{item.PlayerName} · {item.TeamName} — 팀에 문의해 보세요",
        nameof(SoccerNotificationType.MatchResult) => $"{item.TeamName} vs {item.ActorName} ({item.MetaText}) 결과가 등록됐어요",
        nameof(SoccerNotificationType.ViewRequest) => $"{item.ActorName} 님이 {item.PlayerName} 선수의 상세 정보 열람을 요청했어요",
        _ => $"{FieldTypeLabel(item.MetaText)} 항목 · {item.TeamName}",
    };

    private string MoveIconClass(NotificationDto item) => item.Type switch
    {
        nameof(SoccerNotificationType.ClaimApproved) => Css.Notification.MoveIconTeal,
        nameof(SoccerNotificationType.ClaimRejected) => Css.Notification.MoveIconMuted,
        nameof(SoccerNotificationType.ViewRequest) => Css.Notification.MoveIconViolet,
        _ => Css.Notification.MoveIconNavy,
    };

    private static RenderFragment MoveIcon(NotificationDto item) => item.Type switch
    {
        nameof(SoccerNotificationType.ClaimApproved) =>
            @<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 12.5l5 5 10-11"></path></svg>,
        nameof(SoccerNotificationType.ClaimRejected) =>
            @<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"></path></svg>,
        nameof(SoccerNotificationType.MatchResult) =>
            @<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 3v18M3 12h18"></path></svg>,
        nameof(SoccerNotificationType.ViewRequest) =>
            @<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"></circle><path d="M3.5 19.5c0-3 2.5-5.2 5.5-5.2s5.5 2.2 5.5 5.2"></path><path d="M15.5 9.5l2 2 4-4.5"></path></svg>,
        _ =>
            @<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><path d="M14 3v6h6"></path></svg>,
    };

    internal static string RelationLabel(string? relation) => relation switch
    {
        "Father" => "아버지",
        "Guardian" => "기타 보호자",
        _ => "어머니",
    };

    // 기록 수정 신청 항목 라벨 (B6 폼 4항목과 동일)
    private static string FieldTypeLabel(string? fieldType) => fieldType switch
    {
        "Score" => "스코어",
        "GoalAssist" => "득점·도움",
        "Appearance" => "출전 선수",
        _ => "기타",
    };

    internal static string TimeAgo(DateTime createdAtUtc)
    {
        TimeSpan span = DateTime.UtcNow - createdAtUtc;
        if (span.TotalMinutes < 1)
        {
            return "방금 전";
        }

        if (span.TotalMinutes < 60)
        {
            return $"{(int)span.TotalMinutes}분 전";
        }

        if (span.TotalHours < 24)
        {
            return $"{(int)span.TotalHours}시간 전";
        }

        if (span.TotalHours < 48)
        {
            return "어제";
        }

        DateTime local = createdAtUtc.ToLocalTime();
        return $"{local.Month}/{local.Day}";
    }
}
