@* 빈 상태 Tier B — 카드/섹션 수준(페이지 내 한 블록만 빔). Design.EmptyStates.
   일러스트 없이 아이콘 박스 40px + 한 줄 문구 — 섹션 하나 때문에 페이지가 소란해지지 않게. *@
@using PlayGround.Client.Styles

<div class="@($"{Css.State.EmptySlot} {Class}")">
    <span class="@Css.State.EmptySlotIcon">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            @Icon
        </svg>
    </span>
    <span class="@Css.State.EmptySlotBody">
        <span class="@Css.State.EmptySlotTitle">@Title</span>
        @if (Link is not null)
        {
            @Link
        }
    </span>
</div>

@code {
    /// <summary>viewBox 0 0 24 24 기준 모노톤 라인 아이콘.</summary>
    [Parameter, EditorRequired]
    public RenderFragment? Icon { get; set; }

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    /// <summary>소유자용 텍스트 링크(선택) — Css.State.EmptySlotLink 사용.</summary>
    [Parameter]
    public RenderFragment? Link { get; set; }

    [Parameter]
    public string? Class { get; set; }
}
