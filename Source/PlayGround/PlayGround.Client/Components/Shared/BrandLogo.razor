@* 브랜드 워드마크: PlayGround(네이비) + 종목명(연회색) — 종목별 서비스 구분 (Soccer/Baseball …). 헤더/푸터 공용 *@
@if (Href is null)
{
    <div class="@RootClass">@Inner</div>
}
else
{
    <a href="@Href" class="@RootClass">@Inner</a>
}

@code {
    // null이면 링크가 아닌 정적 로고(푸터)
    [Parameter]
    public string? Href { get; set; }

    // true: 푸터 사이즈, false: 헤더 사이즈
    [Parameter]
    public bool Compact { get; set; }

    // true: 부모의 현재 텍스트 색 상속 (하이브리드 헤더의 흰색↔네이비 전환용)
    [Parameter]
    public bool InheritColor { get; set; }

    // 종목 접미사 — 타 종목 서비스 도입 시 교체 (예: "Baseball")
    [Parameter]
    public string Sport { get; set; } = "Soccer";

    private string RootClass => Compact
        ? $"flex items-baseline gap-1.5 font-extrabold text-[16px] md:text-[17px] tracking-[-.02em] whitespace-nowrap {ColorClass}"
        : $"flex items-baseline gap-1.5 md:gap-2 font-extrabold text-[17px] md:text-[19px] tracking-[-.02em] whitespace-nowrap {ColorClass}";

    private string ColorClass => InheritColor ? "text-current" : "text-navy-deep";

    // 종목명은 연회색 — 색 상속 모드(어두운/전환 헤더)에선 고정 회색 대신 현재색 반투명
    private string SportClass => InheritColor ? "opacity-55" : "text-text-muted";

    private RenderFragment Inner => @<text>PlayGround<span class="@SportClass">@Sport</span></text>;
}
