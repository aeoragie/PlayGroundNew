@using PlayGround.Client.Styles

@* CTA: 네이비 그라디언트 래퍼 + 상단 장식 원, 중앙 정렬 *@
<section id="cta" class="@($"{Css.Landing.Container} py-[72px] md:py-[110px] [scroll-margin-top:70px] md:[scroll-margin-top:80px]")">
    <div class="relative overflow-hidden bg-gradient-navy rounded-wrap-sm md:rounded-wrap px-[26px] py-11 md:px-14 md:py-[72px]
                flex flex-col items-center gap-3.5 md:gap-5 text-center">
        <DecorCircle Class="border-white/[.08] left-1/2 -top-[120px] w-[340px] h-[340px] -ml-[170px]
                            md:-top-[140px] md:w-[520px] md:h-[520px] md:-ml-[260px]" />

        <h2 class="relative m-0 text-[26px] md:text-[38px] font-extrabold tracking-[-.02em] text-white">지금 무료로 시작하세요</h2>

        <p class="relative m-0 text-[14.5px] leading-[1.6] md:text-[17px] text-white/70 [word-break:keep-all]">
            팀도, 선수도, 가입 즉시<span class="hidden md:inline">&nbsp;</span><br class="md:hidden" />홈페이지와 프로필이 만들어집니다.
        </p>

        <PillButton Href="#top" Variant="PillVariant.Orange" Size="PillSize.ExtraLarge"
                    Class="relative mt-1.5 md:mt-2 w-full max-w-[280px] md:w-auto md:max-w-none">무료로 시작하기</PillButton>

        <div class="relative text-[12.5px] md:text-[13.5px] text-white/50">Google · Kakao 계정으로 10초 만에</div>
    </div>
</section>
