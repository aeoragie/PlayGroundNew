@using PlayGround.Client.Styles

@* 핵심 기능 3: PC 3컬럼(아이콘 위) / 모바일 세로 스택(아이콘 좌 + 텍스트 우 가로형) *@
<section id="features" class="@($"{Css.Landing.Container} pt-[72px] md:pt-[110px] [scroll-margin-top:70px] md:[scroll-margin-top:80px]")">
    <SectionHeader Overline="CORE" Title="폐쇄적인 정보를, 모두에게" />

    <div class="flex flex-col gap-3.5 md:grid md:grid-cols-3 md:gap-6">
        @foreach (var feature in Features)
        {
            <div class="bg-white border-1.5 border-border rounded-card-xs md:rounded-card-sm px-5 py-[22px] md:px-[30px] md:py-[34px]
                        flex gap-4 items-start md:flex-col md:gap-[13px]">
                <div class="w-[42px] h-[42px] rounded-[11px] text-[20px] md:w-[46px] md:h-[46px] md:rounded-btn-lg md:text-[22px]
                            flex-none bg-navy flex items-center justify-center">@feature.Icon</div>
                <div class="flex flex-col gap-[7px] md:gap-[13px] min-w-0">
                    <CardTitle SizeClass="text-[16.5px] md:text-[19px]">@feature.Title</CardTitle>
                    <CardText>@feature.Body</CardText>
                </div>
            </div>
        }
    </div>
</section>

@code {
    private sealed record Feature(string Icon, string Title, string Body);

    private static readonly Feature[] Features =
    [
        new("🏠", "팀 홈페이지 자동 생성", "소개·선수단·시즌성적·모집까지, 대시보드에 입력한 데이터가 그대로 공개 홈페이지가 됩니다. 별도 제작 비용 없이."),
        new("📈", "선수 이력 · 기록 관리", "커리어 타임라인, 시즌 통계, 대표 영상 포트폴리오. 경기 결과가 입력되면 선수 기록이 자동으로 쌓입니다."),
        new("📊", "경기기록 무료 공개", "대회 결과, 순위표, 일정을 로그인 없이 누구나 조회. 자녀와 관심팀의 기록을 언제든 확인하세요.")
    ];
}
