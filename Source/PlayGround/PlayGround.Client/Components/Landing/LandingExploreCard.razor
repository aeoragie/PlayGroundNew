@* 모바일 팀 탐색 진입 카드 (Design.Navigation 7/21 보강 ①) — 히어로 CTA 대신 히어로 아래 콘텐츠 카드.
   PC는 히어로 보조 CTA "우리 동네 팀 둘러보기"가 담당하므로 모바일 전용. *@
@using PlayGround.Client.Styles

<section class="md:hidden px-[22px] -mt-9 relative z-10">
    <a href="@Routes.TeamExplore"
       class="flex items-center gap-3.5 bg-bg border-1.5 border-border rounded-2xl px-[18px] py-4 shadow-authcard">
        <span class="w-10 h-10 rounded-[11px] bg-surface-icon flex items-center justify-center shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                 stroke-linecap="round" stroke-linejoin="round" class="text-navy"><circle cx="11" cy="11" r="7"></circle><path d="M20 20l-3.5-3.5"></path></svg>
        </span>
        <span class="flex flex-col gap-px flex-1 min-w-0">
            <span class="text-sm font-extrabold text-navy-deep whitespace-nowrap">우리 동네 팀 둘러보기</span>
            <span class="text-xs text-text-muted whitespace-nowrap">우리 지역 팀 찾기</span>
        </span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" class="text-text-faint shrink-0"><path d="M9 6l6 6-6 6"></path></svg>
    </a>
</section>
