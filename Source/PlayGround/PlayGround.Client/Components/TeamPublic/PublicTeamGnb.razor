@* 공개 사이트 GNB — 좌측 PlayGround 브랜드(획득 플라이휠 노출) + 팀 엠블럼·팀명, 우측 경기기록·로그인.
   팀명은 첫 화면에선 숨김 → 히어로 통과(PC 300px / 모바일 170px) 시 구분선과 함께 fade-in (자리 유지) *@
@implements IAsyncDisposable
@inject IJSRuntime Js
@inject NavigationManager Nav

<header class="bg-bg border-b border-border sticky top-0 z-50">
    <div class="max-w-[1120px] mx-auto px-4 md:px-8 h-[54px] md:h-[60px] flex items-center gap-2.5 md:gap-3.5">
        <BrandLogo Href="@Routes.Landing" Compact="true" />
        <a href="@Routes.TeamPublicHome(Slug)" class="@BrandClass">
            <span class="w-px h-4 md:h-[18px] bg-border shrink-0"></span>
            <TeamEmblem LogoUrl="@LogoUrl" ContainerClass="w-6 h-6 md:w-[30px] md:h-[30px] rounded-[7px]" IconSize="14" />
            <span class="overflow-hidden text-ellipsis">@TeamName</span>
        </a>
        <div class="hidden md:block flex-1"></div>
        @if (IsManager)
        {
            @* 관리자 본인이 자기 팀 열람 중 — 최소 노출 원칙에 맞춰 버튼이 아닌 텍스트 링크 (Design.Navigation 배선) *@
            <a href="@Routes.TeamDashboard" class="text-[12.5px] md:text-[13.5px] font-bold text-text-strong whitespace-nowrap">관리</a>
        }
        <a href="@Routes.Records" class="text-[12.5px] md:text-[13.5px] font-bold text-text-strong whitespace-nowrap">경기기록</a>
        @* 팀 홈은 PlayGround 최소 노출 원칙 — 로그인해도 벨·아바타를 넣지 않고 텍스트 성격의 버튼 하나만 바꾼다 *@
        <AuthorizeView>
            <Authorized>
                <a href="@Routes.Dashboard" class="@AuthButtonClass">내 대시보드</a>
            </Authorized>
            <NotAuthorized>
                <a href="@LoginHref" class="@AuthButtonClass">로그인</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</header>

@code {
    [Parameter, EditorRequired]
    public string Slug { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string TeamName { get; set; } = string.Empty;

    [Parameter]
    public string? LogoUrl { get; set; }

    /// <summary>열람자 = 이 팀의 관리자 본인 — "관리" 텍스트 링크 노출.</summary>
    [Parameter]
    public bool IsManager { get; set; }

    private const string AuthButtonClass =
        "text-[12.5px] md:text-[13.5px] font-bold text-white hover:text-white bg-navy hover:bg-navy-deep " +
        "px-3.5 py-2 md:px-[18px] md:py-[9px] rounded-lg md:rounded-[9px] whitespace-nowrap transition-colors";

    // 팀 홈에서 로그인하러 가면 이 팀 페이지로 돌아온다
    private string LoginHref => Routes.LoginWithReturn("/" + Nav.ToBaseRelativePath(Nav.Uri));

    private IJSObjectReference? mModule;
    private IJSObjectReference? mScrollHandle;
    private DotNetObjectReference<PublicTeamGnb>? mSelfRef;
    private bool mPastHero;

    // 숨김 상태에서도 flex 자리는 유지 (pointer-events만 차단)
    private string BrandClass =>
        "flex items-center gap-2 md:gap-2.5 flex-1 min-w-0 md:flex-none text-[15px] md:text-[16.5px] font-extrabold " +
        "tracking-[-.02em] text-navy-deep whitespace-nowrap transition-all duration-[250ms] " +
        (mPastHero ? "opacity-100 translate-y-0" : "opacity-0 translate-y-[6px] pointer-events-none");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            mSelfRef = DotNetObjectReference.Create(this);
            mModule = await Js.InvokeAsync<IJSObjectReference>("import", "./js/team-public-home.js");
            mScrollHandle = await mModule.InvokeAsync<IJSObjectReference>("initHeroScroll", mSelfRef);
        }
    }

    [JSInvokable]
    public void OnHeroScrollChanged(bool pastHero)
    {
        if (mPastHero != pastHero)
        {
            mPastHero = pastHero;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (mScrollHandle != null)
            {
                await mScrollHandle.InvokeVoidAsync("dispose");
                await mScrollHandle.DisposeAsync();
            }

            if (mModule != null)
            {
                await mModule.DisposeAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            // 페이지 이탈 시 JS 런타임이 먼저 끊긴 경우 — 무시
        }

        mSelfRef?.Dispose();
    }
}
