@* 리뷰 작성·수정 — PC 중앙 모달 / 모바일 전체 시트 (Css.MatchForm 골격 재사용).
   별점은 별 5개 탭 선택(기본 5) — 폼 위젯 카탈로그에 별점이 없어 최소 형태로.
   저장 성공 = 토스트(A2), 검증 오류 = 인라인(폼 오류에 토스트 금지). *@
@using PlayGround.Client.Services.Feedback
@using PlayGround.Client.Styles
@using PlayGround.Contracts.Team
@inject TeamClient Teams
@inject ToastService Toasts

@if (IsOpen)
{
    <div class="@Css.MatchForm.Overlay">
        <div class="fixed inset-0" @onclick="CancelAsync"></div>

        <div class="@Css.MatchForm.Card">
            <span class="@Css.MatchForm.GrabBar"></span>

            <div class="@Css.MatchForm.Header">
                <span class="flex flex-col gap-1 min-w-0">
                    <h2 class="@Css.MatchForm.Title">@(IsEdit ? "리뷰 수정" : "리뷰 쓰기")</h2>
                    <span class="@Css.MatchForm.Subtitle">저장하면 공개 홈페이지 리뷰 탭에 바로 반영돼요. 팀은 리뷰를 삭제할 수 없어요.</span>
                </span>
                <button type="button" aria-label="닫기" class="@Css.MatchForm.CloseButton" @onclick="CancelAsync">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
                         stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg>
                </button>
            </div>

            <CascadingValue Value="@mForm" IsFixed="true">
                <div class="@Css.MatchForm.Body">
                    <div class="@Css.Form.FieldWrapper">
                        <label class="@Css.Form.Label">별점</label>
                        <div class="flex gap-1">
                            @for (int star = 1; star <= 5; star++)
                            {
                                int current = star;
                                <button type="button" aria-label="@($"{current}점")"
                                        class="@($"text-[26px] leading-none bg-transparent border-0 cursor-pointer p-0.5 transition-colors {(current <= mRating ? "text-orange" : "text-navy-muted")}")"
                                        @onclick="() => mRating = current">★</button>
                            }
                        </div>
                    </div>

                    <TextField Label="리뷰 내용" @bind-Value="mBody" Multiline="true" Rows="5"
                               Placeholder="팀 생활에서 실제로 겪은 이야기를 적어 주세요. 좋았던 점과 아쉬운 점 모두 다음 가족에게 도움이 돼요."
                               Validator="ValidateBody" MaxLength="500" />
                </div>

                <div class="@Css.MatchForm.Footer">
                    <button type="button" class="@Css.MatchForm.CancelButton" @onclick="CancelAsync">취소</button>
                    <SubmitButton Label="@(IsEdit ? "리뷰 저장" : "리뷰 올리기")" BusyLabel="저장 중…" IsBusy="@mSaving"
                                  OnClick="SubmitAsync" Class="@Css.MatchForm.SubmitWidth" />
                </div>
            </CascadingValue>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter, EditorRequired]
    public string TeamSlug { get; set; } = string.Empty;

    /// <summary>수정 대상 — null이면 신규 작성.</summary>
    [Parameter]
    public TeamReviewDto? Editing { get; set; }

    /// <summary>저장 성공 후 — 부모가 목록을 다시 불러온다.</summary>
    [Parameter]
    public EventCallback OnSaved { get; set; }

    private readonly FormFieldContext mForm = new();

    private int mRating = 5;
    private string mBody = string.Empty;
    private bool mSaving;
    private Guid mLoadedFor;

    private bool IsEdit => Editing is not null;

    protected override void OnParametersSet()
    {
        if (!IsOpen)
        {
            mLoadedFor = Guid.Empty;
            return;
        }

        // 열릴 때 1회 프리필 (수정) — 재렌더마다 입력을 덮어쓰지 않는다
        Guid target = Editing?.ReviewId ?? Guid.Empty;
        if (Editing is not null && mLoadedFor != target)
        {
            mLoadedFor = target;
            mRating = Editing.Rating;
            mBody = Editing.Body;
        }
    }

    private static string? ValidateBody(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "리뷰 내용을 입력해 주세요." : null;

    private async Task SubmitAsync()
    {
        bool fieldsValid = await mForm.ValidateAllAsync();
        if (!fieldsValid)
        {
            return;
        }

        var request = new SaveTeamReviewRequest
        {
            ReviewId = Editing?.ReviewId ?? Guid.Empty,
            TeamSlug = TeamSlug,
            Rating = mRating,
            Body = mBody.Trim(),
        };

        mSaving = true;
        RecruitmentSaveResult result = await Teams.SaveReviewAsync(request);
        mSaving = false;

        if (!result.Success)
        {
            if (result.IsNetworkError)
            {
                Toasts.ShowError(result.Error ?? "저장하지 못했어요.", "재시도", SubmitAsync);
            }
            else
            {
                Toasts.ShowError(result.Error ?? "저장하지 못했어요.");
            }

            return;
        }

        Toasts.ShowSuccess(IsEdit ? "리뷰를 저장했어요." : "리뷰를 올렸어요. 소중한 이야기 감사해요.");
        Reset();
        await IsOpenChanged.InvokeAsync(false);
        await OnSaved.InvokeAsync();
    }

    private async Task CancelAsync()
    {
        Reset();
        await IsOpenChanged.InvokeAsync(false);
    }

    private void Reset()
    {
        mRating = 5;
        mBody = string.Empty;
        mLoadedFor = Guid.Empty;
    }
}
