@* 모집 탭(모바일): 카드 세로 스택 — 문의 카드는 버튼 없이 문장으로 종료 (레퍼런스 그대로,
   입단 문의는 하단 고정 오렌지 CTA가 담당). "지원하기"는 지원 플로우 미구현이라 무동작 버튼. *@
@using PlayGround.Contracts.Team

<div class="flex flex-col gap-3">
    <h2 class="m-0 text-base font-extrabold text-navy-deep">선수 모집</h2>

    @foreach (TeamRecruitmentDto item in Data.Items)
    {
        @if (item.IsOpen)
        {
            <div class="bg-white border-1.5 border-border rounded-[15px] p-5 flex flex-col gap-[11px]">
                <div class="flex items-center gap-2">
                    <span class="text-[15px] font-extrabold text-navy-deep">@item.Title</span>
                    <span class="text-[10.5px] font-bold text-teal-ink bg-teal/[.12] rounded-full px-[9px] py-0.5 whitespace-nowrap">모집중</span>
                </div>
                <p class="m-0 text-[12.5px] text-text-body leading-[1.65] break-keep">@item.Description</p>
                @if (item.Conditions.Count > 0 || item.DeadlineDate is not null)
                {
                    <div class="flex gap-[7px] flex-wrap">
                        @foreach (string condition in item.Conditions)
                        {
                            <span class="text-[11px] font-bold text-text-strong bg-surface-icon rounded-full px-2.5 py-[3px] whitespace-nowrap">@condition</span>
                        }
                        @if (item.DeadlineDate is not null)
                        {
                            <span class="text-[11px] font-bold text-text-strong bg-surface-icon rounded-full px-2.5 py-[3px] whitespace-nowrap">마감 @PublicRecruitSection.DeadlineText(item)</span>
                        }
                    </div>
                }
                <button type="button" class="flex items-center justify-center h-11 rounded-[11px] bg-navy text-[13.5px] font-bold text-white whitespace-nowrap border-0 cursor-pointer">지원하기</button>
            </div>
        }
        else
        {
            <div class="bg-surface-soft border-1.5 border-border rounded-[15px] p-5 flex flex-col gap-2 opacity-75">
                <div class="flex items-center gap-2">
                    <span class="text-[15px] font-extrabold text-navy-deep">@item.Title</span>
                    <span class="text-[10.5px] font-bold text-text-muted bg-surface-icon rounded-full px-[9px] py-0.5 whitespace-nowrap">마감</span>
                </div>
                <p class="m-0 text-[12.5px] text-text-body leading-[1.65] break-keep">@item.Description</p>
            </div>
        }
    }

    <div class="bg-white border-1.5 border-border rounded-[15px] p-5 flex flex-col gap-2">
        <span class="text-sm font-extrabold text-navy-deep break-keep">모집 공고가 없어도 문의할 수 있어요</span>
        <span class="text-[12.5px] text-text-body break-keep">연령·포지션을 남겨주시면 자리가 생길 때 연락드립니다.</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public TeamRecruitmentsResponse Data { get; set; } = new();
}
