@* 선수단 탭(PC): 연령 pill + 사진 카드 grid(minmax 200px) — SPEC.TEAMPUBLICHOME.md ②
   공개 규칙: 이름·포지션·등번호·학년만. Claim 뱃지 비노출, Claimed 선수만 "공개 프로필 →".
   연령 pill은 전원 AgeGroup 보유 시만 노출 (대시보드 선수단과 동일 규칙) *@
@using PlayGround.Contracts.Team

<div class="flex flex-col gap-4">
    <div class="flex items-center gap-2.5">
        <h2 class="m-0 text-[19px] font-extrabold text-navy-deep">선수단 <span class="text-[13.5px] font-bold text-text-muted">@(Roster.Count)명</span></h2>
        <div class="flex-1"></div>
        @if (HasAgeTabs)
        {
            @foreach (SoccerAgeGroup age in AgeTabs)
            {
                SoccerAgeGroup tab = age;
                <button type="button" class="@PillClass(tab)" @onclick="() => mAgeTab = tab">@tab</button>
            }
        }
    </div>

    <div class="grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-3.5">
        @foreach (TeamPublicPlayerDto player in VisiblePlayers)
        {
            <div class="bg-white border-1.5 border-border rounded-[14px] px-3 pt-3 pb-4 flex flex-col items-center gap-2.5 text-center hover:border-navy hover:shadow-menu transition-all">
                <div class="w-full aspect-[4/3] rounded-[10px] overflow-hidden relative bg-surface-icon">
                    @if (player.PhotoUrl is not null)
                    {
                        <img src="@player.PhotoUrl" alt="@player.Name" class="absolute inset-0 w-full h-full object-cover" />
                    }
                    else
                    {
                        <span class="absolute inset-0 flex items-center justify-center">
                            <Avatar Name="@player.Name" Size="44" />
                        </span>
                    }
                    <span class="absolute top-[7px] left-[7px] w-7 h-7 rounded-full bg-navy-deep/85 flex items-center justify-center text-xs font-extrabold text-white pointer-events-none">@(player.JerseyNumber ?? "-")</span>
                </div>
                <span class="flex flex-col gap-0.5">
                    <span class="text-[14.5px] font-extrabold text-navy-deep whitespace-nowrap">@player.Name</span>
                    <span class="text-xs text-text-body whitespace-nowrap">@(player.Position ?? "-") · @(player.Grade ?? "-")</span>
                </span>
                @* "공개 프로필 →" 링크는 공개 선수 프로필(/player/{id})이 생길 때 붙인다 — # 링크는 랜딩 오이동 *@
            </div>
        }
    </div>

    @if (Roster.Count > 0)
    {
        <span class="text-[12.5px] text-text-muted break-keep">공개 프로필이 있는 선수만 상세 기록으로 연결됩니다. 이름·포지션 외 개인정보는 공개되지 않아요.</span>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public List<TeamPublicPlayerDto> Roster { get; set; } = new();

    private SoccerAgeGroup? mAgeTab;

    // 연령 pill은 전원이 AgeGroup을 가질 때만 (혼합·전부 null이면 pill 없이 전체 표시)
    private bool HasAgeTabs => Roster.Count > 0 && Roster.All(p => AgeOf(p) is not null);

    private List<SoccerAgeGroup> AgeTabs =>
        Roster
        .Select(AgeOf)
        .OfType<SoccerAgeGroup>()
        .Distinct()
        .OrderBy(age => age)
        .ToList();

    private IEnumerable<TeamPublicPlayerDto> VisiblePlayers =>
        HasAgeTabs && mAgeTab is not null ? Roster.Where(p => AgeOf(p) == mAgeTab) : Roster;

    protected override void OnParametersSet()
    {
        if (HasAgeTabs && (mAgeTab is null || !AgeTabs.Contains(mAgeTab.Value)))
        {
            mAgeTab = AgeTabs[0];
        }
    }

    private static SoccerAgeGroup? AgeOf(TeamPublicPlayerDto player) =>
        SoccerAgeGroupExtensions.ParseAgeGroupOrNull(player.AgeGroup);

    private string PillClass(SoccerAgeGroup tab) =>
        "h-[34px] px-3.5 rounded-full text-[12.5px] font-bold border-1.5 whitespace-nowrap cursor-pointer transition-colors " +
        (mAgeTab == tab ? "border-navy bg-navy text-white" : "border-border bg-white text-text-body");
}
