@* 경기기록 GNB — 브랜드 + 구분선 + "경기기록", 우측은 로그인 개인화 표시 (비로그인이면 비움) *@

<header class="bg-bg border-b border-border sticky top-0 z-50">
    <div class="max-w-[1100px] mx-auto px-4 md:px-8 h-[54px] md:h-[60px] flex items-center gap-3 md:gap-4">
        <BrandLogo Href="@Routes.Landing" Compact="true" />
        <span class="w-px h-4 bg-border shrink-0"></span>
        <span class="text-[13px] font-bold text-text-strong whitespace-nowrap">경기기록</span>
        <div class="flex-1"></div>
        @if (UserLabel is not null)
        {
            <span class="flex items-center gap-[7px] text-[12.5px] font-bold text-text-strong whitespace-nowrap">
                <span class="w-[26px] h-[26px] rounded-full bg-teal flex items-center justify-center text-[11px] font-extrabold text-white">@UserInitial</span>
                @UserLabel
            </span>
        }
    </div>
</header>

@code {
    [Parameter]
    public string? UserLabel { get; set; }   // 예: "김OO 님 · U15 보호자"

    [Parameter]
    public string? UserInitial { get; set; }
}
