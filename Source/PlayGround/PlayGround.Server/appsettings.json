{
  "//": [
    "이 파일(appsettings.json)은 커밋되는 공통 설정 — 시크릿 금지.",
    "시크릿(Jwt:Key, OAuth ClientId/ClientSecret, 실 DB 커넥션 등)은 여기 두지 말 것.",
    "로컬 개발: appsettings.Local.json 을 만들어 넣는다 (gitignore되어 커밋 안 됨). appsettings.Local.json.example 를 복사해서 채우면 된다.",
    "Staging/Production: 호스트 환경변수로 주입 (예: Jwt__Key, OAuth__Google__ClientSecret). '__'가 계층 구분자다."
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "LoggingConfig": {
    "LogLevel": "Info",
    "EnableFileLogging": true,
    "EnableConsoleLogging": true,
    "MaxArchiveFiles": 30
  },
  "DatabaseConfiguration": {
    "Databases": {
      "Account": {
        "Provider": "SqlServer",
        "ConnectionString": ""
      },
      "Soccer": {
        "Provider": "SqlServer",
        "ConnectionString": ""
      }
    }
  },
  "OAuth": {
    "Google": {
      "AuthorizationEndpoint": "https://accounts.google.com/o/oauth2/v2/auth",
      "TokenEndpoint": "https://oauth2.googleapis.com/token",
      "UserInfoEndpoint": "https://www.googleapis.com/oauth2/v2/userinfo",
      "Scope": "openid email profile"
    },
    "Kakao": {
      "AuthorizationEndpoint": "https://kauth.kakao.com/oauth/authorize",
      "TokenEndpoint": "https://kauth.kakao.com/oauth/token",
      "UserInfoEndpoint": "https://kapi.kakao.com/v2/user/me"
    },
    "Line": {
      "AuthorizationEndpoint": "https://access.line.me/oauth2/v2.1/authorize",
      "TokenEndpoint": "https://api.line.me/oauth2/v2.1/token",
      "Scope": "profile openid email"
    }
  }
}
