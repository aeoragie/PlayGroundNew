# 빌드 출력 (Directory.Build.props에서 중앙 관리)
Binary/
Intermediate/
[Bb]in/
[Oo]bj/

# 제너레이터 생성 코드는 커밋한다 (수동 실행 단계라 clone 즉시 빌드되도록).
# Generated/ 는 의도적으로 ignore하지 않음.

# IDE
.vs/
.vscode/
*.user
*.suo

# SQL 프로젝트(SSDT) 로컬 캐시 — 소스 아님
*.dbmdl
*.jfm

# 테스트/커버리지
TestResults/
*.trx
coverage*.json
coverage*.xml

# Node (Tailwind 빌드)
node_modules/

# 로그
Logs/
*.log

# 로컬 설정 (민감정보)
appsettings.Local.json
appsettings.*.Local.json
.env

# 업로드된 사용자 이미지 (로컬 저장소 어댑터) — 소스가 아니다
Source/PlayGround/PlayGround.Server/wwwroot/uploads/

# 검증 스크린샷 — 산출물이지 소스가 아니다
Source/Tools/Verification/*.png
